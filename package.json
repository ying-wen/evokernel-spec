{
  "name": "evokernel-spec",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=22.0.0", "pnpm": ">=9.0.0" },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "validate": "tsx scripts/validate-data.ts",
    "check-links": "tsx scripts/check-evidence-links.ts",
    "audit:data": "tsx scripts/audit-data.ts",
    "agent:deploy": "tsx scripts/agent-deploy/index.ts",
    "agent:deploy:productized": "tsx scripts/agent-deploy/index.ts --use-llm-orchestrator",
    "agent:list-bundles": "tsx scripts/agent-deploy/list-bundles.ts",
    "agent:auto-pr": "tsx scripts/agent-deploy/auto-pr-cli.ts",
    "agent:install": "tsx scripts/agent-deploy/install-plugin.ts",
    "agent:doctor": "tsx scripts/agent-deploy/doctor.ts",
    "agent:status": "tsx scripts/agent-deploy/status.ts",
    "test": "pnpm --filter web test && pnpm --filter @evokernel/schemas test && pnpm --filter @evokernel/scripts test",
    "test:e2e": "pnpm --filter web exec playwright test site",
    "lint": "biome check .",
    "format": "biome format --write .",
    "launch": "./launch.sh",
    "launch:fast": "./launch.sh --no-build --no-validate",
    "launch:stop": "./launch.sh --stop",
    "health": "curl -sf http://127.0.0.1:4321/api/health.json | head -30",
    "pack:dist": "tsx scripts/pack-dist.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
