---
import '~/styles/global.css';
import Nav from '~/components/ui/Nav.astro';
import Footer from '~/components/ui/Footer.astro';
import Analytics from '~/components/impact/Analytics.astro';
import type { Locale } from '~/lib/i18n';
import { pathname } from '~/lib/i18n';

interface Props {
  title: string;
  description?: string;
  noIndex?: boolean;
  ogImage?: string;
  locale?: Locale;
}

// Auto-detect locale from URL prefix if not explicitly set
const path = Astro.url.pathname;
const derivedLocale: Locale = path.startsWith('/en/') || path === '/en' ? 'en' : 'zh';

const {
  title,
  description = derivedLocale === 'en'
    ? 'Open knowledge base for AI inference hardware, frontier models, and deployment cases. Most comprehensive Chinese accelerator coverage, transparent calculator.'
    : 'AI 推理硬件 × 模型 × 部署的开源知识库。覆盖国产芯片最全, 数据带 evidence 引证, 计算器透明。',
  noIndex = false,
  ogImage,
  locale = derivedLocale
} = Astro.props;

const pageTitle = `${title} · EvoKernel Spec`;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://evokernel.dev').toString();
const ogImageUrl = ogImage ?? new URL('/og-default.svg', Astro.site ?? 'https://evokernel.dev').toString();
const skipText = locale === 'en' ? 'Skip to main content' : '跳转到主内容';
const ogLocale = locale === 'en' ? 'en_US' : 'zh_CN';
const htmlLang = locale === 'en' ? 'en' : 'zh';

// hreflang alternates: every page has zh + en pair.
// Astro.url.pathname includes the deploy base (e.g. /evokernel-spec/), so we
// strip the base, do the locale-prefix swap on the bare path, then re-prepend
// the base. Otherwise we'd get malformed /en/evokernel-spec/... URLs.
const BASE_RAW = import.meta.env.BASE_URL ?? '/';
const BASE = BASE_RAW === '/' ? '' : BASE_RAW.replace(/\/$/, '');
const stripBase = (p: string) => (BASE && p.startsWith(BASE) ? p.slice(BASE.length) || '/' : p);
const bare = stripBase(path); // path without deploy-base prefix
const barePathZh = bare.startsWith('/en/') ? bare.replace(/^\/en/, '') || '/' : bare === '/en' ? '/' : bare;
const barePathEn = bare.startsWith('/en/') || bare === '/en' ? bare : '/en' + (bare === '/' ? '/' : bare);
const altPathZh = BASE + barePathZh;
const altPathEn = BASE + barePathEn;
const altUrlZh = new URL(altPathZh, Astro.site ?? 'https://evokernel.dev').toString();
const altUrlEn = new URL(altPathEn, Astro.site ?? 'https://evokernel.dev').toString();
---
<!DOCTYPE html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="zh" href={altUrlZh} />
    <link rel="alternate" hreflang="en" href={altUrlEn} />
    <link rel="alternate" hreflang="x-default" href={altUrlZh} />
    {noIndex && <meta name="robots" content="noindex" />}

    <!-- OpenGraph / Twitter -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="EvoKernel Spec" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- RSS auto-discovery -->
    <link rel="alternate" type="application/rss+xml" title="EvoKernel Spec — Cases" href={pathname('/cases.xml')} />

    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E⚛%3C/text%3E%3C/svg%3E" type="image/svg+xml" />

    <slot name="head" />
    <Analytics />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main-content" class="skip-link">{skipText}</a>
    <Nav locale={locale} />
    <main id="main-content" class="flex-1" data-pagefind-body><slot /></main>
    <Footer locale={locale} />
    <style is:global>
      .skip-link {
        position: absolute;
        left: -9999px;
        top: 1rem;
        z-index: 100;
        background: var(--color-accent);
        color: white;
        padding: 0.5rem 1rem;
        border-radius: 0.375rem;
        text-decoration: none;
        font-weight: 600;
      }
      .skip-link:focus {
        left: 1rem;
      }
    </style>
  </body>
</html>
