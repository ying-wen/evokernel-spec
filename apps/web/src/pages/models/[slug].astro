---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import KpiCard from '~/components/ui/KpiCard.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import Badge from '~/components/ui/Badge.astro';
import { getModels, getResolvedHardware, getHardware, getCases, getPlaybooks, getModelGraphs } from '~/lib/data';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';
import { modelLD, breadcrumbLD } from '~/lib/jsonld';
import RecommendedHardware from '~/components/model/RecommendedHardware.astro';
import RecommendedPlaybooks from '~/components/playbook/RecommendedPlaybooks.astro';
import { findPlaybooksForModel, inferModelArchetype } from '~/lib/playbook-match';

export async function getStaticPaths() {
  const models = await getModels();
  return models.map((m) => ({ params: { slug: m.id }, props: { model: m } }));
}

const { model } = Astro.props;
const arch = model.architecture;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://evokernel.dev').toString();
const ldModel = modelLD(model, canonicalUrl);
const ldCrumbs = breadcrumbLD([
  { name: '首页', url: new URL('/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: '模型', url: new URL('/models/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: model.name, url: canonicalUrl }
]);
const hardware = await getResolvedHardware();
const hardwareRaw = await getHardware();
const cases = await getCases();
const allPlaybooks = await getPlaybooks();
const matchingPlaybooks = findPlaybooksForModel(model, allPlaybooks);
const modelArchetype = inferModelArchetype(model);

// v2.8: execution graphs for this model (per-phase)
const allGraphs = await getModelGraphs();
const modelGraphs = allGraphs.filter((g) => g.model_id === model.id);

function statusOnHw(hwId: string): 'measured' | 'claimed' | 'unknown' {
  const has = cases.some((c) => c.stack.hardware.id === hwId && c.stack.model.id === model.id);
  return has ? 'measured' : 'unknown';
}
const colorMap = { measured: 'var(--color-tier-measured)', claimed: 'var(--color-tier-estimated)', unknown: 'var(--color-text-muted)' };
const labelMap = { measured: '🟢 实测', claimed: '🟡 声称', unknown: '— 未知' };
---
<BaseLayout title={model.name}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldModel)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldCrumbs)} />
  </Fragment>
  <Container>
    <section class="pt-12 pb-3">
      <Breadcrumbs items={[
        { name: '首页', href: '/' },
        { name: '模型', href: '/models/' },
        { name: model.name }
      ]} />
    </section>
    <section class="pt-3 pb-6">
      <h1 style="font-size: clamp(2rem, 1.5rem + 1.5vw, 3rem); font-weight: 600;">{model.name}</h1>
      <div class="flex gap-2 mt-3 flex-wrap">
        <Badge>{model.lab}</Badge>
        <Badge variant={arch.family === 'moe' ? 'accent' : 'default'}>{arch.family.toUpperCase()}</Badge>
        {model.modalities.map((m) => <Badge>{m}</Badge>)}
        <Badge>{model.license}</Badge>
        <Badge>{model.release_date}</Badge>
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">架构</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <KpiCard label="Total params"><span style="font-size: 1.5rem;">{arch.total_params_b}<span class="text-base opacity-60"> B</span></span></KpiCard>
        <KpiCard label="Active params"><span style="font-size: 1.5rem;">{arch.active_params_b}<span class="text-base opacity-60"> B</span></span></KpiCard>
        <KpiCard label="Layers"><span style="font-size: 1.5rem;">{arch.layers}</span></KpiCard>
        {arch.max_context_length !== undefined ? (
          <KpiCard label="Context"><span style="font-size: 1.5rem;">{(arch.max_context_length / 1024).toFixed(0)}<span class="text-base opacity-60"> k</span></span></KpiCard>
        ) : (
          <KpiCard label="Family"><span style="font-size: 1.25rem;">{arch.family}</span></KpiCard>
        )}
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">详细规格</h3>
      <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <SpecRow label="Hidden size">{arch.hidden_size}</SpecRow>
        {arch.ffn_size !== undefined && <SpecRow label="FFN size">{arch.ffn_size}</SpecRow>}
        {arch.num_attention_heads !== undefined && <SpecRow label="Attention heads">{arch.num_attention_heads}</SpecRow>}
        {arch.num_kv_heads !== undefined && <SpecRow label="KV heads">{arch.num_kv_heads}</SpecRow>}
        {arch.head_dim !== undefined && <SpecRow label="Head dim">{arch.head_dim}</SpecRow>}
        {arch.vocab_size !== undefined && <SpecRow label="Vocab size">{arch.vocab_size}</SpecRow>}
        <SpecRow label="Attention type">{arch.attention_type}</SpecRow>
        {arch.moe && (<>
          <SpecRow label="MoE experts">{arch.moe.num_experts}</SpecRow>
          <SpecRow label="MoE top-k">{arch.moe.top_k}</SpecRow>
          <SpecRow label="Expert hidden">{arch.moe.expert_hidden_size}</SpecRow>
        </>)}
      </div>
    </section>

    {model.operator_decomposition.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">算子拆解 (per token)</h3>
        <div class="overflow-x-auto rounded-lg border" style="border-color: var(--color-border);">
          <table class="w-full text-sm">
            <thead style="background: var(--color-surface);">
              <tr>
                <th class="text-left px-4 py-2">算子</th>
                <th class="text-right px-4 py-2">FLOPs / token</th>
                <th class="text-right px-4 py-2">Bytes / token</th>
              </tr>
            </thead>
            <tbody>
              {model.operator_decomposition.map((op) => (
                <tr class="border-t" style="border-color: var(--color-border);">
                  <td class="px-4 py-2 font-medium"><a href={pathname(`/operators/${op.operator}/`)} class="underline" style="color: var(--color-accent);">{op.operator}</a></td>
                  <td class="px-4 py-2 text-right font-mono">{op.flops_per_token.toExponential(2)}</td>
                  <td class="px-4 py-2 text-right font-mono">{op.bytes_per_token.toExponential(2)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {model.operator_decomposition.length > 0 && (
      <RecommendedHardware model={model} hardware={hardwareRaw} cases={cases} locale="zh" />
    )}

    <RecommendedPlaybooks playbooks={matchingPlaybooks} pivot="model" inferredLabel={modelArchetype} />

    {/* v2.8: Model execution graph(s) */}
    {modelGraphs.length > 0 && (
      <section class="pb-8" id="execution-graph">
        <h3 class="text-lg font-semibold mb-3">🔀 Execution graph <span class="text-xs ml-2 font-normal" style="color: var(--color-text-muted);">v2.8 — 智能体 codegen 输入</span></h3>
        <p class="text-sm mb-4 max-w-3xl" style="color: var(--color-text-muted);">
          逐 op 的执行序列 + shape 模板. 智能体把 model arch 解析为 op 调用顺序时的核心数据.
          结合 operator FLOPs/bytes 公式 + hardware specs, 可以在不实际跑的前提下预测 per-token 资源.
        </p>
        {modelGraphs.map((g) => (
          <details class="rounded-lg border mb-3" style="background: var(--color-surface-raised); border-color: var(--color-border);">
            <summary class="p-4 cursor-pointer flex items-center gap-3 flex-wrap">
              <Badge variant="accent">{g.phase}</Badge>
              <span class="font-semibold">{g.layer_count} layers · {g.per_layer_ops.length} ops/layer</span>
              <span class="text-xs" style="color: var(--color-text-muted);">{g.pre_layer_ops.length} pre + {g.post_layer_ops.length} post</span>
            </summary>
            <div class="px-4 pb-4">
              {Object.keys(g.placeholder_definitions).length > 0 && (
                <div class="mb-3">
                  <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">Placeholders</div>
                  <div class="flex gap-1 flex-wrap">
                    {Object.entries(g.placeholder_definitions).map(([k, v]) => (
                      <span style="font-size: 0.7rem; padding: 2px 6px; background: color-mix(in oklch, var(--color-border) 30%, transparent); border-radius: 3px; font-family: var(--font-mono);">
                        <strong>{k}</strong>: {v}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              <div>
                <div class="text-xs font-semibold mb-2" style="color: var(--color-text-muted);">Per-layer ops ({g.per_layer_ops.length})</div>
                <ol class="space-y-1.5">
                  {g.per_layer_ops.map((op) => (
                    <li class="text-xs rounded p-2 border" style="background: var(--color-bg); border-color: color-mix(in oklch, var(--color-border) 60%, transparent);">
                      <div class="flex items-baseline gap-2 flex-wrap">
                        <span class="font-mono shrink-0" style="color: var(--color-accent); font-weight: 600;">{op.order}.</span>
                        <a href={pathname(`/operators/${op.op_id}/`)} class="hover:underline" style="color: var(--color-accent);">{op.op_id}</a>
                        {op.label && <span style="color: var(--color-text-muted);">— {op.label}</span>}
                        {op.repeat_per_layer > 1 && <span style="color: var(--color-accent); font-size: 0.65rem;">×{op.repeat_per_layer}</span>}
                      </div>
                      {Object.keys(op.shape_template).length > 0 && (
                        <div class="mt-1" style="font-family: var(--font-mono); font-size: 0.65rem; color: var(--color-text-muted);">
                          {Object.entries(op.shape_template).map(([k, v]) => (
                            <span class="mr-3">{k}: {v}</span>
                          ))}
                        </div>
                      )}
                      {op.notes && <div class="text-xs mt-1" style="color: var(--color-text-muted); font-style: italic;">{op.notes}</div>}
                    </li>
                  ))}
                </ol>
              </div>

              {g.notes && (
                <div class="mt-3 pt-3 border-t" style="border-color: color-mix(in oklch, var(--color-border) 50%, transparent);">
                  <div class="text-xs whitespace-pre-line" style="color: var(--color-text-muted);">{g.notes}</div>
                </div>
              )}
            </div>
          </details>
        ))}
      </section>
    )}

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">兼容硬件</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
        {hardware.map((h) => {
          const s = statusOnHw(h.id);
          return (
            <a href={pathname(`/hardware/${h.id}`)} class="flex items-center gap-2 p-3 rounded border text-sm transition-transform hover:translate-x-0.5"
               style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <span class="text-xs" style={`color: ${colorMap[s]};`}>{labelMap[s]}</span>
              <span>{h.name}</span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="pb-12">
      <div class="flex flex-wrap gap-3">
        <a href={pathname(`/calculator/?model=${model.id}`)}
           class="inline-block px-5 py-2 rounded-md font-medium"
           style="background: var(--color-accent); color: white;">
          在计算器中评估 →
        </a>
        <a href={pathname(`/calculator/?model=${model.id}&hw=h100-sxm5`)}
           class="inline-block px-5 py-2 rounded-md font-medium border"
           style="border-color: var(--color-border); color: var(--color-text);">
          预设 8× H100
        </a>
        <a href={pathname(`/calculator/?model=${model.id}&hw=ascend-910c`)}
           class="inline-block px-5 py-2 rounded-md font-medium border"
           style="border-color: var(--color-china); color: var(--color-china);">
          预设 8× 昇腾 910C
        </a>
        <a href={pathname(`/calculator/?model=${model.id}&hw=mi355x&prec=fp4`)}
           class="inline-block px-5 py-2 rounded-md font-medium border"
           style="border-color: var(--color-border); color: var(--color-text);">
          预设 8× MI355X (FP4)
        </a>
      </div>
    </section>
  </Container>
</BaseLayout>
