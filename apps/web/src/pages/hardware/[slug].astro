---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import KpiCard from '~/components/ui/KpiCard.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import Badge from '~/components/ui/Badge.astro';
import TierChip from '~/components/ui/TierChip.astro';
import { getResolvedHardware, getCases, getEngines, getQuantizations, getModels, getHardware, getOperators, getServers, getPlaybooks } from '~/lib/data';
import { buildEfficiencyMap, getEfficiency } from '~/lib/calculator';
import Topology from '~/components/hardware/Topology.astro';
import RecommendedModels from '~/components/hardware/RecommendedModels.astro';
import RecommendedPlaybooks from '~/components/playbook/RecommendedPlaybooks.astro';
import { findPlaybooksForHardware, inferHardwareClass } from '~/lib/playbook-match';
import MemoryHierarchy from '~/components/hardware/MemoryHierarchy.astro';
import OperatorFitnessMatrix from '~/components/hardware/OperatorFitnessMatrix.astro';
import SuperPodAtlas from '~/components/hardware/SuperPodAtlas.astro';
import OperatorCoverage from '~/components/hardware/OperatorCoverage.astro';
import Substitutes from '~/components/hardware/Substitutes.astro';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';
import { hardwareLD, breadcrumbLD } from '~/lib/jsonld';
import { buildMeta, lastUpdatedFor } from '~/lib/build-meta';
import VendorBadge from '~/components/ui/VendorBadge.astro';
import QuickEstimates from '~/components/hardware/QuickEstimates.astro';

export async function getStaticPaths() {
  const all = await getResolvedHardware();
  return all.map((h) => ({ params: { slug: h.id }, props: { hw: h } }));
}

const { hw } = Astro.props;
const isChina = hw.vendor.country === 'CN';
const allCases = await getCases();
const relatedCases = allCases.filter((c) => c.stack.hardware.id === hw.id).sort((a, b) => b.submitted_at.localeCompare(a.submitted_at));
const allEngines = await getEngines();
const allQuants = await getQuantizations();

const tierFor = (ref?: string) => {
  if (!ref) return 'official' as const;
  return hw.evidence.find((e) => e.id === ref)?.tier ?? 'official' as const;
};

const c = hw.compute;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://evokernel.dev').toString();
const ldHardware = hardwareLD(hw, canonicalUrl);
const ldBreadcrumbs = breadcrumbLD([
  { name: '首页', url: new URL('/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: '硬件', url: new URL('/hardware/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: hw.name, url: canonicalUrl }
]);
const meta = buildMeta();
const allHardwareRaw = await getHardware();
const allModels = await getModels();
const efficiencyMap = buildEfficiencyMap(allCases, allHardwareRaw, allModels);
const efficiency = getEfficiency(hw.id, efficiencyMap);
const allPlaybooks = await getPlaybooks();
const matchingPlaybooks = findPlaybooksForHardware(hw, allPlaybooks);
const hardwareClass = inferHardwareClass(hw);
// Source yaml path (vendored under <vendor-id>/<hw-id>.yaml)
const sourcePath = `data/hardware/${hw.vendor.id}/${hw.id}.yaml`;
const lastUpdated = lastUpdatedFor(sourcePath) || meta.builtAt;
---
<BaseLayout title={hw.name}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldHardware)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldBreadcrumbs)} />
  </Fragment>
  <Container>
    <section class="pt-12 pb-3">
      <Breadcrumbs items={[
        { name: '首页', href: '/' },
        { name: '硬件', href: '/hardware/' },
        { name: hw.name }
      ]} />
    </section>
    <section class="pt-3 pb-6">
      <header class="flex items-center gap-3 mb-4">
        <VendorBadge vendorId={hw.vendor.id} vendorName={hw.vendor.name} country={hw.vendor.country} size="md" />
        <a href={pathname(`/vendors/${hw.vendor.id}/`)} class="text-sm font-medium underline" style={`color: ${isChina ? 'var(--color-china)' : 'var(--color-text-muted)'};`}>
          {isChina ? (hw.vendor.chinese_names[0] ?? hw.vendor.name) : hw.vendor.name}
        </a>
        {isChina && <Badge variant="china">国产</Badge>}
        <span class="ml-auto text-xs font-mono" style="color: var(--color-text-muted);" title={`Source last modified: ${lastUpdated}`}>
          Last verified <time datetime={lastUpdated}>{lastUpdated.slice(0, 10)}</time>
        </span>
      </header>
      <h1 style="font-size: clamp(2rem, 1.5rem + 1.5vw, 3rem); font-weight: 600;">{hw.name}</h1>
      <div class="flex gap-2 mt-3 flex-wrap">
        <Badge>{hw.form_factor.toUpperCase()}</Badge>
        <Badge>{hw.status === 'in-production' ? '在售' : hw.status}</Badge>
        <Badge>发布于 {hw.release_year}</Badge>
        <Badge>{hw.generation}</Badge>
      </div>
    </section>

    <nav class="hw-toc sticky py-2 mb-2" aria-label="In-page sections" style="top: 4rem; z-index: 15; background: color-mix(in oklch, var(--color-bg) 88%, transparent); backdrop-filter: blur(8px);">
      <div class="flex gap-1 flex-wrap text-xs">
        <a href="#specs" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">规格 Specs</a>
        {hw.architecture && <a href="#architecture" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">架构 Arch</a>}
        <a href="#interconnect" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">互联 Interconnect</a>
        <a href="#topology" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">拓扑 Topology</a>
        <a href="#models" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">适配模型 Models</a>
        <a href="#operators" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">算子 Operators</a>
        <a href="#substitutes" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">替代品 Substitutes</a>
        <a href="#engines" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">引擎 Engines</a>
        <a href="#cases" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">案例 Cases</a>
        <a href="#citations" class="px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">引证 Citations</a>
      </div>
    </nav>

    <section class="pb-8">
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3">
        <KpiCard label="BF16" sublabel="TFLOP/s">
          {c.bf16_tflops ? (
            <>{c.bf16_tflops.value} <TierChip tier={tierFor(c.bf16_tflops.evidence_ref)} /></>
          ) : '—'}
        </KpiCard>
        <KpiCard label="FP8" sublabel="TFLOP/s">
          {c.fp8_tflops ? (
            <>{c.fp8_tflops.value} <TierChip tier={tierFor(c.fp8_tflops.evidence_ref)} /></>
          ) : '不支持'}
        </KpiCard>
        <KpiCard label="FP4" sublabel="TFLOP/s">
          {c.fp4_tflops ? (
            <>{c.fp4_tflops.value} <TierChip tier={tierFor(c.fp4_tflops.evidence_ref)} /></>
          ) : '不支持'}
        </KpiCard>
        <KpiCard label="Memory" sublabel="GB">
          {hw.memory.capacity_gb ? (
            <>{hw.memory.capacity_gb.value} <TierChip tier={tierFor(hw.memory.capacity_gb.evidence_ref)} /></>
          ) : '—'}
        </KpiCard>
        <KpiCard label="Mem BW" sublabel="GB/s">
          {hw.memory.bandwidth_gbps ? (
            <>{hw.memory.bandwidth_gbps.value} <TierChip tier={tierFor(hw.memory.bandwidth_gbps.evidence_ref)} /></>
          ) : '—'}
        </KpiCard>
        <KpiCard label="TDP" sublabel="W">
          {hw.power.tdp_w ? (
            <>{hw.power.tdp_w.value} <TierChip tier={tierFor(hw.power.tdp_w.evidence_ref)} /></>
          ) : '—'}
        </KpiCard>
      </div>
    </section>

    <section class="pb-8" id="specs">
      <h3 class="text-lg font-semibold mb-3">完整规格</h3>
      <div class="grid lg:grid-cols-2 gap-6">
        <div>
          <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">算力</h4>
          <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <SpecRow label="FP4 TFLOPS">{c.fp4_tflops?.value ?? '不支持'}</SpecRow>
            <SpecRow label="FP8 TFLOPS">{c.fp8_tflops?.value ?? '不支持'}</SpecRow>
            <SpecRow label="BF16 TFLOPS">{c.bf16_tflops?.value ?? '—'}</SpecRow>
            <SpecRow label="FP16 TFLOPS">{c.fp16_tflops?.value ?? '—'}</SpecRow>
            <SpecRow label="INT8 TOPS">{c.int8_tops?.value ?? '—'}</SpecRow>
          </div>
        </div>
        <div>
          <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">显存</h4>
          <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <SpecRow label="容量">{hw.memory.capacity_gb?.value} GB</SpecRow>
            <SpecRow label="带宽">{hw.memory.bandwidth_gbps?.value} GB/s</SpecRow>
            <SpecRow label="类型">{hw.memory.type}</SpecRow>
          </div>
        </div>
      </div>
      {hw.architecture && (
        <div class="mt-6" id="architecture">
          <h4 class="text-sm font-semibold mb-2 flex items-center gap-2" style="color: var(--color-text-muted);">
            <span>芯片架构</span>
            <span class="text-xs px-1.5 py-0.5 rounded" style="background: color-mix(in oklch, var(--color-tier-measured) 14%, var(--color-bg)); color: var(--color-tier-measured); font-weight: 600;">🟢 vendor floorplan</span>
          </h4>
          <div class="grid md:grid-cols-2 gap-3">
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              {hw.architecture.compute_unit_count && <SpecRow label={`${hw.architecture.compute_unit_label ?? 'CU'} count`}>{hw.architecture.compute_unit_count.value}</SpecRow>}
              {hw.architecture.tensor_cores_per_cu && <SpecRow label={`Tensor cores / ${hw.architecture.compute_unit_label ?? 'CU'}`}>{hw.architecture.tensor_cores_per_cu.value}</SpecRow>}
              {hw.architecture.l2_cache_mb && <SpecRow label="L2 cache">{hw.architecture.l2_cache_mb.value} MB</SpecRow>}
              {hw.architecture.l1_cache_kb_per_cu && <SpecRow label="L1$ / CU">{hw.architecture.l1_cache_kb_per_cu.value} KB</SpecRow>}
              {hw.architecture.hbm_stacks && <SpecRow label="HBM stacks">{hw.architecture.hbm_stacks.value}</SpecRow>}
            </div>
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              {hw.architecture.process_node_nm && <SpecRow label="制程">{hw.architecture.process_node_nm.value} nm</SpecRow>}
              {hw.architecture.die_area_mm2 && <SpecRow label="Die area">{hw.architecture.die_area_mm2.value} mm²</SpecRow>}
              {hw.architecture.transistor_count_b && <SpecRow label="Transistors">{hw.architecture.transistor_count_b.value} B</SpecRow>}
              {hw.architecture.pcie_gen && <SpecRow label="PCIe">Gen {hw.architecture.pcie_gen.value} ×{hw.architecture.pcie_lanes?.value ?? 16}</SpecRow>}
            </div>
          </div>
          {(hw.architecture.memory_hierarchy?.length ?? 0) > 0 && (
            <div class="mt-4">
              <MemoryHierarchy hw={hw} />
            </div>
          )}
        </div>
      )}
    </section>

    {/* v2.1: power-thermal envelope detail (only when extended fields present) */}
    {(hw.power.cooling || hw.power.sustained_w || hw.power.fp16_tflops_per_watt || hw.power.operating_temp_c || hw.power.power_connector) && (
      <section class="pb-8" id="power-thermal">
        <h3 class="text-lg font-semibold mb-3">⚡ 电源 / 散热</h3>
        <div class="grid lg:grid-cols-2 gap-6">
          <div>
            <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">功耗</h4>
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              {hw.power.tdp_w && <SpecRow label="TDP">{hw.power.tdp_w.value} W</SpecRow>}
              {hw.power.sustained_w && <SpecRow label="Sustained (持续)">{hw.power.sustained_w.value} W</SpecRow>}
              {hw.power.peak_w && <SpecRow label="Peak (峰值)">{hw.power.peak_w.value} W</SpecRow>}
              {hw.power.fp16_tflops_per_watt && <SpecRow label="fp16 TFLOPS / W">{hw.power.fp16_tflops_per_watt.value}</SpecRow>}
              {hw.power.int8_tops_per_watt && <SpecRow label="int8 TOPS / W">{hw.power.int8_tops_per_watt.value}</SpecRow>}
              {hw.power.power_connector && <SpecRow label="连接器">{hw.power.power_connector}</SpecRow>}
            </div>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">散热 / 温度</h4>
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              {hw.power.cooling && <SpecRow label="散热类型">{hw.power.cooling}</SpecRow>}
              {hw.power.operating_temp_c && (
                <SpecRow label="工作温度 (°C)">
                  {hw.power.operating_temp_c.min ?? '—'} ~ {hw.power.operating_temp_c.max ?? '—'}
                </SpecRow>
              )}
              {hw.power.throttle_temp_c && <SpecRow label="Throttle 温度">{hw.power.throttle_temp_c} °C</SpecRow>}
            </div>
            {hw.power.notes && (
              <p class="text-xs mt-3" style="color: var(--color-text-muted);">{hw.power.notes}</p>
            )}
          </div>
        </div>
        <p class="text-xs mt-4" style="color: var(--color-text-muted);">
          → 横向对比所有卡的电源 / 散热: <a href={pathname('/hardware/power-thermal-matrix/')} class="underline" style="color: var(--color-accent);">/hardware/power-thermal-matrix/</a>
        </p>
      </section>
    )}

    <section class="pb-8" id="interconnect">
      <div class="grid lg:grid-cols-2 gap-6">
        <div>
          <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">Scale-Up (节点内)</h4>
          <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <SpecRow label="协议">{hw.scale_up.protocol}</SpecRow>
            <SpecRow label="单链带宽">{hw.scale_up.bandwidth_gbps} GB/s</SpecRow>
            <SpecRow label="World size">{hw.scale_up.world_size}</SpecRow>
            <SpecRow label="拓扑">{hw.scale_up.topology}</SpecRow>
            <SpecRow label="交换机">{hw.scale_up.switch ?? '—'}</SpecRow>
          </div>
        </div>
        <div>
          <h4 class="text-sm font-semibold mb-2" style="color: var(--color-text-muted);">Scale-Out (节点间)</h4>
          <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <SpecRow label="单卡出口">{hw.scale_out.bandwidth_gbps_per_card} Gbps</SpecRow>
            <SpecRow label="协议">{hw.scale_out.protocol}</SpecRow>
            <SpecRow label="NIC">{hw.scale_out.nic ?? '—'}</SpecRow>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-8" id="topology">
      <h3 class="text-lg font-semibold mb-3">拓扑示意</h3>
      <Topology hw={hw} />
    </section>

    <section class="pb-8" id="super-pod">
      <SuperPodAtlas hw={allHardwareRaw.find((x) => x.id === hw.id)!} servers={await getServers()} />
    </section>

    <section class="pb-4" id="recommended">
      <RecommendedModels
        hardware={allHardwareRaw.find((x) => x.id === hw.id)!}
        allHardware={allHardwareRaw}
        models={allModels}
        cases={allCases}
        locale="zh"
      />
    </section>

    <section class="pb-4" id="playbooks">
      <RecommendedPlaybooks playbooks={matchingPlaybooks} pivot="hardware" inferredLabel={hardwareClass} />
    </section>

    <section class="pb-8" id="models">
      <h3 class="text-lg font-semibold mb-3">能跑哪些模型? · QuickEstimates</h3>
      <QuickEstimates hw={allHardwareRaw.find((x) => x.id === hw.id)!} models={allModels} cases={allCases} hardware={allHardwareRaw} />
    </section>

    <section class="pb-8" id="fit">
      <h3 class="text-lg font-semibold mb-3">算子级 fit · 任意模型瓶颈类型 + 上界</h3>
      <OperatorFitnessMatrix hw={allHardwareRaw.find((x) => x.id === hw.id)!} models={allModels} />
    </section>

    <section class="pb-8" id="operators">
      <h3 class="text-lg font-semibold mb-3">算子支持 & 优化空间</h3>
      <OperatorCoverage hw={allHardwareRaw.find((x) => x.id === hw.id)!} operators={await getOperators()} models={allModels} cases={allCases} hardware={allHardwareRaw} />
    </section>

    <section class="pb-8" id="substitutes">
      <Substitutes hw={hw} allHardware={await getResolvedHardware()} />
    </section>

    <section class="pb-12" id="engines">
      <h3 class="text-lg font-semibold mb-3">软件栈支持</h3>
      <div class="overflow-x-auto rounded-lg border" style="border-color: var(--color-border);">
        <table class="w-full text-sm">
          <thead style="background: var(--color-surface);">
            <tr>
              <th class="text-left px-4 py-2 font-medium">引擎</th>
              <th class="text-left px-4 py-2 font-medium">状态</th>
              {allQuants.slice(0, 6).map((q) => <th class="px-2 py-2 text-xs font-medium">{q.name}</th>)}
            </tr>
          </thead>
          <tbody>
            {allEngines.map((e) => {
              const supported = hw.software_support.engines.find((se) => se.id === e.id);
              const supQuants = new Set(hw.software_support.quantizations);
              const status = supported ? supported.status : null;
              const colorMap = {
                'officially-supported': 'var(--color-tier-measured)',
                'community-port': 'var(--color-tier-estimated)',
                'unsupported': 'oklch(55% 0.2 25)'
              };
              const labelMap = {
                'officially-supported': '官方',
                'community-port': '社区',
                'unsupported': '不支持'
              };
              return (
                <tr class="border-t" style="border-color: var(--color-border);">
                  <td class="px-4 py-2 font-medium">{e.name}</td>
                  <td class="px-4 py-2 text-xs" style={`color: ${status ? colorMap[status] : 'var(--color-text-muted)'};`}>
                    {status ? labelMap[status] : '未确认'}
                  </td>
                  {allQuants.slice(0, 6).map((q) => (
                    <td class="px-2 py-2 text-center">
                      {status && supQuants.has(q.id) ? <span style={`color: ${colorMap[status]};`}>✓</span> : <span style="color: var(--color-text-muted);">—</span>}
                    </td>
                  ))}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="pb-12">
      {efficiency.isCalibrated && (
        <div class="mb-6 p-4 rounded-lg border" style="border-color: var(--color-tier-measured); background: color-mix(in oklch, var(--color-tier-measured) 5%, var(--color-bg));">
          <div class="flex items-center justify-between gap-3 flex-wrap">
            <div>
              <div class="text-xs uppercase tracking-wide font-semibold" style="color: var(--color-tier-measured);">实测校准 efficiency factor</div>
              <p class="text-sm mt-1">基于 <strong>{efficiency.sampleCount}</strong> 个该硬件的实测案例计算得出, 计算器使用此值替代默认 0.5。</p>
              {efficiency.sampleCount >= 2 && (
                <p class="text-xs mt-2" style={`color: ${efficiency.stddev > 0.15 ? 'var(--color-tier-estimated)' : 'var(--color-text-muted)'};`}>
                  σ = {efficiency.stddev.toFixed(2)} · range [{efficiency.min.toFixed(2)}, {efficiency.max.toFixed(2)}]
                  {efficiency.stddev > 0.15 && <span> · ⚠ 高方差: 多种 workload 结果差异大, 实际部署需取中值附近预估</span>}
                </p>
              )}
            </div>
            <div class="text-right">
              <div class="text-3xl font-mono font-semibold" style="color: var(--color-tier-measured);">
                {efficiency.factor.toFixed(2)}
                {efficiency.sampleCount >= 2 && (
                  <span class="text-base font-normal" style="color: var(--color-text-muted);"> ± {efficiency.stddev.toFixed(2)}</span>
                )}
              </div>
              <div class="text-xs" style="color: var(--color-text-muted);">measured / theoretical (n={efficiency.sampleCount})</div>
            </div>
          </div>
        </div>
      )}

      <h3 class="text-lg font-semibold mb-3" id="cases">已有部署案例 ({relatedCases.length})</h3>
      {relatedCases.length === 0 ? (
        <div class="text-sm p-6 rounded-lg border" style="border-color: var(--color-border); color: var(--color-text-muted); background: var(--color-surface);">
          暂无该硬件的实测案例。
          <a href="https://github.com/evokernel/evokernel-spec" class="underline ml-1" style="color: var(--color-accent);">成为第一个贡献者?</a>
        </div>
      ) : (
        <ul class="space-y-2">
          {relatedCases.slice(0, 8).map((c) => (
            <li>
              <a href={pathname(`/cases/${c.id}`)} class="block p-4 rounded-lg border transition-transform hover:translate-x-1"
                 style="background: var(--color-surface-raised); border-color: var(--color-border);">
                <div class="flex justify-between items-start gap-4">
                  <div>
                    <div class="font-medium">{c.title}</div>
                    <div class="text-xs mt-1" style="color: var(--color-text-muted);">
                      {c.stack.model.id} · {c.stack.engine.id} {c.stack.engine.version} · {c.stack.quantization} · TP={c.stack.parallel.tp}
                    </div>
                  </div>
                  <div class="text-right text-xs font-mono" style="color: var(--color-text-muted);">
                    <div>{c.results.throughput_tokens_per_sec.decode} tok/s</div>
                    <div>{c.submitted_at}</div>
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="pb-16" id="citations">
      <h3 class="text-lg font-semibold mb-3">引证</h3>
      <ol class="space-y-2 text-sm">
        {hw.evidence.map((e, i) => (
          <li>
            [{i + 1}] {e.citation} —
            <a href={e.url} class="underline ml-1" style="color: var(--color-accent);" target="_blank" rel="noopener">{e.url}</a>
            <span class="ml-1" style="color: var(--color-text-muted);"> · 访问于 {e.accessed}</span>
            <span class="ml-2"><TierChip tier={e.tier} /></span>
          </li>
        ))}
      </ol>
      {hw.disclaimers.length > 0 && (
        <div class="mt-4 text-xs p-3 rounded" style="background: color-mix(in oklch, var(--color-tier-estimated) 10%, var(--color-bg)); color: var(--color-tier-estimated);">
          {hw.disclaimers.map((d) => <div>⚠ {d}</div>)}
        </div>
      )}
    </section>
  </Container>
</BaseLayout>
