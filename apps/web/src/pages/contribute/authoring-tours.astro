---
/**
 * /contribute/authoring-tours/ — guide for contributors writing new
 * end-to-end deployment tours. Goes with the v1.24 data-driven tour refactor.
 *
 * Pulls live tour count + sample structure from data so the guide stays in
 * sync with the actual tour catalog. Closes the v1.25 horizon item
 * "Tour authoring guide for contributors".
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import {
  getTours, getResolvedCases, getPipelineStages, getOperators, getFusedKernels, getPatterns
} from '~/lib/data';

const [tours, cases, pipelineStages, operators, fusedKernels, patterns] = await Promise.all([
  getTours(), getResolvedCases(), getPipelineStages(), getOperators(), getFusedKernels(), getPatterns()
]);

const orderedStages = [...pipelineStages].sort((a, b) => a.order - b.order);
---
<BaseLayout title="贡献 Tour / Authoring End-to-End Tours">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        CONTRIBUTE · AUTHORING TOURS
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        贡献 Tour · Authoring Guide
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        Tour 是端到端部署叙事 — 拿一个具体 case 走完 7 阶段, 让读者一次看完整链路.
        v1.24 后 tour 是 <strong>data-driven</strong>: 写一个 YAML 文件即可.
        这页解释格式 + 提供从零到 PR 的完整流程.
      </p>
      <div class="mt-6 flex gap-6 text-sm flex-wrap">
        <div><span style="color: var(--color-text-muted);">现有 Tour: </span><strong>{tours.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">现有 Cases: </span><strong>{cases.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">每 Tour 阶段: </span><strong>{orderedStages.length}</strong></div>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="when-to-write-heading">
      <h2 id="when-to-write-heading" class="text-2xl font-semibold mb-4">什么时候写 Tour</h2>
      <div class="grid lg:grid-cols-2 gap-4 text-sm">
        <div class="rounded-lg border p-4" style="border-color: oklch(70% 0.15 145); background: color-mix(in oklch, oklch(70% 0.15 145) 5%, transparent);">
          <div class="font-semibold mb-2" style="color: oklch(60% 0.15 145);">✓ 适合写 Tour</div>
          <ul class="space-y-1.5" style="color: var(--color-text-muted);">
            <li>· 你已经在生产环境跑过这个 (model × hardware × engine × quant) 组合</li>
            <li>· 部署涉及多个值得记录的决策点 (量化 / 并行 / 引擎)</li>
            <li>· 有踩坑记录可以分享给后人</li>
            <li>· 这条 deployment 路径与现有 tour 显著不同 (硬件 / 厂商 / 规模)</li>
            <li>· 已经先提交了对应的 case YAML</li>
          </ul>
        </div>
        <div class="rounded-lg border p-4" style="border-color: oklch(70% 0.18 30); background: color-mix(in oklch, oklch(70% 0.18 30) 5%, transparent);">
          <div class="font-semibold mb-2" style="color: oklch(60% 0.18 30);">✗ 暂不适合</div>
          <ul class="space-y-1.5" style="color: var(--color-text-muted);">
            <li>· 没跑过实测 — 直觉描述不算 tour (走 playbook 路径)</li>
            <li>· 与现有 tour 重复 (除非显著不同的 case)</li>
            <li>· 部署仅涉及单一决策点 (写 case 即可, 不需要 tour)</li>
            <li>· 还在调试中 — 等稳定后再写</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="format-heading">
      <h2 id="format-heading" class="text-2xl font-semibold mb-4">YAML 文件结构</h2>
      <p class="text-sm mb-4" style="color: var(--color-text-muted);">
        路径: <code class="text-xs px-2 py-0.5 rounded" style="background: var(--color-surface);">data/tours/&lt;slug&gt;.yaml</code>
        (slug 命名建议: <code>&lt;model&gt;-&lt;hardware&gt;-&lt;engine&gt;-&lt;quant&gt;</code>, 全小写连字符).
      </p>

      <div class="rounded-lg border p-5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <div class="text-xs font-medium uppercase tracking-wider mb-3" style="color: var(--color-text-muted);">完整模板 / Template</div>
        <pre class="text-xs overflow-x-auto p-3 rounded" style="background: var(--color-bg); color: var(--color-text);"><code>id: &lt;slug-matching-filename&gt;
title: '&lt;Display Title&gt;'
context_zh: '&lt;场景 1&gt; · &lt;场景 2&gt; · &lt;关键技术栈&gt;'
case_id: case-&lt;your-existing-case-id&gt;
playbook_id: &lt;optional matching playbook&gt;
display_order: 30  # smaller = appears earlier in index; default 100
why_it_matters: |
  &lt;1-3 sentences explaining what's unique about this deployment.
   Read by every visitor on the index card.&gt;

stages:
  - stage_id: acquire    # required exact id from /pipeline/
    decision: '&lt;short concrete decision, copy-pasteable&gt;'
    rationale: |
      &lt;why this decision in 1-3 sentences. Reference numbers from the case.&gt;
    pitfall: |
      &lt;optional production gotcha specific to this stage&gt;

  - stage_id: convert
    decision: '&lt;...&gt;'
    rationale: |
      &lt;...&gt;
    # optional fields:
    involves_operators: [matmul, scaled-dot-product-attention]
    involves_kernels: [flash-attention-v3]
    involves_patterns: [gqa-mqa-shared-kv]

  # ... repeat for: quantize, compile, shard, serve, observe</code></pre>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="ids-heading">
      <h2 id="ids-heading" class="text-2xl font-semibold mb-4">合法 ID 速查</h2>

      <div class="grid lg:grid-cols-3 gap-4">
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">stage_id (必填, 7 选)</h3>
          <ul class="text-xs space-y-1 font-mono" style="color: var(--color-text);">
            {orderedStages.map((s) => (
              <li>· {s.id}</li>
            ))}
          </ul>
        </div>

        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">case_id (必填, 全集 {cases.length})</h3>
          <p class="text-xs mb-2" style="color: var(--color-text-muted);">必须先在 <code>data/cases/</code> 里有对应 case. 例如:</p>
          <ul class="text-xs space-y-0.5 font-mono" style="color: var(--color-text-muted);">
            {cases.slice(0, 5).map((c) => (
              <li>· {c.id}</li>
            ))}
            <li class="italic">… 见 <a href={pathname('/cases/')} style="color: var(--color-accent);" class="hover:underline">cases 目录</a></li>
          </ul>
        </div>

        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">cross-references (选填)</h3>
          <ul class="text-xs space-y-1" style="color: var(--color-text-muted);">
            <li>· involves_operators: <strong>{operators.length}</strong> 个 (见 <a href={pathname('/operators/')} style="color: var(--color-accent);" class="hover:underline">operators</a>)</li>
            <li>· involves_kernels: <strong>{fusedKernels.length}</strong> 个 (见 <a href={pathname('/fused-kernels/')} style="color: var(--color-accent);" class="hover:underline">fused-kernels</a>)</li>
            <li>· involves_patterns: <strong>{patterns.length}</strong> 个 (见 <a href={pathname('/patterns/')} style="color: var(--color-accent);" class="hover:underline">patterns</a>)</li>
          </ul>
          <p class="text-xs mt-2" style="color: var(--color-text-muted);">
            ID 不在 catalog 时校验报错 — 写之前查目录确认 spelling.
          </p>
        </div>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="workflow-heading">
      <h2 id="workflow-heading" class="text-2xl font-semibold mb-4">从 0 到 PR 的步骤</h2>
      <ol class="space-y-3 text-sm">
        <li class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-accent);">1</span>
            <strong>确认 case 已存在.</strong>
          </div>
          <p class="mt-2" style="color: var(--color-text-muted);">
            Tour 必须基于实测 case. 如果 case 还没提交, 先按
            <a href={pathname('/contribute/')} style="color: var(--color-accent);" class="hover:underline"> 贡献指南 </a>
            提交 case YAML, 再写 tour.
          </p>
        </li>

        <li class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-accent);">2</span>
            <strong>复制最近的 tour 当模板.</strong>
          </div>
          <pre class="text-xs overflow-x-auto p-2 rounded mt-2" style="background: var(--color-bg); color: var(--color-text);"><code>cp data/tours/llama4-scout-h200-vllm-fp8.yaml data/tours/&lt;your-slug&gt;.yaml</code></pre>
        </li>

        <li class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-accent);">3</span>
            <strong>改 7 阶段叙事.</strong>
          </div>
          <p class="mt-2" style="color: var(--color-text-muted);">
            每个 stage: 真实做了什么决定, 为什么这么决定 (引用 case 实测数据), 哪个 op/kernel/pattern 涉及, 踩了什么坑.
            每段 1-3 句话, 不要写成长文.
          </p>
        </li>

        <li class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-accent);">4</span>
            <strong>本地验证.</strong>
          </div>
          <pre class="text-xs overflow-x-auto p-2 rounded mt-2" style="background: var(--color-bg); color: var(--color-text);"><code>pnpm validate                    # schema 检查
pnpm --filter web dev            # 启动 dev server
# 浏览 http://localhost:4321/learn/tours/&lt;your-slug&gt;/</code></pre>
        </li>

        <li class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="flex items-baseline gap-2">
            <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-accent);">5</span>
            <strong>提 PR.</strong>
          </div>
          <p class="mt-2" style="color: var(--color-text-muted);">
            Title: <code class="text-xs px-1 py-0.5 rounded" style="background: var(--color-bg);">tour: &lt;model&gt; × &lt;hardware&gt;</code>.
            描述: 1 段 why-it-matters + 链接到对应 case.
            CI 跑 schema 校验 + E2E (tour 渲染 smoke test).
          </p>
        </li>
      </ol>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="examples-heading">
      <h2 id="examples-heading" class="text-2xl font-semibold mb-4">参考已有 Tour</h2>
      <div class="grid lg:grid-cols-3 gap-3 text-sm">
        {tours.map((t) => (
          <a href={pathname(`/learn/tours/${t.id}/`)}
             class="block rounded-lg border p-3 transition-transform hover:-translate-y-0.5"
             style="border-color: var(--color-border); background: var(--color-surface-raised); color: var(--color-text);">
            <div class="font-semibold" style="color: var(--color-accent);">{t.title}</div>
            <div class="text-xs mt-1 font-mono" style="color: var(--color-text-muted);">{t.context_zh}</div>
          </a>
        ))}
      </div>
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">动手?</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          先选一个有 case 但还没 tour 的 (model × hardware) 组合, 然后照模板写.
          有问题 → GitHub issue.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href="https://github.com/ying-wen/evokernel-spec/tree/main/data/tours" class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;" target="_blank" rel="noopener noreferrer">📂 data/tours/ 源码 →</a>
          <a href={pathname('/learn/tours/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">浏览全部 Tour →</a>
          <a href={pathname('/contribute/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">总贡献指南 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
