---
/**
 * /contribute/case-form/ — public submission portal for cases.
 *
 * Removes the "fork + clone + vim" friction. Form generates a YAML that
 * matches schemas/case.ts; user copies / downloads and pastes into a
 * GitHub UI new-file PR. CI's `pnpm validate` catches schema errors.
 *
 * Closes a Tier-2 roadmap item: turns the project from "hard to contribute"
 * to "3-minute case-add path."
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import CaseSubmissionForm from '~/components/case-submission/CaseSubmissionForm.tsx';
import '~/components/case-submission/CaseSubmissionForm.css';
import { getModels, getResolvedHardware, getEngines, getQuantizations } from '~/lib/data';

const [models, hardware, engines, quantizations] = await Promise.all([
  getModels(),
  getResolvedHardware(),
  getEngines(),
  getQuantizations()
]);

// Trim payloads to the picker fields the form needs. Keeps island JS small.
const modelOptions = models
  .map((m) => ({ id: m.id, name: m.name }))
  .sort((a, b) => a.name.localeCompare(b.name));
const hardwareOptions = hardware
  .map((h) => ({ id: h.id, name: h.name, vendor: h.vendor.id }))
  .sort((a, b) => a.name.localeCompare(b.name));
const engineIds = engines.map((e) => e.id).sort();
const quantizationIds = quantizations.map((q) => q.id).sort();
---
<BaseLayout title="提交部署案例 / Submit a deployment case">
  <Container width="wide">
    <section class="pt-12 pb-6">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        CONTRIBUTE · CASE SUBMISSION
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        提交部署案例
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        填表 → 自动生成 PR-ready YAML → GitHub UI 新建文件 → CI 自动校验. 3 分钟从 "我有部署数据"
        到 "PR 已提交". 比 fork + clone + vim 快一个量级.
      </p>
      <p class="text-sm mt-4 max-w-3xl" style="color: var(--color-text-muted);">
        所有字段都对应
        <a href="https://github.com/ying-wen/evokernel-spec/blob/main/schemas/case.ts" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent);" class="hover:underline">
          schemas/case.ts
        </a>
        — 生成的 YAML 直接走和现有 41 个 case 同样的 schema 校验. 不达标 CI 红 ❌, 改完再 commit.
      </p>
      <div class="mt-6 flex gap-6 text-sm flex-wrap">
        <div><span style="color: var(--color-text-muted);">Catalog 模型: </span><strong>{modelOptions.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">Catalog 硬件: </span><strong>{hardwareOptions.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">Catalog 引擎: </span><strong>{engineIds.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">现有案例: </span><a href={pathname('/cases/')} style="color: var(--color-accent);" class="hover:underline">浏览样本 →</a></div>
      </div>
    </section>

    <section class="py-6">
      <CaseSubmissionForm
        client:only="react"
        models={modelOptions}
        hardware={hardwareOptions}
        engines={engineIds}
        quantizations={quantizationIds}
      />
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">想贡献的不止 case?</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          其他贡献路径 (playbook / pattern / fused-kernel / tour / model / hardware / 引证 …) 暂时还需要传统 PR
          flow. 见 <a href={pathname('/contribute/')} style="color: var(--color-accent);" class="hover:underline">贡献指南</a> 的完整说明.
          Tour 编写有专门指南: <a href={pathname('/contribute/authoring-tours/')} style="color: var(--color-accent);" class="hover:underline">如何写 tour</a>.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/contribute/')} class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;">完整贡献指南 →</a>
          <a href={pathname('/contribute/authoring-tours/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">Tour 编写指南 →</a>
          <a href="https://github.com/ying-wen/evokernel-spec" target="_blank" rel="noopener noreferrer" class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">GitHub ↗</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
