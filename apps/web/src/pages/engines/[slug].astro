---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import Badge from '~/components/ui/Badge.astro';
import { getEngines, getResolvedHardware, getCases } from '~/lib/data';

export async function getStaticPaths() {
  const engines = await getEngines();
  return engines.map((e) => ({ params: { slug: e.id }, props: { engine: e } }));
}

const { engine } = Astro.props;
const allHardware = await getResolvedHardware();
const supportingHw = allHardware.filter((h) => h.software_support.engines.some((se) => se.id === engine.id));
const allCases = await getCases();
const cases = allCases.filter((c) => c.stack.engine.id === engine.id).sort((a, b) => b.submitted_at.localeCompare(a.submitted_at));
---
<BaseLayout title={`${engine.name} 推理引擎`}>
  <Container>
    <section class="pt-12 pb-8">
      <a href={pathname("/engines/")} class="text-sm" style="color: var(--color-text-muted);">← 引擎目录</a>
      <h1 style="font-size: clamp(2rem, 1.5rem + 1.5vw, 3rem); margin-top: 1rem; font-weight: 600;">{engine.name}</h1>
      <div class="flex gap-2 mt-3 flex-wrap">
        <Badge variant="accent">{engine.latest_version}</Badge>
        <Badge>维护: {engine.maintainer}</Badge>
      </div>
      {engine.notes && <p class="mt-4 text-base" style="color: var(--color-text-muted);">{engine.notes}</p>}
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">资源</h3>
      <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <SpecRow label="源码"><a href={engine.source_url} class="underline" style="color: var(--color-accent);" target="_blank" rel="noopener">{engine.source_url}</a></SpecRow>
        {engine.documentation_url && <SpecRow label="文档"><a href={engine.documentation_url} class="underline" style="color: var(--color-accent);" target="_blank" rel="noopener">{engine.documentation_url}</a></SpecRow>}
        <SpecRow label="支持厂商">{engine.supported_hardware_vendors.join(', ')}</SpecRow>
        {engine.production_readiness && <SpecRow label="生产就绪度">{engine.production_readiness}</SpecRow>}
      </div>
    </section>

    {/* v1.42: capability matrix fields */}
    {(engine.quantization_formats?.length || engine.parallelism_modes?.length || engine.serving_features?.length || engine.speculative_decoding?.length || engine.frontend_protocols?.length) && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">能力矩阵</h3>
        <div class="rounded-lg border p-4 grid gap-3" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          {engine.quantization_formats?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">量化格式 · {engine.quantization_formats.length}</div>
              <div class="flex gap-1 flex-wrap">
                {engine.quantization_formats.map((q) => <Badge>{q}</Badge>)}
              </div>
            </div>
          ) : null}
          {engine.parallelism_modes?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">并行策略 · {engine.parallelism_modes.length}</div>
              <div class="flex gap-1 flex-wrap">
                {engine.parallelism_modes.map((p) => <Badge variant="accent">{p.toUpperCase()}</Badge>)}
              </div>
            </div>
          ) : null}
          {engine.serving_features?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">服务特性 · {engine.serving_features.length}</div>
              <div class="flex gap-1 flex-wrap">
                {engine.serving_features.map((f) => <Badge>{f}</Badge>)}
              </div>
            </div>
          ) : null}
          {engine.speculative_decoding?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">投机解码方法 · {engine.speculative_decoding.length}</div>
              <div class="flex gap-1 flex-wrap">
                {engine.speculative_decoding.map((s) => <Badge variant="accent">{s}</Badge>)}
              </div>
            </div>
          ) : null}
          {engine.frontend_protocols?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">前端协议</div>
              <div class="flex gap-1 flex-wrap">
                {engine.frontend_protocols.map((p) => <Badge>{p}</Badge>)}
              </div>
            </div>
          ) : null}
          {engine.deployment_targets?.length ? (
            <div>
              <div class="text-xs font-semibold mb-1" style="color: var(--color-text-muted);">部署形态</div>
              <div class="flex gap-1 flex-wrap">
                {engine.deployment_targets.map((d) => <Badge>{d}</Badge>)}
              </div>
            </div>
          ) : null}
        </div>
      </section>
    )}

    {(engine.strengths?.length || engine.weaknesses?.length || engine.best_for?.length) && (
      <section class="pb-8 grid gap-4 md:grid-cols-3">
        {engine.strengths?.length ? (
          <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <h4 class="text-sm font-semibold mb-2">优势</h4>
            <ul class="text-sm space-y-1.5" style="color: var(--color-text-muted);">
              {engine.strengths.map((s) => <li>✓ {s}</li>)}
            </ul>
          </div>
        ) : null}
        {engine.weaknesses?.length ? (
          <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <h4 class="text-sm font-semibold mb-2">局限</h4>
            <ul class="text-sm space-y-1.5" style="color: var(--color-text-muted);">
              {engine.weaknesses.map((w) => <li>· {w}</li>)}
            </ul>
          </div>
        ) : null}
        {engine.best_for?.length ? (
          <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <h4 class="text-sm font-semibold mb-2">最适合</h4>
            <ul class="text-sm space-y-1.5" style="color: var(--color-text-muted);">
              {engine.best_for.map((b) => <li>→ {b}</li>)}
            </ul>
          </div>
        ) : null}
      </section>
    )}

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">兼容硬件 ({supportingHw.length})</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
        {supportingHw.map((h) => {
          const support = h.software_support.engines.find((se) => se.id === engine.id)!;
          const colorMap = {
            'officially-supported': 'var(--color-tier-measured)',
            'community-port': 'var(--color-tier-estimated)',
            'unsupported': 'oklch(55% 0.2 25)'
          };
          const labelMap = { 'officially-supported': '官方', 'community-port': '社区', 'unsupported': '不支持' };
          return (
            <a href={pathname(`/hardware/${h.id}/`)} class="flex justify-between items-center p-3 rounded border text-sm transition-transform hover:translate-x-0.5"
               style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <span>{h.name}</span>
              <span class="text-xs" style={`color: ${colorMap[support.status]};`}>{labelMap[support.status]}</span>
            </a>
          );
        })}
      </div>
    </section>

    <section class="pb-12">
      <h3 class="text-lg font-semibold mb-3">使用本引擎的案例 ({cases.length})</h3>
      {cases.length === 0 ? (
        <p class="text-sm" style="color: var(--color-text-muted);">尚无关联案例。</p>
      ) : (
        <ul class="space-y-2 text-sm">
          {cases.map((c) => (
            <li>
              <a href={pathname(`/cases/${c.id}/`)} class="block p-3 rounded border transition-transform hover:translate-x-0.5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
                <div class="font-medium">{c.title}</div>
                <div class="text-xs mt-1 font-mono" style="color: var(--color-text-muted);">
                  {c.stack.hardware.id} ×{c.stack.hardware.count} · {c.stack.model.id} · {c.results.throughput_tokens_per_sec.decode} tok/s · {c.submitted_at}
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </Container>
</BaseLayout>
