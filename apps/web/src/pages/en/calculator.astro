---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import SectionHeader from '~/components/ui/SectionHeader.astro';
import CalculatorIsland from '~/components/calculator/Calculator.tsx';
import { getHardware, getModels, getCases, getEngines } from '~/lib/data';
import { t } from '~/lib/i18n';

const locale = 'en';
const models = await getModels();
const hardware = await getHardware();
const cases = await getCases();
const engines = await getEngines();
---
<BaseLayout title={t(locale, 'page.calculator.title')} locale={locale}>
  <Container width="wide">
    <section class="py-12">
      <SectionHeader eyebrow="CALCULATOR" title={t(locale, 'page.calculator.title')}
        subtitle={t(locale, 'page.calculator.subtitle')} />
      <CalculatorIsland models={models} hardware={hardware} cases={cases} engines={engines} client:load />
    </section>
  </Container>
</BaseLayout>
