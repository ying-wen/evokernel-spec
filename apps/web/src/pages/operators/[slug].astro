---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import Badge from '~/components/ui/Badge.astro';
import { getOperators, getModels, getResolvedHardware, getEngines, getPatterns } from '~/lib/data';
import { buildOperatorFitnessTable, summarizeFitness } from '~/lib/operator-hw-fitness';

export async function getStaticPaths() {
  const operators = await getOperators();
  return operators.map((op) => ({ params: { slug: op.id }, props: { op } }));
}

const { op } = Astro.props;
const [allModels, allHw, allOperators, allEngines, allPatterns] = await Promise.all([
  getModels(), getResolvedHardware(), getOperators(), getEngines(), getPatterns()
]);

// Fusion graph: this op's neighbors in the fusion graph (forward + reverse).
const fusionTargetOps = allOperators.filter((o) => op.fusion_targets.includes(o.id));
const fusedFromOps = allOperators.filter((o) => o.fusion_targets.includes(op.id) && o.id !== op.id);
const relatedPatternsList = allPatterns.filter((p) => op.related_patterns.includes(p.id));
// Find models that reference this operator in decomposition
const usedBy = allModels.filter((m) => m.operator_decomposition.some((d) => d.operator === op.id));

const aiTypical = op.arithmetic_intensity_typical;
const aiBoundClass = aiTypical
  ? (aiTypical.max < 10 ? 'memory-bound'
     : aiTypical.min > 100 ? 'compute-bound'
     : 'mixed')
  : null;
const aiClassLabel: Record<string, string> = {
  'memory-bound': '🟦 内存带宽受限 (memory-bound)',
  'compute-bound': '🟧 计算受限 (compute-bound)',
  mixed: '🟨 区间跨界 (regime-dependent)'
};

// HARDWARE FITNESS ANALYSIS:
// For a representative model + this operator, compute per-hardware:
//   - arithmetic intensity (FLOPs/bytes) of this op token
//   - hardware ridge point (peak compute / peak bandwidth) [FLOP/byte]
//   - bottleneck: compute-bound vs memory-bound
//   - achievable throughput on this op (per token) given the binding regime
const repModel = usedBy.find((m) => m.id === 'llama-4-scout') ?? usedBy[0];
const repDecomp = repModel?.operator_decomposition.find((d) => d.operator === op.id);

const intensity = repDecomp && repDecomp.bytes_per_token > 0
  ? repDecomp.flops_per_token / repDecomp.bytes_per_token
  : 0;

// v1.15: structural fitness across full hardware corpus at natural precision per card.
// Complements per-model intensity row above by answering the cross-cutting question:
// "where does this operator run efficiently across ALL hardware in the corpus?"
const structuralFitnessCells = buildOperatorFitnessTable(op, allHw);
const fitnessSummary = summarizeFitness(structuralFitnessCells);

const fitnessRows = intensity > 0
  ? allHw
      .map((hw) => {
        const peakBf16 = hw.compute.bf16_tflops?.value;
        const peakBw = hw.memory.bandwidth_gbps?.value;
        if (!peakBf16 || !peakBw) return null;
        const ridgePoint = (peakBf16 * 1000) / peakBw;
        const isComputeBound = intensity >= ridgePoint;
        const achievableTflops = isComputeBound ? peakBf16 : (peakBw * intensity) / 1000;
        const utilizationPct = (achievableTflops / peakBf16) * 100;
        return { hw, ridgePoint, isComputeBound, achievableTflops, peakBf16Tflops: peakBf16, utilizationPct };
      })
      .filter((r) => r !== null)
      .sort((a, b) => b!.achievableTflops - a!.achievableTflops)
  : [];
---
<BaseLayout title={`${op.name} 算子`}>
  <Container width="narrow">
    <section class="pt-12 pb-8">
      <a href={pathname("/operators/")} class="text-sm" style="color: var(--color-text-muted);">← 算子目录</a>
      <h1 style="font-size: clamp(1.75rem, 1.5rem + 1vw, 2.5rem); margin-top: 1rem; font-weight: 600;">{op.name}</h1>
      <div class="flex gap-2 mt-3 flex-wrap">
        <Badge variant="accent">{op.category}</Badge>
        {op.variants.map((v) => <Badge>{v}</Badge>)}
      </div>
      <p class="mt-4 text-base" style="color: var(--color-text-muted);">{op.description}</p>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">公式 / Roofline math</h3>
      <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <SpecRow label="FLOPs"><code style="font-family: var(--font-mono); font-size: 0.875rem;">{op.flops_formula}</code></SpecRow>
        <SpecRow label="Bytes"><code style="font-family: var(--font-mono); font-size: 0.875rem;">{op.bytes_formula}</code></SpecRow>
        {op.arithmetic_intensity_formula && (
          <SpecRow label="Arithmetic intensity"><code style="font-family: var(--font-mono); font-size: 0.875rem;">{op.arithmetic_intensity_formula}</code></SpecRow>
        )}
      </div>
      {aiTypical && aiBoundClass && (
        <div class="mt-3 px-4 py-3 rounded text-sm" style={`background: var(--color-surface); border-left: 3px solid ${aiBoundClass === 'memory-bound' ? 'var(--color-china)' : aiBoundClass === 'compute-bound' ? 'var(--color-accent)' : 'var(--color-tier-estimated)'};`}>
          <div class="font-semibold mb-1">{aiClassLabel[aiBoundClass]}</div>
          <div style="color: var(--color-text-muted);">
            典型 AI 区间: <strong style="color: var(--color-text); font-family: var(--font-mono);">{aiTypical.min} – {aiTypical.max} FLOP/byte</strong>
            {aiTypical.notes && <span> · {aiTypical.notes}</span>}
          </div>
        </div>
      )}
    </section>

    {(fusionTargetOps.length > 0 || fusedFromOps.length > 0 || op.participates_in_fused_kernels.length > 0) && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">融合图谱 / Fusion graph</h3>
        <p class="text-xs mb-4" style="color: var(--color-text-muted);">
          算子融合 (operator fusion) 是把多个 op 折叠到同一 kernel, 消除 HBM 中转读写。
          该 op 的融合相邻关系如下:
        </p>
        <div class="grid sm:grid-cols-2 gap-4">
          {fusionTargetOps.length > 0 && (
            <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <h4 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">→ 该 op 通常 fuse 进:</h4>
              <ul class="space-y-1.5">
                {fusionTargetOps.map((o) => (
                  <li>
                    <a href={pathname(`/operators/${o.id}/`)} class="text-sm font-medium underline" style="color: var(--color-text);">
                      {o.name}
                    </a>
                    <span class="text-xs ml-2" style="color: var(--color-text-muted);">{o.category}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {fusedFromOps.length > 0 && (
            <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <h4 class="text-sm font-semibold mb-2" style="color: var(--color-china);">← 反向: 这些 op 把自己 fuse 进当前 op:</h4>
              <ul class="space-y-1.5">
                {fusedFromOps.map((o) => (
                  <li>
                    <a href={pathname(`/operators/${o.id}/`)} class="text-sm font-medium underline" style="color: var(--color-text);">
                      {o.name}
                    </a>
                    <span class="text-xs ml-2" style="color: var(--color-text-muted);">{o.category}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
        {op.participates_in_fused_kernels.length > 0 && (
          <div class="mt-4 rounded-lg border p-4" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
            <h4 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">⚡ 出现在以下命名 fused kernels:</h4>
            <div class="flex flex-wrap gap-2">
              {op.participates_in_fused_kernels.map((slug) => (
                <a href={pathname(`/fused-kernels/${slug}/`)} class="text-sm font-medium px-3 py-1 rounded border" style="border-color: var(--color-accent); color: var(--color-accent);">
                  {slug}
                </a>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    {op.engine_implementations.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">引擎实现 / Engine kernels ({op.engine_implementations.length})</h3>
        <div class="grid md:grid-cols-2 gap-3">
          {op.engine_implementations.map((impl) => {
            const eng = impl.engine_id ? allEngines.find((e) => e.id === impl.engine_id) : null;
            return (
              <article class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
                <div class="flex justify-between items-start gap-2 mb-2">
                  <h4 class="font-mono text-sm font-semibold" style="color: var(--color-text);">{impl.name}</h4>
                  {eng && (
                    <a href={pathname(`/engines/${eng.id}/`)} class="text-xs px-2 py-0.5 rounded" style="background: color-mix(in oklch, var(--color-accent) 15%, var(--color-bg)); color: var(--color-accent);">
                      {eng.name}
                    </a>
                  )}
                </div>
                {impl.hardware_arch.length > 0 && (
                  <div class="flex flex-wrap gap-1 mb-2">
                    {impl.hardware_arch.map((arch) => <Badge>{arch}</Badge>)}
                  </div>
                )}
                {impl.notes && <p class="text-xs mb-2" style="color: var(--color-text-muted);">{impl.notes}</p>}
                {impl.url && (
                  <a href={impl.url} target="_blank" rel="noopener" class="text-xs underline" style="color: var(--color-accent);">
                    docs / source →
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </section>
    )}

    {op.precision_support.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">原生精度支持 / Native precision support</h3>
        <div class="flex flex-wrap gap-2">
          {op.precision_support.map((p) => <Badge variant="accent">{p.toUpperCase()}</Badge>)}
        </div>
      </section>
    )}

    {relatedPatternsList.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">相关优化模式 / Related patterns</h3>
        <div class="grid sm:grid-cols-2 gap-2">
          {relatedPatternsList.map((p) => (
            <a href={pathname(`/patterns/${p.id}/`)} class="block rounded p-3 text-sm border transition-transform hover:translate-x-0.5"
               style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <div class="font-medium">{p.name}</div>
              <div class="text-xs mt-1" style="color: var(--color-text-muted);">{p.category}</div>
            </a>
          ))}
        </div>
      </section>
    )}

    {op.references.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">参考文献 / References</h3>
        <ul class="space-y-1.5 text-sm">
          {op.references.map((ref) => (
            <li>
              <a href={ref.url} target="_blank" rel="noopener" class="underline" style="color: var(--color-accent);">{ref.title}</a>
              <span class="text-xs ml-2 px-1.5 py-0.5 rounded" style="background: var(--color-surface); color: var(--color-text-muted);">{ref.source_type}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {fitnessRows.length > 0 && repModel && repDecomp && (
      <section class="pb-12">
        <h3 class="text-lg font-semibold mb-2">硬件适配性 / Hardware fitness for this operator</h3>
        <p class="text-xs mb-4 px-3 py-2 rounded" style="background: var(--color-surface); color: var(--color-text-muted);">
          基于代表模型 <a href={pathname(`/models/${repModel.id}/`)} class="underline" style="color: var(--color-accent);">{repModel.name}</a> 的此算子参数 (FLOPs/token = {repDecomp.flops_per_token.toExponential(2)}, Bytes/token = {repDecomp.bytes_per_token.toExponential(2)}, 算术强度 = <strong>{(repDecomp.flops_per_token / repDecomp.bytes_per_token).toFixed(1)} FLOP/byte</strong>)。
          每行展示该硬件在 BF16 精度下的 ridge point、瓶颈类型、以及该算子可达吞吐 (TFLOP/s)。
        </p>
        <div class="overflow-x-auto rounded-lg border" style="border-color: var(--color-border);">
          <table class="w-full text-sm">
            <thead style="background: var(--color-surface);">
              <tr>
                <th class="text-left px-3 py-2 font-medium">硬件</th>
                <th class="text-right px-3 py-2 font-medium">Ridge point</th>
                <th class="text-center px-3 py-2 font-medium">瓶颈</th>
                <th class="text-right px-3 py-2 font-medium">可达 TFLOP/s</th>
                <th class="text-right px-3 py-2 font-medium">峰值利用率</th>
              </tr>
            </thead>
            <tbody>
              {fitnessRows.slice(0, 12).map((r) => {
                const isCN = r.hw.vendor.country === 'CN';
                const tooLow = r.utilizationPct < 30;
                return (
                  <tr class="border-t" style="border-color: var(--color-border);">
                    <td class="px-3 py-2">
                      <a href={pathname(`/hardware/${r.hw.id}/`)} style="color: var(--color-text);" class="font-medium">{r.hw.name}</a>
                      {isCN && <span class="text-xs ml-1" style="color: var(--color-china);">🇨🇳</span>}
                      <div class="text-xs" style="color: var(--color-text-muted);">peak BF16 {r.peakBf16Tflops.toFixed(0)} TF · BW {(r.hw.memory.bandwidth_gbps?.value ?? 0) / 1000} TB/s</div>
                    </td>
                    <td class="text-right px-3 py-2 font-mono text-xs" style="color: var(--color-text-muted);">{r.ridgePoint.toFixed(1)}</td>
                    <td class="text-center px-3 py-2 text-xs">
                      {r.isComputeBound
                        ? <span style="color: var(--color-accent);">计算 compute</span>
                        : <span style="color: var(--color-china);">内存带宽 mem-bw</span>}
                    </td>
                    <td class="text-right px-3 py-2 font-mono">{r.achievableTflops.toFixed(0)}</td>
                    <td class="text-right px-3 py-2 font-mono text-xs" style={`color: ${tooLow ? 'var(--color-tier-estimated)' : 'var(--color-text)'};`}>
                      {r.utilizationPct.toFixed(0)}%
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        {fitnessRows.length > 12 && (
          <p class="text-xs mt-2" style="color: var(--color-text-muted);">显示前 12 张 (按可达 TFLOP/s 降序) · 共 {fitnessRows.length} 张可比较</p>
        )}
      </section>
    )}

    {/* v1.15: structural fitness — answers "where does this op run efficiently?" across ALL hardware */}
    {structuralFitnessCells.length > 0 && (
      <section class="pb-12">
        <h3 class="text-lg font-semibold mb-3">🏛 结构性硬件适配性 / Structural fitness across corpus</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          对全部 {fitnessSummary.total} 张可比较的硬件 (按 highest-precision 计算 ridge point), 此算子的瓶颈分布:
        </p>
        <div class="grid sm:grid-cols-3 gap-3 mb-4">
          <div class="rounded-lg border p-4" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: var(--color-accent);">🟦 Memory-bound</div>
            <div class="font-mono text-2xl font-bold">{fitnessSummary.memoryBound}</div>
            <div class="text-xs" style="color: var(--color-text-muted);">{Math.round((fitnessSummary.memoryBound / fitnessSummary.total) * 100)}% — 量化 / 带宽优化最有效</div>
          </div>
          <div class="rounded-lg border p-4" style="border-color: var(--color-tier-measured); background: color-mix(in oklch, var(--color-tier-measured) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: var(--color-tier-measured);">🟧 Compute-bound</div>
            <div class="font-mono text-2xl font-bold">{fitnessSummary.computeBound}</div>
            <div class="text-xs" style="color: var(--color-text-muted);">{Math.round((fitnessSummary.computeBound / fitnessSummary.total) * 100)}% — 算力升级 / 更激进 quant 才能改善</div>
          </div>
          <div class="rounded-lg border p-4" style="border-color: var(--color-tier-estimated); background: color-mix(in oklch, var(--color-tier-estimated) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide mb-1" style="color: var(--color-tier-estimated);">🟨 Regime-dependent</div>
            <div class="font-mono text-2xl font-bold">{fitnessSummary.regimeDependent}</div>
            <div class="text-xs" style="color: var(--color-text-muted);">{Math.round((fitnessSummary.regimeDependent / fitnessSummary.total) * 100)}% — 跨 ridge, 实际 batch 决定</div>
          </div>
        </div>
        <details class="mt-3">
          <summary class="text-sm cursor-pointer" style="color: var(--color-text-muted);">显示完整表格 ({structuralFitnessCells.length} 张硬件)</summary>
          <table class="w-full text-xs mt-3" style="border-collapse: collapse;">
            <thead>
              <tr style="border-bottom: 1px solid var(--color-border);">
                <th class="text-left p-2">Hardware</th>
                <th class="text-right p-2">Precision</th>
                <th class="text-right p-2">Ridge (FLOP/byte)</th>
                <th class="text-right p-2">Class</th>
              </tr>
            </thead>
            <tbody>
              {structuralFitnessCells.sort((a, b) => a.ridgePoint - b.ridgePoint).map((c) => (
                <tr style="border-bottom: 1px solid color-mix(in oklch, var(--color-border) 60%, transparent);">
                  <td class="p-2">
                    <a href={pathname(`/hardware/${c.hardware.id}/`)} class="hover:underline" style="color: var(--color-accent);">{c.hardware.name}</a>
                  </td>
                  <td class="text-right p-2 font-mono">{c.precision}</td>
                  <td class="text-right p-2 font-mono">{c.ridgePoint.toFixed(1)}</td>
                  <td class="text-right p-2">
                    <span style={`color: ${
                      c.fitnessClass === 'memory-bound' ? 'var(--color-accent)' :
                      c.fitnessClass === 'compute-bound' ? 'var(--color-tier-measured)' :
                      'var(--color-tier-estimated)'
                    };`}>
                      {c.fitnessClass === 'memory-bound' ? '🟦 mem' :
                       c.fitnessClass === 'compute-bound' ? '🟧 compute' :
                       '🟨 regime'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </details>
      </section>
    )}

    <section class="pb-12">
      <h3 class="text-lg font-semibold mb-3">使用此算子的模型 ({usedBy.length})</h3>
      {usedBy.length === 0 ? (
        <p class="text-sm" style="color: var(--color-text-muted);">尚无模型在算子拆解中引用此算子。</p>
      ) : (
        <ul class="space-y-2 text-sm">
          {usedBy.map((m) => {
            const decomp = m.operator_decomposition.find((d) => d.operator === op.id)!;
            return (
              <li>
                <a href={pathname(`/models/${m.id}/`)} class="block p-3 rounded border transition-transform hover:translate-x-0.5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
                  <div class="font-medium">{m.name}</div>
                  <div class="text-xs mt-1 font-mono" style="color: var(--color-text-muted);">
                    FLOPs/token: {decomp.flops_per_token.toExponential(2)} · Bytes/token: {decomp.bytes_per_token.toExponential(2)}
                  </div>
                </a>
              </li>
            );
          })}
        </ul>
      )}
    </section>
  </Container>
</BaseLayout>
