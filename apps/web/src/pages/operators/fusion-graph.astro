---
/**
 * /operators/fusion-graph/ — bipartite graph of operators ↔ fused-kernels.
 *
 * Complementary to /operators/fusion-matrix/ (table view from v1.22). The
 * table is best for lookup ("given operator X, which kernels fuse it"); this
 * graph is best for structural questions ("which operators are hubs across
 * many kernels", "which kernels are heavy-fusion combining many operators",
 * "are there isolated operators with zero kernels — data gap or by design?").
 *
 * Implementation: pure server-rendered SVG, no JS dep. Operators on the left
 * column grouped by category, fused-kernels on the right column grouped by
 * category, cubic Bezier curves drawn between connected (op, kernel) pairs.
 * Edge color = operator category; node size scaled by degree.
 *
 * Edges are derived from the union of two directions:
 *   - operator.participates_in_fused_kernels[*]
 *   - fused-kernel.fuses_operators[*]
 * This redundancy lets us catch data inconsistencies (declared in one
 * direction but not the other → flagged as `dataInconsistencies` for
 * future cleanup PRs).
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import { getOperators, getFusedKernels } from '~/lib/data';

const [operators, fusedKernels] = await Promise.all([getOperators(), getFusedKernels()]);

// Build the bipartite edge set by unioning both directions, then track
// inconsistencies (declared on only one side).
interface Edge {
  opId: string;
  kernelId: string;
  // Indicates which side(s) declared this relationship. Both = consistent.
  declaredFromOp: boolean;
  declaredFromKernel: boolean;
}

const edgeMap = new Map<string, Edge>(); // key = `${opId}|${kernelId}`
for (const op of operators) {
  for (const kid of op.participates_in_fused_kernels ?? []) {
    const key = `${op.id}|${kid}`;
    edgeMap.set(key, { opId: op.id, kernelId: kid, declaredFromOp: true, declaredFromKernel: false });
  }
}
for (const fk of fusedKernels) {
  for (const oid of fk.fuses_operators ?? []) {
    const key = `${oid}|${fk.id}`;
    const existing = edgeMap.get(key);
    if (existing) {
      existing.declaredFromKernel = true;
    } else {
      edgeMap.set(key, { opId: oid, kernelId: fk.id, declaredFromOp: false, declaredFromKernel: true });
    }
  }
}
const allEdges = Array.from(edgeMap.values());
const dataInconsistencies = allEdges.filter((e) => !e.declaredFromOp || !e.declaredFromKernel);

// Compute degree per node — needed for node sizing + sorting
const opDegree = new Map<string, number>();
const kernelDegree = new Map<string, number>();
for (const e of allEdges) {
  opDegree.set(e.opId, (opDegree.get(e.opId) ?? 0) + 1);
  kernelDegree.set(e.kernelId, (kernelDegree.get(e.kernelId) ?? 0) + 1);
}

// Group operators by category, then sort by degree desc within group
const opsByCategory = new Map<string, typeof operators>();
for (const op of operators) {
  if (!opsByCategory.has(op.category)) opsByCategory.set(op.category, []);
  opsByCategory.get(op.category)!.push(op);
}
for (const arr of opsByCategory.values()) {
  arr.sort((a, b) => (opDegree.get(b.id) ?? 0) - (opDegree.get(a.id) ?? 0) || a.id.localeCompare(b.id));
}

const kernelsByCategory = new Map<string, typeof fusedKernels>();
for (const fk of fusedKernels) {
  if (!kernelsByCategory.has(fk.category)) kernelsByCategory.set(fk.category, []);
  kernelsByCategory.get(fk.category)!.push(fk);
}
for (const arr of kernelsByCategory.values()) {
  arr.sort((a, b) => (kernelDegree.get(b.id) ?? 0) - (kernelDegree.get(a.id) ?? 0) || a.id.localeCompare(b.id));
}

// Layout: build flat ordered lists; each node gets (x, y) coordinates.
// SVG dimensions chosen to fit 30+ nodes per side with ~22px row height.
const SVG_WIDTH = 1100;
const ROW_H = 22;
const NODE_R = 5; // base radius (degree adds up to +4 px)
const LEFT_X = 240; // column anchor for operator column
const RIGHT_X = SVG_WIDTH - 260;
const TOP_PAD = 60;
const CATEGORY_GAP = 18;

// Build flat lists with category-group breaks
interface Node {
  id: string;
  name: string;
  category: string;
  x: number;
  y: number;
  degree: number;
  href: string;
}

function flattenWithGroups<T extends { id: string; name: string; category: string }>(
  byCat: Map<string, T[]>,
  x: number,
  hrefPrefix: string,
  degreeMap: Map<string, number>
): { nodes: Node[]; categoryAnchors: Array<{ category: string; y: number }> } {
  const sortedCategories = Array.from(byCat.keys()).sort();
  const nodes: Node[] = [];
  const categoryAnchors: Array<{ category: string; y: number }> = [];
  let y = TOP_PAD;
  for (const cat of sortedCategories) {
    categoryAnchors.push({ category: cat, y: y - 8 });
    for (const item of byCat.get(cat)!) {
      nodes.push({
        id: item.id,
        name: item.name,
        category: item.category,
        x,
        y,
        degree: degreeMap.get(item.id) ?? 0,
        href: `${hrefPrefix}/${item.id}/`
      });
      y += ROW_H;
    }
    y += CATEGORY_GAP;
  }
  return { nodes, categoryAnchors };
}

const { nodes: opNodes, categoryAnchors: opCatAnchors } = flattenWithGroups(opsByCategory, LEFT_X, pathname('/operators'), opDegree);
const { nodes: kernelNodes, categoryAnchors: kernelCatAnchors } = flattenWithGroups(kernelsByCategory, RIGHT_X, pathname('/fused-kernels'), kernelDegree);

const SVG_HEIGHT = Math.max(
  opNodes.length > 0 ? opNodes[opNodes.length - 1].y : 0,
  kernelNodes.length > 0 ? kernelNodes[kernelNodes.length - 1].y : 0
) + 40;

// Build node lookup for edge rendering
const opNodeById = new Map(opNodes.map((n) => [n.id, n]));
const kernelNodeById = new Map(kernelNodes.map((n) => [n.id, n]));

// Color palette for operator categories — deterministic, color-blind safe
const OP_CATEGORY_COLORS: Record<string, string> = {
  'attention': 'oklch(72% 0.18 28)', // warm red-orange
  'mlp': 'oklch(72% 0.18 145)', // green
  'normalization': 'oklch(72% 0.18 220)', // sky-blue
  'communication': 'oklch(72% 0.18 280)', // violet
  'sampling': 'oklch(72% 0.18 80)', // yellow-green
  'embedding': 'oklch(72% 0.18 195)', // teal
  'misc': 'oklch(72% 0.05 0)', // gray
  'rope': 'oklch(72% 0.18 320)' // magenta
};
function opCategoryColor(cat: string): string {
  return OP_CATEGORY_COLORS[cat] ?? 'oklch(72% 0.05 0)';
}

// Hubs (top-degree on each side) for the side-panel commentary
const opHubs = [...opNodes].sort((a, b) => b.degree - a.degree).slice(0, 5);
const kernelHubs = [...kernelNodes].sort((a, b) => b.degree - a.degree).slice(0, 5);
const isolatedOps = opNodes.filter((n) => n.degree === 0);
const isolatedKernels = kernelNodes.filter((n) => n.degree === 0);

// Edge "Bezier" path — simple horizontal cubic bezier
function edgePath(x1: number, y1: number, x2: number, y2: number): string {
  const dx = x2 - x1;
  const cx1 = x1 + dx * 0.5;
  const cx2 = x2 - dx * 0.5;
  return `M ${x1} ${y1} C ${cx1} ${y1}, ${cx2} ${y2}, ${x2} ${y2}`;
}
---
<BaseLayout title="算子 ↔ 融合 Kernel 二分图 / Operator-Kernel Fusion Graph">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        OPERATORS · FUSION GRAPH
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        算子 ↔ 融合 Kernel 二分图
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        左 = {opNodes.length} 个算子 (按 category 分组), 右 = {kernelNodes.length} 个融合 kernel.
        每条曲线 = 一个 (算子, kernel) 融合关系. 与
        <a href={pathname('/operators/fusion-matrix/')} style="color: var(--color-accent);" class="hover:underline">/operators/fusion-matrix/</a>
        互补 — 表格擅长 lookup ("算子 X 在哪些 kernel"), 图擅长结构 ("哪些算子是 hub", "哪些 kernel 是 heavy-fusion",
        "孤立的算子是数据缺失还是设计如此").
      </p>
      <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        <div class="rounded-lg border p-3" data-testid="fg-stat-edges" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{allEdges.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">融合关系总数</div>
        </div>
        <div class="rounded-lg border p-3" data-testid="fg-stat-hubs" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{opHubs[0]?.degree ?? 0}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">最大算子 hub 度数 ({opHubs[0]?.id ?? '—'})</div>
        </div>
        <div class="rounded-lg border p-3" data-testid="fg-stat-heavy" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{kernelHubs[0]?.degree ?? 0}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">最重 kernel 融合数 ({kernelHubs[0]?.id ?? '—'})</div>
        </div>
        <div class="rounded-lg border p-3" data-testid="fg-stat-issues" style={`border-color: ${dataInconsistencies.length > 0 ? 'var(--color-china)' : 'var(--color-border)'}; background: ${dataInconsistencies.length > 0 ? 'color-mix(in oklch, var(--color-china) 5%, var(--color-surface-raised))' : 'var(--color-surface-raised)'};`}>
          <div class="text-2xl font-semibold tabular-nums" style={dataInconsistencies.length > 0 ? 'color: var(--color-china);' : ''}>{dataInconsistencies.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">单边声明 (数据漂移)</div>
        </div>
      </div>
    </section>

    <!-- Side panel + graph -->
    <section class="py-8 border-t" style="border-color: var(--color-border);">
      <div class="grid lg:grid-cols-[260px,1fr] gap-6">
        <aside class="space-y-4 text-sm">
          <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <h3 class="text-xs uppercase tracking-wider font-semibold mb-3" style="color: var(--color-text-muted);">算子 hubs (最多 kernel)</h3>
            <ol class="space-y-2">
              {opHubs.map((n, idx) => (
                <li class="flex items-baseline gap-2 text-xs">
                  <span class="font-mono w-4 text-right" style="color: var(--color-text-muted);">{idx + 1}.</span>
                  <a href={n.href} class="hover:underline" style={`color: ${opCategoryColor(n.category)}; font-weight: 500;`}>{n.id}</a>
                  <span class="ml-auto tabular-nums font-mono" style="color: var(--color-text-muted);">×{n.degree}</span>
                </li>
              ))}
            </ol>
          </div>

          <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <h3 class="text-xs uppercase tracking-wider font-semibold mb-3" style="color: var(--color-text-muted);">Heavy-fusion kernels (融合最多算子)</h3>
            <ol class="space-y-2">
              {kernelHubs.map((n, idx) => (
                <li class="flex items-baseline gap-2 text-xs">
                  <span class="font-mono w-4 text-right" style="color: var(--color-text-muted);">{idx + 1}.</span>
                  <a href={n.href} class="hover:underline" style="color: var(--color-text); font-weight: 500;">{n.id}</a>
                  <span class="ml-auto tabular-nums font-mono" style="color: var(--color-text-muted);">×{n.degree}</span>
                </li>
              ))}
            </ol>
          </div>

          {(isolatedOps.length > 0 || isolatedKernels.length > 0) && (
            <div class="rounded-lg border p-4" style="border-color: var(--color-china); background: color-mix(in oklch, var(--color-china) 5%, var(--color-surface-raised));">
              <h3 class="text-xs uppercase tracking-wider font-semibold mb-3" style="color: var(--color-china);">⚠️ 孤立节点 (0 度)</h3>
              {isolatedOps.length > 0 && (
                <div class="mb-2">
                  <div class="text-xs font-medium mb-1">算子 ({isolatedOps.length}):</div>
                  <div class="text-xs space-x-1">
                    {isolatedOps.slice(0, 6).map((n) => (
                      <a href={n.href} class="inline-block px-1.5 py-0.5 rounded font-mono hover:underline" style="background: var(--color-bg); color: var(--color-text-muted);">{n.id}</a>
                    ))}
                    {isolatedOps.length > 6 && <span class="text-xs" style="color: var(--color-text-muted);">+{isolatedOps.length - 6}</span>}
                  </div>
                </div>
              )}
              {isolatedKernels.length > 0 && (
                <div>
                  <div class="text-xs font-medium mb-1">Kernels ({isolatedKernels.length}):</div>
                  <div class="text-xs space-x-1">
                    {isolatedKernels.slice(0, 6).map((n) => (
                      <a href={n.href} class="inline-block px-1.5 py-0.5 rounded font-mono hover:underline" style="background: var(--color-bg); color: var(--color-text-muted);">{n.id}</a>
                    ))}
                    {isolatedKernels.length > 6 && <span class="text-xs" style="color: var(--color-text-muted);">+{isolatedKernels.length - 6}</span>}
                  </div>
                </div>
              )}
              <p class="text-[11px] mt-2" style="color: var(--color-text-muted);">
                有意为之 (基础算子无融合需求) 还是数据缺失? 翻看每个对应实体的 yaml 的 <code style="background: var(--color-bg);">participates_in_fused_kernels</code> /
                <code style="background: var(--color-bg);">fuses_operators</code> 字段.
              </p>
            </div>
          )}

          {dataInconsistencies.length > 0 && (
            <div class="rounded-lg border p-4" style="border-color: var(--color-china); background: color-mix(in oklch, var(--color-china) 5%, var(--color-surface-raised));">
              <h3 class="text-xs uppercase tracking-wider font-semibold mb-2" style="color: var(--color-china);">⚠️ 数据漂移 (单边声明)</h3>
              <p class="text-[11px] mb-2" style="color: var(--color-text-muted);">
                只在 operator 或 fused-kernel 一侧声明的关系. 应该双边声明保持一致 — 这些是 PR 修复机会.
              </p>
              <ul class="text-[11px] space-y-1" data-testid="fg-inconsistencies">
                {dataInconsistencies.slice(0, 5).map((e) => (
                  <li>
                    <span class="font-mono" style="color: var(--color-text);">{e.opId}</span>
                    <span style="color: var(--color-text-muted);"> ↔ </span>
                    <span class="font-mono" style="color: var(--color-text);">{e.kernelId}</span>
                    <span class="ml-1 text-[10px]" style="color: var(--color-text-muted);">
                      ({e.declaredFromOp ? 'op→kernel only' : 'kernel→op only'})
                    </span>
                  </li>
                ))}
                {dataInconsistencies.length > 5 && (
                  <li style="color: var(--color-text-muted);">+{dataInconsistencies.length - 5} more</li>
                )}
              </ul>
            </div>
          )}
        </aside>

        <div class="overflow-x-auto rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <svg
            viewBox={`0 0 ${SVG_WIDTH} ${SVG_HEIGHT}`}
            xmlns="http://www.w3.org/2000/svg"
            data-testid="fusion-graph-svg"
            style={`width: 100%; height: auto; min-width: ${SVG_WIDTH}px;`}
            role="img"
            aria-labelledby="fg-title"
          >
            <title id="fg-title">Bipartite graph of operators and fused kernels</title>

            <!-- Column headers -->
            <text x={LEFT_X} y={32} text-anchor="middle" style="font-size: 13px; font-weight: 600; fill: var(--color-text);">
              算子 / Operators
            </text>
            <text x={RIGHT_X} y={32} text-anchor="middle" style="font-size: 13px; font-weight: 600; fill: var(--color-text);">
              融合 Kernels
            </text>

            <!-- Category labels (operators side) -->
            {opCatAnchors.map((c) => (
              <text x={LEFT_X - 120} y={c.y + 16} text-anchor="end" style="font-size: 9px; font-weight: 600; fill: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
                {c.category}
              </text>
            ))}
            <!-- Category labels (kernels side) -->
            {kernelCatAnchors.map((c) => (
              <text x={RIGHT_X + 120} y={c.y + 16} text-anchor="start" style="font-size: 9px; font-weight: 600; fill: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
                {c.category}
              </text>
            ))}

            <!-- Edges drawn first (behind nodes) -->
            <g style="opacity: 0.35;">
              {allEdges.map((e) => {
                const a = opNodeById.get(e.opId);
                const b = kernelNodeById.get(e.kernelId);
                if (!a || !b) return null;
                const color = opCategoryColor(a.category);
                const inconsistent = !e.declaredFromOp || !e.declaredFromKernel;
                return (
                  <path
                    d={edgePath(a.x + NODE_R, a.y, b.x - NODE_R, b.y)}
                    fill="none"
                    stroke={inconsistent ? 'var(--color-china)' : color}
                    stroke-width={inconsistent ? '1.5' : '1'}
                    stroke-dasharray={inconsistent ? '3 3' : ''}
                  />
                );
              })}
            </g>

            <!-- Operator nodes -->
            {opNodes.map((n) => {
              const r = NODE_R + Math.min(n.degree, 4);
              const color = opCategoryColor(n.category);
              return (
                <g>
                  <a href={n.href}>
                    <circle cx={n.x} cy={n.y} r={r} fill={color} stroke="var(--color-bg)" stroke-width="1.5" />
                    <text x={n.x - 12} y={n.y + 4} text-anchor="end" style={`font-size: 11px; fill: var(--color-text); font-weight: ${n.degree >= 3 ? '600' : '400'};`}>
                      {n.id}
                    </text>
                    {n.degree > 0 && (
                      <text x={n.x - 12} y={n.y + 4} text-anchor="end" dx={`-${(n.id.length + 1) * 6}`} style="font-size: 9px; fill: var(--color-text-muted); font-family: monospace;">
                        ×{n.degree}
                      </text>
                    )}
                  </a>
                </g>
              );
            })}

            <!-- Kernel nodes -->
            {kernelNodes.map((n) => {
              const r = NODE_R + Math.min(n.degree, 4);
              return (
                <g>
                  <a href={n.href}>
                    <circle cx={n.x} cy={n.y} r={r} fill="var(--color-text-muted)" stroke="var(--color-bg)" stroke-width="1.5" />
                    <text x={n.x + 12} y={n.y + 4} text-anchor="start" style={`font-size: 11px; fill: var(--color-text); font-weight: ${n.degree >= 3 ? '600' : '400'};`}>
                      {n.id}
                    </text>
                    {n.degree > 0 && (
                      <text x={n.x + 12} y={n.y + 4} text-anchor="start" dx={`${(n.id.length + 1) * 6}`} style="font-size: 9px; fill: var(--color-text-muted); font-family: monospace;">
                        ×{n.degree}
                      </text>
                    )}
                  </a>
                </g>
              );
            })}
          </svg>
        </div>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl font-semibold mb-2">如何读这张图</h2>
      <div class="grid lg:grid-cols-2 gap-4 text-sm">
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">节点大小 = 度数</h3>
          <p style="color: var(--color-text-muted);">
            算子节点圆圈越大 = 它参与越多融合 kernel; kernel 节点圆圈越大 = 它融合越多算子.
            <strong>{opHubs[0]?.id}</strong> ({opHubs[0]?.degree} kernels) 是最大算子 hub —
            高度可融合的算子, 任何加速优化都绕不开. <strong>{kernelHubs[0]?.id}</strong>
            ({kernelHubs[0]?.degree} ops) 是最重融合 kernel — 一次 fuse 多个算子, 是热路径优化标杆.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">边色 = 算子 category</h3>
          <p style="color: var(--color-text-muted);">
            红橙 = attention · 绿 = mlp · 蓝 = normalization · 紫 = communication ·
            黄绿 = sampling · 青 = embedding · 灰 = misc · 品红 = rope.
            视觉模式: attention 边密集向右汇聚到几个大 kernel (FlashAttn / FlashMLA / PagedAttention);
            communication 边稀疏 — TP/EP fused kernel 还是少.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">孤立节点 = 数据缺失或设计如此</h3>
          <p style="color: var(--color-text-muted);">
            0 度算子: 没有融合 kernel 引用. 可能合理 (基础原语如 cross-entropy / reduce-scatter 通常单独跑),
            也可能数据缺失. 翻原 yaml 的 <code style="background: var(--color-bg);">participates_in_fused_kernels</code>
            数组是不是空的 — 是的话 PR 补一下.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">虚线边 = 数据漂移</h3>
          <p style="color: var(--color-text-muted);">
            红色虚线 = 关系只在一边声明 (operator yaml 写了但 kernel yaml 没写, 或反之).
            应该双边一致. 当前 <strong>{dataInconsistencies.length}</strong> 条单边声明 —
            修复 PR 是非常 surgical 的: 在缺失那一侧的 yaml 里补一个 id 即可.
          </p>
        </div>
      </div>
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">下一步</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          想 lookup 具体 (op, kernel) 对? 走表格视图. 想读单个算子或 kernel 的完整文档?
          点节点跳详情页. 想理解算子在不同硬件上的适配度? 走 operator-hardware fitness panel.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/operators/fusion-matrix/')} class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;">融合矩阵 (表格视图) →</a>
          <a href={pathname('/operators/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">{opNodes.length} 算子目录 →</a>
          <a href={pathname('/fused-kernels/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">{kernelNodes.length} 融合 kernel 目录 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
