---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import SectionHeader from '~/components/ui/SectionHeader.astro';
import Badge from '~/components/ui/Badge.astro';
import { getResolvedHardware, getModels, getCases, getHardware } from '~/lib/data';
import { buildEfficiencyMap, getEfficiency } from '~/lib/calculator';

const hardwareResolved = await getResolvedHardware();
const hardwareRaw = await getHardware();
const models = await getModels();
const cases = await getCases();

// Insight 1: best decode tok/s/card across all cases
const bestDecodePerCard = cases
  .map((c) => ({ c, perCard: c.results.throughput_tokens_per_sec.decode / Math.max(c.stack.hardware.count, 1) }))
  .sort((a, b) => b.perCard - a.perCard)[0];

// Insight 2: best $/M tokens estimate (assume $2.5/h/card + 0.1/kWh + PUE 1.3)
function tcoFor(c: typeof cases[number]) {
  const hw = hardwareResolved.find((h) => h.id === c.stack.hardware.id);
  const tdp = hw?.power.tdp_w?.value ?? 700;
  const decodeTokPerSec = c.results.throughput_tokens_per_sec.decode;
  if (decodeTokPerSec <= 0) return null;
  const tokensPerHour = decodeTokPerSec * 3600;
  const hwCost = 2.5 * c.stack.hardware.count;
  const powerCostHr = (tdp * 1.3 * c.stack.hardware.count / 1000) * 0.1;
  return ((hwCost + powerCostHr) / tokensPerHour) * 1e6;
}
const cheapestTCO = cases
  .map((c) => ({ c, tco: tcoFor(c) }))
  .filter((x): x is { c: typeof cases[number]; tco: number } => x.tco !== null)
  .sort((a, b) => a.tco - b.tco)[0];

// Insight 3: efficiency calibration leaders + laggards
const effMap = buildEfficiencyMap(cases, hardwareRaw, models);
const calibratedHw = hardwareResolved
  .map((h) => ({ h, eff: getEfficiency(h.id, effMap) }))
  .filter((x) => x.eff.isCalibrated);
const effSorted = [...calibratedHw].sort((a, b) => b.eff.factor - a.eff.factor);
const efficiencyLeader = effSorted[0];
const efficiencyLaggard = effSorted[effSorted.length - 1];

// Insight 4: most-tested hardware (most case coverage)
const caseCountByHw = new Map<string, number>();
for (const c of cases) {
  caseCountByHw.set(c.stack.hardware.id, (caseCountByHw.get(c.stack.hardware.id) ?? 0) + 1);
}
const mostTestedHw = Array.from(caseCountByHw.entries())
  .map(([id, count]) => ({ id, count, hw: hardwareResolved.find((h) => h.id === id) }))
  .filter((x) => x.hw)
  .sort((a, b) => b.count - a.count)[0];

// Insight 5: biggest CN gap — Chinese hardware with measured efficiency far below overseas average
const overseasEff = effSorted.filter((x) => x.h.vendor.country !== 'CN').map((x) => x.eff.factor);
const cnEff = effSorted.filter((x) => x.h.vendor.country === 'CN');
const overseasAvg = overseasEff.length > 0 ? overseasEff.reduce((a, b) => a + b, 0) / overseasEff.length : 0;
const cnGap = cnEff.map((x) => ({
  ...x,
  gap: overseasAvg - x.eff.factor
})).sort((a, b) => b.gap - a.gap)[0];

// Insight 6: largest decode jump generation-over-generation (NVIDIA chain)
const nvidiaCards = hardwareResolved
  .filter((h) => h.vendor.id === 'nvidia')
  .map((h) => ({ h, bf16: h.compute.bf16_tflops?.value ?? 0 }))
  .sort((a, b) => a.h.release_year - b.h.release_year);
let biggestJump = { from: nvidiaCards[0], to: nvidiaCards[0], pct: 0 };
for (let i = 1; i < nvidiaCards.length; i++) {
  const prev = nvidiaCards[i - 1];
  const cur = nvidiaCards[i];
  if (!prev || !cur) continue;
  const pct = prev.bf16 > 0 ? ((cur.bf16 - prev.bf16) / prev.bf16) * 100 : 0;
  if (pct > biggestJump.pct) biggestJump = { from: prev, to: cur, pct };
}

// Insight 7: which model has been deployed on the most distinct hardware
const hwByModel = new Map<string, Set<string>>();
for (const c of cases) {
  const set = hwByModel.get(c.stack.model.id) ?? new Set();
  set.add(c.stack.hardware.id);
  hwByModel.set(c.stack.model.id, set);
}
const mostPortableModel = Array.from(hwByModel.entries())
  .map(([id, set]) => ({ id, count: set.size, model: models.find((m) => m.id === id) }))
  .filter((x) => x.model)
  .sort((a, b) => b.count - a.count)[0];

// Insight 8: super-pod scale advantage — cumulative scale-up domain leader
const superPodLeader = hardwareResolved
  .filter((h) => h.scale_up.world_size >= 32)
  .sort((a, b) => b.scale_up.world_size - a.scale_up.world_size)[0];
---
<BaseLayout title="精选发现">
  <Container>
    <section class="py-12">
      <SectionHeader eyebrow="SHOWCASE" title="精选发现 · 数据告诉我们什么"
        subtitle="从 138 个数据实体中自动计算的洞察。每次构建时刷新, 反映最新案例和实测校准。" />

      <p class="text-xs mb-8" style="color: var(--color-text-muted);">
        全部 8 个洞察都基于实时数据 — 添加新案例后, 这些数字会自动更新。
      </p>

      <div class="grid md:grid-cols-2 gap-4">

        {bestDecodePerCard && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-accent);">⚡ 单卡 Decode 之冠</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/cases/${bestDecodePerCard.c.id}/`)} class="hover:underline">{bestDecodePerCard.c.title}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{Math.round(bestDecodePerCard.perCard).toLocaleString()} <span class="text-sm opacity-60">tok/s/card</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              <a href={pathname(`/hardware/${bestDecodePerCard.c.stack.hardware.id}/`)} class="underline">{bestDecodePerCard.c.stack.hardware.id}</a> ×{bestDecodePerCard.c.stack.hardware.count} ·
              <a href={pathname(`/models/${bestDecodePerCard.c.stack.model.id}/`)} class="underline">{bestDecodePerCard.c.stack.model.id}</a> · {bestDecodePerCard.c.stack.engine.id} · {bestDecodePerCard.c.stack.quantization}
            </p>
          </article>
        )}

        {cheapestTCO && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-tier-measured); background: color-mix(in oklch, var(--color-tier-measured) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-tier-measured);">💰 最低 $/M tokens</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/cases/${cheapestTCO.c.id}/`)} class="hover:underline">{cheapestTCO.c.title}</a>
            </h3>
            <div class="font-mono text-3xl my-2">${cheapestTCO.tco.toFixed(2)}<span class="text-sm opacity-60"> /M tokens</span></div>
            <p class="text-xs mb-1" style="color: var(--color-text-muted);">
              {cheapestTCO.c.stack.hardware.id} ×{cheapestTCO.c.stack.hardware.count} · 假设 $2.5/h/卡 + $0.10/kWh + PUE 1.3
            </p>
          </article>
        )}

        {efficiencyLeader && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-accent);">🎯 实测校准最高 (软件栈最成熟)</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/hardware/${efficiencyLeader.h.id}/`)} class="hover:underline">{efficiencyLeader.h.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{efficiencyLeader.eff.factor.toFixed(2)} <span class="text-sm opacity-60">/ 1.00</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              基于 {efficiencyLeader.eff.sampleCount} 个案例的 measured/theoretical 比值。理论值的 {(efficiencyLeader.eff.factor * 100).toFixed(0)}% 已达到。
            </p>
          </article>
        )}

        {efficiencyLaggard && efficiencyLeader && efficiencyLaggard.h.id !== efficiencyLeader.h.id && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-tier-estimated); background: color-mix(in oklch, var(--color-tier-estimated) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-tier-estimated);">⚠️ 实测校准最低 (软件栈待优化)</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/hardware/${efficiencyLaggard.h.id}/`)} class="hover:underline">{efficiencyLaggard.h.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{efficiencyLaggard.eff.factor.toFixed(2)} <span class="text-sm opacity-60">/ 1.00</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              理论值的 {(efficiencyLaggard.eff.factor * 100).toFixed(0)}% — 软件栈优化空间巨大。
              {efficiencyLaggard.h.vendor.country === 'CN' && '国产硬件常见现象, 随 CANN/MUSA/MindIE 等迭代会逐年提升。'}
            </p>
          </article>
        )}

        {mostTestedHw && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-accent);">📊 测试最广 (社区贡献最多)</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/hardware/${mostTestedHw.id}/`)} class="hover:underline">{mostTestedHw.hw!.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{mostTestedHw.count} <span class="text-sm opacity-60">个 case</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              覆盖最广的硬件 — 数据飞轮在转。
            </p>
          </article>
        )}

        {cnGap && cnGap.gap > 0 && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-china); background: color-mix(in oklch, var(--color-china) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-china);">🚀 国产软件栈追赶机会</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/hardware/${cnGap.h.id}/`)} class="hover:underline">{cnGap.h.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">+{(cnGap.gap * 100).toFixed(0)}<span class="text-sm opacity-60"> 百分点 仍可优化</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              当前 {cnGap.eff.factor.toFixed(2)} vs 海外平均 {overseasAvg.toFixed(2)}。 软件栈每提升 0.05, 等效硬件性能提升 ~10%。
            </p>
          </article>
        )}

        {biggestJump.pct > 0 && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-accent);">📈 最大代际跃迁</div>
            <h3 class="text-lg font-semibold mb-2">
              {biggestJump.from?.h.name} → {biggestJump.to?.h.name}
            </h3>
            <div class="font-mono text-3xl my-2">+{biggestJump.pct.toFixed(0)}<span class="text-sm opacity-60"> % BF16</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              {biggestJump.from?.h.compute.bf16_tflops?.value} → {biggestJump.to?.h.compute.bf16_tflops?.value} TFLOPS BF16 ·
              {biggestJump.from?.h.release_year} → {biggestJump.to?.h.release_year}
            </p>
          </article>
        )}

        {mostPortableModel && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-accent);">🌍 跨硬件可移植性之冠</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/models/${mostPortableModel.id}/`)} class="hover:underline">{mostPortableModel.model!.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{mostPortableModel.count} <span class="text-sm opacity-60">种硬件</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              已在 {mostPortableModel.count} 种不同加速卡上有实测案例 — 部署友好度最高的 frontier 模型。
            </p>
          </article>
        )}

        {superPodLeader && (
          <article class="rounded-lg p-5 border" style="border-color: var(--color-china); background: color-mix(in oklch, var(--color-china) 5%, var(--color-bg));">
            <div class="text-xs uppercase tracking-wide font-semibold mb-2" style="color: var(--color-china);">🏗 Scale-up 域王者</div>
            <h3 class="text-lg font-semibold mb-2">
              <a href={pathname(`/hardware/${superPodLeader.id}/`)} class="hover:underline">{superPodLeader.name}</a>
            </h3>
            <div class="font-mono text-3xl my-2">{superPodLeader.scale_up.world_size} <span class="text-sm opacity-60">cards / domain</span></div>
            <p class="text-sm" style="color: var(--color-text-muted);">
              {superPodLeader.scale_up.protocol} · {superPodLeader.scale_up.bandwidth_gbps} GB/s. 单 scale-up 域内能放下整个超大 MoE.
            </p>
          </article>
        )}
      </div>

      <div class="mt-12 p-5 rounded-lg" style="background: var(--color-surface);">
        <h3 class="text-base font-semibold mb-2">↻ 这些数字怎么算的?</h3>
        <p class="text-sm" style="color: var(--color-text-muted);">
          每次构建网站时, 这个页面遍历所有 cases / hardware / models 实体, 即时计算上述指标。
          所以新增一个 case 后, "最低 $/M tokens" 等数字会自动更新。
        </p>
        <p class="text-sm mt-2" style="color: var(--color-text-muted);">
          公式见 <a href={pathname("/learn/")} class="underline" style="color: var(--color-accent);">/learn 学习中心</a>。
          数据可信度详见 <a href={pathname("/quality/")} class="underline" style="color: var(--color-accent);">/quality 数据质量</a>。
        </p>
      </div>
    </section>
  </Container>
</BaseLayout>
