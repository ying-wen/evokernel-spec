---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import SectionHeader from '~/components/ui/SectionHeader.astro';
import Leaderboard from '~/components/case/Leaderboard.tsx';
import { getCases } from '~/lib/data';

const cases = await getCases();
---
<BaseLayout title="部署案例">
  <Container>
    <section class="py-12">
      <SectionHeader eyebrow="CASES" title="部署案例 · 排行榜" subtitle={`${cases.length} 条实测部署 recipe · 按吞吐 / 延迟 / 日期排序 · 多维筛选`} />
      <Leaderboard cases={cases} client:load />
    </section>
  </Container>
</BaseLayout>
