---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import KpiCard from '~/components/ui/KpiCard.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import TierChip from '~/components/ui/TierChip.astro';
import { getCases, getPatterns, getPipelineStages, getPlaybooks } from '~/lib/data';
import CaseChart from '~/components/case/CaseChart.tsx';
import Breadcrumbs from '~/components/ui/Breadcrumbs.astro';
import { caseLD, breadcrumbLD } from '~/lib/jsonld';
import { recommendPatternsForCase, BOTTLENECK_LABEL_ZH, BOTTLENECK_COLOR } from '~/lib/bottleneck-map';

export async function getStaticPaths() {
  const cases = await getCases();
  return cases.map((c) => ({ params: { slug: c.id }, props: { c, allCases: cases } }));
}

const { c, allCases } = Astro.props;
const related = allCases.filter((x) => x.stack.model.id === c.stack.model.id);
const r = c.results;
const u = r.utilization;
const others = Math.max(0, 100 - u.compute_pct - u.memory_bw_pct);

// Bottleneck-aware pattern recommendation — closes the diagnosis loop:
// case (concrete proof) → bottleneck (diagnosis) → patterns (mechanism) → playbooks (recipes)
const allPatterns = await getPatterns();
const allStages = await getPipelineStages();
const allPlaybooks = await getPlaybooks();
const { recommendation, matchedPatterns } = recommendPatternsForCase(c, allPatterns);
const recommendedStages = allStages.filter((s) => recommendation.stage_ids.includes(s.id));
// Direct in-case patterns vs bottleneck-implied patterns — keep distinct so user sees
// what they ALREADY use vs what they COULD use.
const alreadyUsedPatternIds = new Set(c.patterns);
const newSuggestedPatterns = matchedPatterns.filter((p) => !alreadyUsedPatternIds.has(p.id));
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://evokernel.dev').toString();
const ldCase = caseLD(c, canonicalUrl);
const ldCrumbs = breadcrumbLD([
  { name: '首页', url: new URL('/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: '案例', url: new URL('/cases/', Astro.site ?? 'https://evokernel.dev').toString() },
  { name: c.title, url: canonicalUrl }
]);
---
<BaseLayout title={c.title}>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldCase)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(ldCrumbs)} />
  </Fragment>
  <Container>
    <article class="case-detail">
    <section class="pt-12 pb-3 print:hidden">
      <Breadcrumbs items={[
        { name: '首页', href: '/' },
        { name: '案例', href: '/cases/' },
        { name: c.title }
      ]} />
    </section>
    <section class="pt-3 pb-6">
      <h1 style="font-size: clamp(1.5rem, 1.2rem + 1vw, 2.25rem); font-weight: 600;">{c.title}</h1>
      <div class="text-xs mt-2" style="color: var(--color-text-muted);">由 <span style="color: var(--color-accent);">{c.submitter.github}</span> 于 {c.submitted_at} 提交 · <a href={canonicalUrl} style="color: var(--color-text-muted);">{canonicalUrl}</a></div>
      <div class="mt-3 print:hidden">
        <button type="button" onclick="window.print()" class="text-xs px-3 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted); background: var(--color-surface);">
          🖨 打印 / 导出 PDF
        </button>
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">Stack</h3>
      <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <SpecRow label="硬件"><a href={pathname(`/hardware/${c.stack.hardware.id}`)} class="underline" style="color: var(--color-accent);">{c.stack.hardware.id}</a> × {c.stack.hardware.count} ({c.stack.hardware.topology})</SpecRow>
        <SpecRow label="服务器">{c.stack.server?.id ?? '—'}</SpecRow>
        <SpecRow label="互联">intra: {c.stack.interconnect.intra_node} · inter: {c.stack.interconnect.inter_node}</SpecRow>
        <SpecRow label="模型"><a href={pathname(`/models/${c.stack.model.id}`)} class="underline" style="color: var(--color-accent);">{c.stack.model.id}</a> ({c.stack.model.weight_format})</SpecRow>
        <SpecRow label="引擎">{c.stack.engine.id} {c.stack.engine.version}</SpecRow>
        <SpecRow label="量化">{c.stack.quantization}</SpecRow>
        <SpecRow label="并行">TP={c.stack.parallel.tp} · PP={c.stack.parallel.pp} · EP={c.stack.parallel.ep} · SP={c.stack.parallel.sp}{c.stack.parallel.disaggregated ? ' · disaggregated' : ''}</SpecRow>
        <SpecRow label="驱动">{c.stack.driver}</SpecRow>
        <SpecRow label="OS">{c.stack.os}</SpecRow>
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">场景</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <KpiCard label="Prefill seq">{c.scenario.prefill_seq_len}</KpiCard>
        <KpiCard label="Decode seq">{c.scenario.decode_seq_len}</KpiCard>
        <KpiCard label="Batch">{c.scenario.batch_size}</KpiCard>
        <KpiCard label="Max concurrent">{c.scenario.max_concurrent_requests}</KpiCard>
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">结果</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-4">
        <KpiCard label="Decode tok/s" emphasize><span style="font-size: 1.5rem;">{r.throughput_tokens_per_sec.decode}</span></KpiCard>
        <KpiCard label="Prefill tok/s"><span style="font-size: 1.5rem;">{r.throughput_tokens_per_sec.prefill}</span></KpiCard>
        <KpiCard label="TTFT p50" sublabel="ms"><span style="font-size: 1.5rem;">{r.latency_ms.ttft_p50}</span></KpiCard>
        <KpiCard label="TBT p50" sublabel="ms"><span style="font-size: 1.5rem;">{r.latency_ms.tbt_p50}</span></KpiCard>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
        <KpiCard label="Memory/card" sublabel="GB"><span style="font-size: 1.5rem;">{r.memory_per_card_gb}</span></KpiCard>
        <KpiCard label="Power/card" sublabel="W"><span style="font-size: 1.5rem;">{r.power_per_card_w}</span></KpiCard>
        <KpiCard label="Compute" sublabel="util %"><span style="font-size: 1.5rem;">{u.compute_pct}</span></KpiCard>
        <KpiCard label="Memory BW" sublabel="util %"><span style="font-size: 1.5rem;">{u.memory_bw_pct}</span></KpiCard>
      </div>

      {related.length > 1 && (
        <div class="mb-6">
          <h4 class="text-sm font-semibold mb-2">同模型横向对比</h4>
          <CaseChart current={c} related={related} client:visible />
        </div>
      )}

      <h4 class="text-sm font-semibold mb-2">瓶颈分析 — <span style="color: var(--color-accent);">{c.bottleneck}</span></h4>
      <div class="flex h-8 rounded overflow-hidden" style="background: var(--color-surface);">
        {u.compute_pct > 0 && <div style={`width: ${u.compute_pct}%; background: var(--color-tier-measured);`} title={`compute ${u.compute_pct}%`}></div>}
        {u.memory_bw_pct > 0 && <div style={`width: ${u.memory_bw_pct}%; background: var(--color-accent);`} title={`memory bw ${u.memory_bw_pct}%`}></div>}
        {others > 0 && <div style={`width: ${others}%; background: var(--color-tier-estimated); opacity: 0.6;`} title={`other ${others}%`}></div>}
      </div>
      <div class="flex gap-4 text-xs mt-2" style="color: var(--color-text-muted);">
        <span>Compute {u.compute_pct}%</span>
        <span>Memory BW {u.memory_bw_pct}%</span>
        <span>Other {others}%</span>
      </div>

      {/* v1.14: bottleneck-aware diagnosis panel — closes the loop case → bottleneck → patterns → playbooks */}
      <div class="mt-6 rounded-lg border p-4" style={`border-color: ${BOTTLENECK_COLOR[c.bottleneck]}; background: color-mix(in oklch, ${BOTTLENECK_COLOR[c.bottleneck]} 5%, var(--color-bg));`}>
        <div class="text-xs uppercase tracking-wide mb-2" style={`color: ${BOTTLENECK_COLOR[c.bottleneck]};`}>
          🩺 诊断 / Diagnosis · {BOTTLENECK_LABEL_ZH[c.bottleneck]}
        </div>
        <p class="text-sm mb-3" style="color: var(--color-text);">{recommendation.diagnosis_zh}</p>
        <p class="text-sm font-medium mb-3" style="color: var(--color-text);">{recommendation.advice_zh}</p>

        {newSuggestedPatterns.length > 0 && (
          <div class="mt-4">
            <div class="text-xs uppercase tracking-wide mb-2" style="color: var(--color-text-muted);">建议尝试的优化模式 ({newSuggestedPatterns.length})</div>
            <div class="grid sm:grid-cols-2 gap-2">
              {newSuggestedPatterns.slice(0, 6).map((p) => (
                <a href={pathname(`/patterns/${p.id}/`)} class="block p-2.5 text-xs rounded border transition-transform hover:translate-x-0.5"
                   style="border-color: var(--color-border); background: var(--color-surface-raised);">
                  <div class="font-medium" style="color: var(--color-text);">{p.name}</div>
                  <div class="text-xs mt-0.5" style="color: var(--color-text-muted);">{p.category}</div>
                </a>
              ))}
            </div>
          </div>
        )}

        {alreadyUsedPatternIds.size > 0 && (
          <div class="mt-3 text-xs" style="color: var(--color-text-muted);">
            ✓ 此案例已应用: {Array.from(alreadyUsedPatternIds).join(', ')}
          </div>
        )}

        {recommendedStages.length > 0 && (
          <div class="mt-3 flex gap-2 flex-wrap text-xs">
            <span style="color: var(--color-text-muted);">影响阶段:</span>
            {recommendedStages.map((s) => (
              <a href={pathname(`/pipeline/${s.id}/`)} class="px-2 py-0.5 rounded hover:underline"
                 style="background: var(--color-surface); color: var(--color-accent);">{s.order}. {s.name_zh}</a>
            ))}
          </div>
        )}
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">复现步骤</h3>
      <pre class="text-xs p-4 rounded border overflow-x-auto" style="background: var(--color-surface-raised); border-color: var(--color-border);"><code>{c.reproduction.startup_command}</code></pre>
      <p class="text-xs mt-2" style="color: var(--color-text-muted);">Benchmark tool: {c.reproduction.benchmark_tool}</p>
    </section>

    {c.issues_encountered.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">踩坑记录</h3>
        <ul class="list-disc pl-5 space-y-2 text-sm">
          {c.issues_encountered.map((i) => <li>{i}</li>)}
        </ul>
      </section>
    )}

    {c.patterns.length > 0 && (
      <section class="pb-8">
        <h3 class="text-lg font-semibold mb-3">优化模式</h3>
        <div class="flex gap-2 flex-wrap">
          {c.patterns.map((p) => (
            <a href={pathname(`/patterns/${p}`)} class="text-sm px-3 py-1 rounded border" style="border-color: var(--color-accent); color: var(--color-accent);">
              {p}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="pb-12">
      <h3 class="text-lg font-semibold mb-3">引证</h3>
      <ol class="space-y-2 text-sm">
        {c.evidence.map((e, i) => (
          <li>
            [{i + 1}] {e.citation} —
            <a href={e.url} class="underline ml-1" style="color: var(--color-accent);" target="_blank" rel="noopener">{e.url}</a>
            <span class="ml-1" style="color: var(--color-text-muted);"> · {e.accessed}</span>
            <span class="ml-2"><TierChip tier={e.tier} /></span>
            {e.contributor_attestation && (
              <div class="text-xs mt-1 pl-4" style="color: var(--color-text-muted);">声明: {e.contributor_attestation}</div>
            )}
          </li>
        ))}
      </ol>
    </section>
    </article>
  </Container>
</BaseLayout>

<style is:global>
  @media print {
    /* Hide navigation, footer, and interactive controls when printing */
    header[role="banner"], header.sticky, footer, .print\:hidden { display: none !important; }
    body { background: white !important; color: black !important; }
    .case-detail { max-width: 100% !important; }
    .case-detail a { color: #0a4ca0 !important; text-decoration: underline; }
    .case-detail h1 { font-size: 24pt !important; }
    .case-detail h3 { font-size: 14pt !important; page-break-after: avoid; }
    /* Avoid breaking inside KPI cards or tables */
    .case-detail .grid > * { page-break-inside: avoid; }
    .case-detail pre { page-break-inside: avoid; white-space: pre-wrap !important; word-break: break-word; font-size: 9pt; }
    .case-detail dl { page-break-inside: avoid; }
    /* Show URL after links so PDFs are still useful offline */
    .case-detail a[href^="http"]::after { content: " (" attr(href) ")"; font-size: 8pt; color: #555; }
  }
</style>
