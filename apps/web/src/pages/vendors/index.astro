---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import SectionHeader from '~/components/ui/SectionHeader.astro';
import Badge from '~/components/ui/Badge.astro';
import { getVendors, getHardware, getModels } from '~/lib/data';

const vendors = await getVendors();
const hardware = await getHardware();
const models = await getModels();

function hwCount(vid: string) { return hardware.filter((h) => h.vendor === vid).length; }
function modelCount(vid: string) { return models.filter((m) => m.lab === vid).length; }

const cn = vendors.filter((v) => v.country === 'CN');
const overseas = vendors.filter((v) => v.country !== 'CN');
---
<BaseLayout title="厂商目录">
  <Container>
    <section class="py-12">
      <SectionHeader eyebrow="VENDORS" title="厂商目录" subtitle={`${vendors.length} 家厂商 · 硬件 + 模型 lab · 国别分组`} />

      <h3 class="text-xl font-semibold mt-12 mb-4" style="color: var(--color-china);">国产 ({cn.length})</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {cn.map((v) => (
          <a href={`/vendors/${v.id}/`} class="block">
            <article class="rounded-lg p-5 border h-full transition-transform hover:-translate-y-0.5"
                     style="background: var(--color-surface-raised); border-color: color-mix(in oklch, var(--color-china) 25%, var(--color-border));">
              <div class="flex justify-between items-start mb-2">
                <h4 class="text-base font-semibold">{v.chinese_names[0] ?? v.name}</h4>
                <Badge variant="china">{v.country}</Badge>
              </div>
              <div class="text-xs" style="color: var(--color-text-muted);">{v.name}</div>
              <dl class="grid grid-cols-2 gap-2 mt-3 text-xs">
                <div><dt style="color: var(--color-text-muted);">类型</dt><dd>{v.type}</dd></div>
                {hwCount(v.id) > 0 && <div><dt style="color: var(--color-text-muted);">硬件</dt><dd class="font-mono">{hwCount(v.id)}</dd></div>}
                {modelCount(v.id) > 0 && <div><dt style="color: var(--color-text-muted);">模型</dt><dd class="font-mono">{modelCount(v.id)}</dd></div>}
              </dl>
            </article>
          </a>
        ))}
      </div>

      <h3 class="text-xl font-semibold mt-12 mb-4">海外 ({overseas.length})</h3>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {overseas.map((v) => (
          <a href={`/vendors/${v.id}/`} class="block">
            <article class="rounded-lg p-5 border h-full transition-transform hover:-translate-y-0.5"
                     style="background: var(--color-surface-raised); border-color: var(--color-border);">
              <div class="flex justify-between items-start mb-2">
                <h4 class="text-base font-semibold">{v.name}</h4>
                <Badge>{v.country}</Badge>
              </div>
              <dl class="grid grid-cols-2 gap-2 mt-3 text-xs">
                <div><dt style="color: var(--color-text-muted);">类型</dt><dd>{v.type}</dd></div>
                {hwCount(v.id) > 0 && <div><dt style="color: var(--color-text-muted);">硬件</dt><dd class="font-mono">{hwCount(v.id)}</dd></div>}
                {modelCount(v.id) > 0 && <div><dt style="color: var(--color-text-muted);">模型</dt><dd class="font-mono">{modelCount(v.id)}</dd></div>}
              </dl>
            </article>
          </a>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>
