---
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';
import Container from '~/components/ui/Container.astro';
import KpiCard from '~/components/ui/KpiCard.astro';
import SpecRow from '~/components/ui/SpecRow.astro';
import Badge from '~/components/ui/Badge.astro';
import TierChip from '~/components/ui/TierChip.astro';
import { getServers, getResolvedHardware, getCases } from '~/lib/data';
import { marked } from 'marked';
import SwitchFabric from '~/components/server/SwitchFabric.astro';

export async function getStaticPaths() {
  const servers = await getServers();
  return servers.map((s) => ({ params: { slug: s.id }, props: { server: s } }));
}

const { server } = Astro.props;
const allHardware = await getResolvedHardware();
const card = allHardware.find((h) => h.id === server.card);
const allCases = await getCases();
const cases = allCases.filter((c) => c.stack.server?.id === server.id || (c.stack.hardware.id === server.card && c.stack.hardware.count === server.card_count));
const isChina = card ? card.vendor.country === 'CN' : false;
// Render cabinet_layout_md once at build time. Falsy when not populated.
const cabinetMd = server.cabinet_layout_md ? await marked.parse(server.cabinet_layout_md) : '';
const hasClusterDetail = (server.switch_chips?.length ?? 0) > 0
  || server.power_distribution
  || server.oversubscription_ratio !== undefined
  || server.bisection_bandwidth_tbs
  || server.host_cpu
  || server.network_topology
  || server.storage_architecture
  || cabinetMd;
const hostCpu = server.host_cpu;
const netTopo = server.network_topology;
const storage = server.storage_architecture;
// Architecture label kept short for chip; full description shown in row.
const archLabelMap: Record<string, string> = {
  'arm-neoverse-v2': 'ARM Neoverse V2',
  'arm-kunpeng': 'ARM Kunpeng',
  'arm-graviton': 'ARM Graviton',
  'x86-zen4': 'x86 Zen 4',
  'x86-zen5': 'x86 Zen 5',
  'x86-zen-licensed': 'x86 Zen (licensed)',
  'x86-sapphire-rapids': 'x86 Sapphire Rapids',
  'x86-emerald-rapids': 'x86 Emerald Rapids',
  'x86-granite-rapids': 'x86 Granite Rapids',
  'risc-v': 'RISC-V',
  'other': 'Other'
};
// Storage parallel-FS family labels.
const fsLabelMap: Record<string, string> = {
  'lustre': 'Lustre',
  'gpfs-spectrum-scale': 'IBM Spectrum Scale (GPFS)',
  'weka': 'Weka',
  'daos': 'DAOS',
  'beegfs': 'BeeGFS',
  'cephfs': 'CephFS',
  'pure-flashblade': 'Pure FlashBlade',
  'vast': 'VAST Data',
  'object-store-s3-compat': 'S3-compat object store',
  'cloud-managed': 'Cloud-managed',
  'none': '— 无 parallel FS',
  'other': 'Other / 厂商专有'
};
const ckptLabelMap: Record<string, string> = {
  'local-nvme': 'Local NVMe (per-node)',
  'parallel-fs': 'Parallel filesystem',
  'object-store': 'Object store (S3 / OSS)',
  'hybrid': 'Hybrid (hot NVMe + cold object/FS)',
  'unknown': 'Unknown'
};
// Topology family — same pattern as archLabelMap.
const topoLabelMap: Record<string, string> = {
  'fat-tree': 'Fat-Tree',
  'fat-tree-rail-optimized': 'Fat-Tree (rail-optimized)',
  'dragonfly-plus': 'Dragonfly+',
  'full-mesh': 'Full-Mesh',
  '2d-torus': '2D-Torus',
  '3d-torus': '3D-Torus',
  '4d-torus': '4D-Torus',
  'slim-fly': 'Slim-Fly',
  'optical-fabric': 'Optical Fabric',
  'hierarchical-mesh': 'Hierarchical Mesh',
  'star-burst': 'Star-Burst',
  'single-switch': 'Single-Switch',
  'other': 'Other'
};
---
<BaseLayout title={server.name}>
  <Container>
    <section class="pt-12 pb-6">
      <a href={pathname("/servers/")} class="text-sm" style="color: var(--color-text-muted);">← 服务器目录</a>
      <h1 style="font-size: clamp(2rem, 1.5rem + 1.5vw, 3rem); margin-top: 1rem; font-weight: 600;">{server.name}</h1>
      {server.chinese_names[0] && <div class="text-base mt-2" style="color: var(--color-china);">{server.chinese_names[0]}</div>}
      <div class="flex gap-2 mt-3 flex-wrap">
        <Badge variant={server.type === 'super-pod' ? 'china' : 'default'}>{server.type}</Badge>
        <Badge>{server.cooling}</Badge>
        <Badge>发布于 {server.release_year}</Badge>
        {isChina && <Badge variant="china">国产方案</Badge>}
      </div>
    </section>

    <section class="pb-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        <KpiCard label="卡数" sublabel="GPU/NPU"><span style="font-size: 1.75rem;">{server.card_count}</span></KpiCard>
        <KpiCard label="Scale-up 域" sublabel="cards"><span style="font-size: 1.75rem;">{server.scale_up_domain_size}</span></KpiCard>
        <KpiCard label="总显存" sublabel="GB"><span style="font-size: 1.75rem;">{server.total_memory_gb ?? '—'}</span></KpiCard>
        <KpiCard label="机柜功耗" sublabel="kW"><span style="font-size: 1.75rem;">{server.rack_power_kw ?? '—'}</span></KpiCard>
      </div>
    </section>

    <section class="pb-8">
      <h3 class="text-lg font-semibold mb-3">配置</h3>
      <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
        <SpecRow label="加速卡">
          {card ? (
            <a href={pathname(`/hardware/${card.id}/`)} class="underline" style="color: var(--color-accent);">{card.name}</a>
          ) : server.card}
          × {server.card_count}
        </SpecRow>
        <SpecRow label="Scale-up 互联">{server.intra_node_interconnect}</SpecRow>
        <SpecRow label="Scale-out 互联">{server.inter_node_interconnect}</SpecRow>
        <SpecRow label="冷却方式">{server.cooling}</SpecRow>
        {server.total_compute_pflops_bf16 && <SpecRow label="总 BF16 算力">{server.total_compute_pflops_bf16} PFLOPs</SpecRow>}
      </div>
    </section>

    {hasClusterDetail && (
      <section class="pb-10" id="cluster-internal">
        <h3 class="text-lg font-semibold mb-3 flex items-center gap-2">
          <span>集群内部 / Cluster internals</span>
          <span class="text-xs px-1.5 py-0.5 rounded" style="background: color-mix(in oklch, var(--color-accent) 14%, var(--color-bg)); color: var(--color-accent); font-weight: 600;">
            switch fabric · power · cabinet
          </span>
        </h3>

        <div class="grid lg:grid-cols-2 gap-4">
          {(server.switch_chips?.length ?? 0) > 0 && (
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
                <h4 class="text-sm font-semibold">Scale-up 交换 fabric</h4>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  switch chip × radix × per-port BW = 总 fabric 容量
                </p>
              </div>
              <div class="p-4 space-y-3">
                {(server.switch_chips ?? []).map((s) => {
                  const totalGBps = s.count * s.radix * s.bandwidth_gbps_per_port;
                  return (
                    <div class="rounded p-3 border" style="border-color: var(--color-border); background: var(--color-bg);">
                      <div class="flex justify-between items-baseline gap-2">
                        <span class="font-mono text-sm font-semibold" style="color: var(--color-text);">{s.name}</span>
                        <span class="text-xs font-mono" style="color: var(--color-text-muted);">×{s.count}</span>
                      </div>
                      <div class="grid grid-cols-3 gap-2 mt-2 text-xs">
                        <div>
                          <div style="color: var(--color-text-muted);">radix</div>
                          <div class="font-mono font-semibold">{s.radix}</div>
                        </div>
                        <div>
                          <div style="color: var(--color-text-muted);">per-port</div>
                          <div class="font-mono font-semibold">{s.bandwidth_gbps_per_port} GB/s</div>
                        </div>
                        <div>
                          <div style="color: var(--color-text-muted);">aggregate</div>
                          <div class="font-mono font-semibold" style="color: var(--color-accent);">{(totalGBps / 1000).toFixed(1)} TB/s</div>
                        </div>
                      </div>
                      {s.url && (
                        <a href={s.url} target="_blank" rel="noopener" class="text-xs underline mt-2 inline-block" style="color: var(--color-accent);">datasheet →</a>
                      )}
                    </div>
                  );
                })}
                {server.bisection_bandwidth_tbs?.value && (
                  <div class="text-xs px-3 py-2 rounded" style="background: color-mix(in oklch, var(--color-tier-measured) 8%, var(--color-bg)); color: var(--color-tier-measured);">
                    🟢 <strong>Scale-up bisection: {server.bisection_bandwidth_tbs.value} TB/s</strong> (full bandwidth between any pair within the scale-up domain)
                  </div>
                )}
              </div>
            </div>
          )}

          {(server.power_distribution || server.scale_out_nics_per_node || server.oversubscription_ratio !== undefined) && (
            <div class="rounded-lg border" style="border-color: var(--color-border); background: var(--color-surface-raised);">
              <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
                <h4 class="text-sm font-semibold">电力 + Scale-out 出口</h4>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  PSU 配置、过订比、机柜外端口
                </p>
              </div>
              <div>
                {server.power_distribution?.psu_count && <SpecRow label="PSU 数量">{server.power_distribution.psu_count} ({server.power_distribution.redundancy ?? 'N'})</SpecRow>}
                {server.power_distribution?.sustained_kw && <SpecRow label="持续功耗">{server.power_distribution.sustained_kw} kW</SpecRow>}
                {server.power_distribution?.peak_kw && <SpecRow label="峰值功耗">{server.power_distribution.peak_kw} kW</SpecRow>}
                {server.power_distribution?.voltage && <SpecRow label="供电电压">{server.power_distribution.voltage}</SpecRow>}
                {server.scale_out_nics_per_node && <SpecRow label="Scale-out NIC / 节点">{server.scale_out_nics_per_node}</SpecRow>}
                {server.scale_out_bandwidth_gbps_per_nic && <SpecRow label="Per-NIC 带宽">{server.scale_out_bandwidth_gbps_per_nic} GB/s</SpecRow>}
                {server.oversubscription_ratio !== undefined && <SpecRow label="Scale-out 过订比">{server.oversubscription_ratio.toFixed(1)}× {server.oversubscription_ratio === 1 ? '(full bisection)' : `(${server.oversubscription_ratio}:1)`}</SpecRow>}
              </div>
            </div>
          )}

          {hostCpu && (
            <div class="rounded-lg border" data-testid="host-cpu-card" style={`border-color: ${hostCpu.has_coherent_gpu_link ? 'var(--color-accent)' : 'var(--color-border)'}; background: var(--color-surface-raised);`}>
              <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
                <h4 class="text-sm font-semibold flex items-center gap-2">
                  Host CPU
                  {hostCpu.has_coherent_gpu_link && <Badge variant="default">GPU-coherent</Badge>}
                </h4>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  {hostCpu.name}
                </p>
              </div>
              <div>
                <SpecRow label="厂商">{hostCpu.vendor}</SpecRow>
                <SpecRow label="架构">{archLabelMap[hostCpu.architecture] ?? hostCpu.architecture}</SpecRow>
                {hostCpu.cores_per_node && <SpecRow label="核心 / 节点">{hostCpu.cores_per_node}{hostCpu.sockets_per_node ? ` (${hostCpu.sockets_per_node} sockets)` : ''}</SpecRow>}
                {hostCpu.host_ram_gb && <SpecRow label="Host RAM">{hostCpu.host_ram_gb} GB</SpecRow>}
                {hostCpu.pcie_gen && <SpecRow label="PCIe">Gen {hostCpu.pcie_gen}{hostCpu.pcie_lanes_per_node ? ` × ${hostCpu.pcie_lanes_per_node} lanes` : ''}</SpecRow>}
                <SpecRow label="GPU-coherent 链路">{hostCpu.has_coherent_gpu_link ? '✓ NVLink-C2C / Infinity-Fabric / 类似' : '— PCIe-only'}</SpecRow>
              </div>
              {hostCpu.notes && (
                <div class="px-4 py-3 border-t text-xs" style="border-color: var(--color-border); color: var(--color-text-muted); line-height: 1.6;">
                  {hostCpu.notes}
                </div>
              )}
              <div class="px-4 py-2 border-t text-xs" style="border-color: var(--color-border);">
                <a href={pathname('/servers/host-cpu-matrix/')} class="hover:underline" style="color: var(--color-accent);">
                  → 14/14 super-pod host CPU 对照矩阵
                </a>
              </div>
            </div>
          )}

          {netTopo && (
            <div class="rounded-lg border" data-testid="network-topology-card" style={`border-color: ${netTopo.in_network_reduction ? 'var(--color-accent)' : 'var(--color-border)'}; background: var(--color-surface-raised);`}>
              <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
                <h4 class="text-sm font-semibold flex items-center gap-2">
                  网络拓扑
                  {netTopo.in_network_reduction && <Badge variant="default">In-Network Reduction</Badge>}
                </h4>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  {topoLabelMap[netTopo.topology] ?? netTopo.topology}
                </p>
              </div>
              <div>
                <SpecRow label="拓扑">{topoLabelMap[netTopo.topology] ?? netTopo.topology}</SpecRow>
                {netTopo.diameter_hops !== undefined && <SpecRow label="网络直径">{netTopo.diameter_hops} 跳</SpecRow>}
                {netTopo.bisection_bandwidth_gbps_per_node !== undefined && <SpecRow label="Bisection / 节点">{netTopo.bisection_bandwidth_gbps_per_node} GB/s</SpecRow>}
                {netTopo.latency_us_p99_intra_node !== undefined && <SpecRow label="节点内 latency p99">{netTopo.latency_us_p99_intra_node} μs</SpecRow>}
                {netTopo.latency_us_p99_inter_node !== undefined && <SpecRow label="跨节点 latency p99">{netTopo.latency_us_p99_inter_node} μs</SpecRow>}
                {netTopo.switch_count !== undefined && <SpecRow label="Switch chip 数">{netTopo.switch_count}</SpecRow>}
                <SpecRow label="In-network reduction">{netTopo.in_network_reduction ? '✓ SHARP / 类似' : '— 不支持'}</SpecRow>
                <SpecRow label="RDMA">{netTopo.rdma_capable ? '✓ 支持' : '— 不支持'}</SpecRow>
              </div>
              {netTopo.notes && (
                <div class="px-4 py-3 border-t text-xs" style="border-color: var(--color-border); color: var(--color-text-muted); line-height: 1.6; white-space: pre-line;">
                  {netTopo.notes}
                </div>
              )}
              <div class="px-4 py-2 border-t text-xs" style="border-color: var(--color-border);">
                <a href={pathname('/servers/network-topology-matrix/')} class="hover:underline" style="color: var(--color-accent);">
                  → 14/14 super-pod 网络拓扑对照矩阵
                </a>
              </div>
            </div>
          )}

          {storage && (
            <div class="rounded-lg border" data-testid="storage-card" style={`border-color: ${storage.gpu_direct_storage ? 'var(--color-accent)' : 'var(--color-border)'}; background: var(--color-surface-raised);`}>
              <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
                <h4 class="text-sm font-semibold flex items-center gap-2">
                  存储架构
                  {storage.gpu_direct_storage && <Badge variant="default">GPU Direct Storage</Badge>}
                </h4>
                <p class="text-xs mt-1" style="color: var(--color-text-muted);">
                  {storage.parallel_fs_family ? (fsLabelMap[storage.parallel_fs_family] ?? storage.parallel_fs_family) : 'Storage path'}
                </p>
              </div>
              <div>
                {storage.local_nvme_per_node_tb !== undefined && <SpecRow label="Local NVMe / 节点">{storage.local_nvme_per_node_tb} TB</SpecRow>}
                {storage.parallel_fs_pb !== undefined && <SpecRow label="Parallel FS 容量">{storage.parallel_fs_pb} PB</SpecRow>}
                {storage.parallel_fs_family && <SpecRow label="Parallel FS 类型">{fsLabelMap[storage.parallel_fs_family] ?? storage.parallel_fs_family}</SpecRow>}
                {storage.checkpoint_strategy && <SpecRow label="Checkpoint 策略">{ckptLabelMap[storage.checkpoint_strategy] ?? storage.checkpoint_strategy}</SpecRow>}
                {storage.aggregate_read_bandwidth_gbps !== undefined && <SpecRow label="聚合读带宽">{storage.aggregate_read_bandwidth_gbps} GB/s</SpecRow>}
                <SpecRow label="GPU Direct Storage">{storage.gpu_direct_storage ? '✓ GDS / NPU-DS' : '— 经 host RAM 中转'}</SpecRow>
                <SpecRow label="RDMA to storage">{storage.rdma_storage ? '✓ NVMe-oF / RoCE' : '— 不支持'}</SpecRow>
              </div>
              {storage.notes && (
                <div class="px-4 py-3 border-t text-xs" style="border-color: var(--color-border); color: var(--color-text-muted); line-height: 1.6; white-space: pre-line;">
                  {storage.notes}
                </div>
              )}
              <div class="px-4 py-2 border-t text-xs" style="border-color: var(--color-border);">
                <a href={pathname('/servers/storage-matrix/')} class="hover:underline" style="color: var(--color-accent);">
                  → 14/14 super-pod 存储架构对照矩阵
                </a>
              </div>
            </div>
          )}
        </div>

        {(server.switch_chips?.length ?? 0) > 0 && (
          <div class="mt-4">
            <SwitchFabric server={server} />
          </div>
        )}

        {cabinetMd && (
          <div class="mt-4 rounded-lg border p-5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
            <article class="cabinet-md" style="color: var(--color-text); line-height: 1.7;" set:html={cabinetMd}></article>
          </div>
        )}
      </section>
    )}

    <section class="pb-12">
      <h3 class="text-lg font-semibold mb-3">部署案例 ({cases.length})</h3>
      {cases.length === 0 ? (
        <p class="text-sm" style="color: var(--color-text-muted);">尚无关联案例。<a href="https://github.com/evokernel/evokernel-spec" class="underline ml-1" style="color: var(--color-accent);">贡献第一个?</a></p>
      ) : (
        <ul class="space-y-2 text-sm">
          {cases.map((c) => (
            <li>
              <a href={pathname(`/cases/${c.id}/`)} class="block p-3 rounded border transition-transform hover:translate-x-0.5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
                <div class="font-medium">{c.title}</div>
                <div class="text-xs mt-1 font-mono" style="color: var(--color-text-muted);">
                  {c.stack.model.id} · {c.stack.engine.id} · {c.stack.quantization} · decode {c.results.throughput_tokens_per_sec.decode} tok/s
                </div>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <section class="pb-12">
      <h3 class="text-lg font-semibold mb-3">引证</h3>
      <ol class="space-y-2 text-sm">
        {server.evidence.map((e, i) => (
          <li>
            [{i + 1}] {e.citation} —
            <a href={e.url} class="underline ml-1" style="color: var(--color-accent);" target="_blank" rel="noopener">{e.url}</a>
            <span class="ml-2"><TierChip tier={e.tier} /></span>
          </li>
        ))}
      </ol>
    </section>
  </Container>
</BaseLayout>

<style>
  .cabinet-md :global(h2) { font-size: 1.05rem; font-weight: 600; margin-top: 0; margin-bottom: 0.5rem; }
  .cabinet-md :global(h3) { font-size: 0.95rem; font-weight: 600; margin-top: 1rem; margin-bottom: 0.5rem; }
  .cabinet-md :global(p) { margin-bottom: 0.5rem; }
  .cabinet-md :global(ul) { margin-left: 1.25rem; list-style: disc; margin-bottom: 0.5rem; }
  .cabinet-md :global(li) { margin-bottom: 0.2rem; }
  .cabinet-md :global(strong) { color: var(--color-text); font-weight: 600; }
  .cabinet-md :global(code) { background: var(--color-surface); padding: 0.1rem 0.3rem; border-radius: 0.25rem; font-size: 0.875em; font-family: var(--font-mono); }
</style>
