---
/**
 * /servers/storage-matrix/ — storage architecture comparison across super-pods.
 *
 * Third architectural axis after host_cpu (v1.27) and network_topology (v1.28).
 * The storage path constrains real production: where weights live, how fast
 * checkpoints save, whether the GPU can read NVMe directly (GDS).
 *
 * Reads from data/servers/*.yaml (any server with storage_architecture populated).
 * Surfaces the divide between GDS-capable systems (NVL72 / GB300 / DGX A100 /
 * H100/H200 / CloudMatrix 384 / Atlas 900 / Atlas 800T) vs PCIe-bound systems
 * (MI325X / MI300A / Cambricon / Moore Threads) vs cloud-only object-store
 * paths (AWS Trn2).
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import { getServers } from '~/lib/data';

const allServers = await getServers();
const serversWithStorage = allServers.filter((s) => s.storage_architecture).sort((a, b) => {
  // Group by gpu_direct_storage first (GDS-capable first), then by FS family
  const aGds = a.storage_architecture!.gpu_direct_storage ?? false;
  const bGds = b.storage_architecture!.gpu_direct_storage ?? false;
  if (aGds !== bGds) return aGds ? -1 : 1;
  return (a.storage_architecture!.parallel_fs_family ?? '').localeCompare(b.storage_architecture!.parallel_fs_family ?? '') || a.id.localeCompare(b.id);
});

interface Row {
  label_zh: string;
  label_en: string;
  format: (s: typeof serversWithStorage[number]) => string;
  highlight?: 'max' | 'min';
}

const fsLabelMap: Record<string, string> = {
  'lustre': 'Lustre',
  'gpfs-spectrum-scale': 'GPFS',
  'weka': 'Weka',
  'daos': 'DAOS',
  'beegfs': 'BeeGFS',
  'cephfs': 'CephFS',
  'pure-flashblade': 'Pure FlashBlade',
  'vast': 'VAST',
  'object-store-s3-compat': 'S3-compat',
  'cloud-managed': 'Cloud-managed',
  'none': 'None',
  'other': 'Other'
};
const ckptLabelMap: Record<string, string> = {
  'local-nvme': 'Local NVMe',
  'parallel-fs': 'Parallel FS',
  'object-store': 'Object Store',
  'hybrid': 'Hybrid',
  'unknown': 'Unknown'
};

const ROWS: Row[] = [
  { label_zh: 'Local NVMe / 节点 (TB)', label_en: 'Local NVMe / node', format: (s) => s.storage_architecture!.local_nvme_per_node_tb !== undefined ? `${s.storage_architecture!.local_nvme_per_node_tb} TB` : '—', highlight: 'max' },
  { label_zh: 'Parallel FS 容量 (PB)', label_en: 'Parallel FS capacity', format: (s) => s.storage_architecture!.parallel_fs_pb !== undefined ? `${s.storage_architecture!.parallel_fs_pb} PB` : '—', highlight: 'max' },
  { label_zh: 'Parallel FS 类型', label_en: 'Parallel FS family', format: (s) => s.storage_architecture!.parallel_fs_family ? (fsLabelMap[s.storage_architecture!.parallel_fs_family] ?? s.storage_architecture!.parallel_fs_family) : '—' },
  { label_zh: 'Checkpoint 策略', label_en: 'Checkpoint strategy', format: (s) => s.storage_architecture!.checkpoint_strategy ? (ckptLabelMap[s.storage_architecture!.checkpoint_strategy] ?? s.storage_architecture!.checkpoint_strategy) : '—' },
  { label_zh: '聚合读带宽 (GB/s)', label_en: 'Aggregate read', format: (s) => s.storage_architecture!.aggregate_read_bandwidth_gbps !== undefined ? `${s.storage_architecture!.aggregate_read_bandwidth_gbps} GB/s` : '—', highlight: 'max' },
  { label_zh: 'GPU Direct Storage', label_en: 'GDS', format: (s) => s.storage_architecture!.gpu_direct_storage ? '✓' : '—' },
  { label_zh: 'RDMA to storage', label_en: 'RDMA storage', format: (s) => s.storage_architecture!.rdma_storage ? '✓' : '—' },
  { label_zh: 'GPU 总数', label_en: 'Total GPUs', format: (s) => `${s.card_count}× ${s.card}` },
  { label_zh: 'Notes', label_en: 'Notes', format: (s) => s.storage_architecture!.notes ?? '—' }
];

function extractNumber(s: string): number | null {
  const match = s.match(/^([\d.]+)/);
  return match ? Number(match[1]) : null;
}

function findHighlightId(row: Row): string | null {
  if (!row.highlight) return null;
  const nums = serversWithStorage.map((s) => ({ id: s.id, n: extractNumber(row.format(s)) }));
  const valid = nums.filter((x) => x.n !== null);
  if (valid.length === 0) return null;
  const winner = valid.reduce((best, cur) => {
    if (best.n === null) return cur;
    if (cur.n === null) return best;
    if (row.highlight === 'max' && cur.n > best.n) return cur;
    if (row.highlight === 'min' && cur.n < best.n) return cur;
    return best;
  });
  return winner.id;
}

// FS family + checkpoint distribution stats
const fsCounts = new Map<string, number>();
for (const s of serversWithStorage) {
  const fam = s.storage_architecture!.parallel_fs_family ?? 'unknown';
  fsCounts.set(fam, (fsCounts.get(fam) ?? 0) + 1);
}
const totalServers = allServers.length;
const populated = serversWithStorage.length;
const gdsCount = serversWithStorage.filter((s) => s.storage_architecture!.gpu_direct_storage).length;
---
<BaseLayout title="超节点 存储架构对照 / Storage Matrix">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        SERVERS · STORAGE MATRIX
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        存储架构对照矩阵
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        存储是 cluster-internal 第三个架构轴 — 决定权重 / dataset / checkpoint 路径.
        GDS-capable 系统 (NVL72 / DGX A100 / HGX H100/H200 / CloudMatrix 384) 让 GPU
        直接 RDMA 读 NVMe; 没有 GDS 的系统 (MI325X / MI300A / Cambricon / Moore Threads)
        必须经过 host RAM. AWS Trn2 是 cloud-only object-store 路径.
        每行 <span style="color: var(--color-accent);">★</span> 标记最优值.
      </p>
      <div class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        <div class="rounded-lg border p-3" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{populated}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">已填 storage / {totalServers} 总数</div>
        </div>
        <div class="rounded-lg border p-3" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{fsCounts.size}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">不同 FS 类型</div>
        </div>
        <div class="rounded-lg border p-3" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{gdsCount}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">含 GPU Direct Storage</div>
        </div>
        <div class="rounded-lg border p-3" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <div class="text-2xl font-semibold tabular-nums">{ROWS.length}</div>
          <div class="text-xs mt-1" style="color: var(--color-text-muted);">对比维度</div>
        </div>
      </div>
    </section>

    <section class="py-6 border-t" style="border-color: var(--color-border);" aria-labelledby="fs-distribution-heading">
      <h2 id="fs-distribution-heading" class="text-lg font-semibold mb-3">Parallel FS 分布</h2>
      <div class="flex flex-wrap gap-2 text-xs">
        {Array.from(fsCounts.entries()).sort((a, b) => b[1] - a[1]).map(([fs, count]) => (
          <span class="px-3 py-1.5 rounded border" style="border-color: var(--color-border); background: var(--color-surface-raised); color: var(--color-text);">
            <strong style="color: var(--color-accent);">{fsLabelMap[fs] ?? fs}</strong>
            <span class="ml-2" style="color: var(--color-text-muted);">×{count}</span>
          </span>
        ))}
      </div>
    </section>

    <section class="py-6 border-t" style="border-color: var(--color-border);" aria-labelledby="matrix-heading">
      <h2 id="matrix-heading" class="text-lg font-semibold mb-3">存储架构详情对照</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" style="border-collapse: collapse; min-width: 720px;" data-testid="storage-matrix">
          <thead>
            <tr style="border-bottom: 2px solid var(--color-border);">
              <th class="text-left py-3 px-3 font-semibold sticky left-0" style="color: var(--color-text-muted); background: var(--color-bg);">维度 / Axis</th>
              {serversWithStorage.map((s) => (
                <th class="text-left py-3 px-3 font-semibold" style="color: var(--color-text); min-width: 220px;">
                  <a href={pathname(`/servers/${s.id}/`)} class="hover:underline" style="color: var(--color-accent);">{s.name}</a>
                  <div class="text-xs font-normal mt-0.5" style="color: var(--color-text-muted);">{s.id}</div>
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {ROWS.map((row) => {
              const winnerId = findHighlightId(row);
              return (
                <tr style="border-bottom: 1px solid var(--color-border);" data-testid={`storage-row-${row.label_en.toLowerCase().replace(/\s+/g, '-').replace(/\//g, '')}`}>
                  <td class="py-2.5 px-3 align-top text-xs sticky left-0" style="background: var(--color-bg);">
                    <div class="font-semibold" style="color: var(--color-text);">{row.label_zh}</div>
                    <div class="font-normal" style="color: var(--color-text-muted);">{row.label_en}</div>
                  </td>
                  {serversWithStorage.map((s) => {
                    const isWinner = winnerId === s.id;
                    return (
                      <td class="py-2.5 px-3 align-top text-xs" style={isWinner
                        ? 'color: var(--color-accent); font-weight: 600; background: color-mix(in oklch, var(--color-accent) 5%, transparent);'
                        : 'color: var(--color-text);'}>
                        {row.format(s)}
                        {isWinner && <span class="ml-1" aria-label="best in this row">★</span>}
                      </td>
                    );
                  })}
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);" aria-labelledby="why-heading">
      <h2 id="why-heading" class="text-lg font-semibold mb-3">为什么存储架构重要</h2>
      <div class="grid lg:grid-cols-2 gap-4 text-sm">
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">1. GPU Direct Storage 是分水岭</h3>
          <p style="color: var(--color-text-muted);">
            GDS 让 GPU RDMA 直接读 NVMe / 远端 FS, 跳过 host RAM 中转. 多 1-2x weight load
            速度, 大型 dataset training 时 dataloader 不再是瓶颈. NVIDIA + CUDA 路径成熟,
            华为 NPU-DS 是国产对标. AMD ROCm DirectGMA 仍 experimental — 这是 ROCm 生态相对
            CUDA 的真实 storage gap.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">2. Local NVMe 决定 weight reload 速度</h3>
          <p style="color: var(--color-text-muted);">
            Hybrid checkpoint (NVL72 / GB300) 把热权重存 local NVMe, 重启时秒级 reload;
            纯 parallel-fs 路径 (HGX, Atlas 900) reload 受 FS 网络限制 (分钟级).
            生产服务 MTBF 优化时, hybrid 是更合理选择.
            <a href={pathname('/patterns/hot-cold-kv-tiering/')} class="hover:underline" style="color: var(--color-accent);">hot-cold KV 分层</a>
            patterns 受 storage 选择直接影响.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">3. 信创存储替代 = OceanStor</h3>
          <p style="color: var(--color-text-muted);">
            国央企部署对 storage 也有自主可控要求. CloudMatrix 384 / Atlas 900 通常配
            OceanStor (华为分布式 FS), 与 NPU Direct Storage 集成. 思元 590 集群多用 OceanStor
            或自研. Lustre / Weka 在国央企不可用 — 是国产部署 storage 选择的核心约束.
          </p>
        </div>
        <div class="rounded-lg border p-4" style="border-color: var(--color-border); background: var(--color-surface-raised);">
          <h3 class="text-sm font-semibold mb-2" style="color: var(--color-accent);">4. Cloud vs on-premise 是根本路径差</h3>
          <p style="color: var(--color-text-muted);">
            AWS Trn2 走 S3 object store 不是 weakness — 是 cloud-native 的 trade-off:
            cluster-elastic + 按需 scaling 必然走 object store. On-premise super-pod 走
            parallel FS 是因为持久 storage 性能优先. 选 storage 路径前先想 deploy 模式
            (cloud vs on-premise vs hybrid) 决定一切.
          </p>
        </div>
      </div>
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">三个 cluster-internal 架构轴</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          v1.27 host_cpu (compute 轴), v1.28 network_topology (fabric 轴), v1.29 storage (持久层轴) — 14/14 super-pod 三个轴全部 covered.
          一起对照看才能完整理解 cluster-internal 设计选择.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/servers/host-cpu-matrix/')} class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;">Host CPU 对照矩阵 →</a>
          <a href={pathname('/servers/network-topology-matrix/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">网络拓扑对照矩阵 →</a>
          <a href={pathname('/servers/compare/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">超节点完整对比 →</a>
          <a href={pathname('/patterns/hot-cold-kv-tiering/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">Hot-cold KV 分层 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
