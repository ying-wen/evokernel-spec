---
/**
 * Quantization decision tree — interactive guide for picking the right quant
 * strategy given (model size × hardware × quality target × use case).
 *
 * Pulls live data from data/patterns + data/quantizations + data/cases so the
 * recommendations stay in sync with the catalog rather than going stale in
 * markdown. Each leaf links to the relevant pattern detail and example cases.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import { getQuantizations, getPatterns, getCases } from '~/lib/data';

const [quantizations, patterns, cases] = await Promise.all([
  getQuantizations(), getPatterns(), getCases()
]);

interface DecisionLeaf {
  precision: string;
  pattern_id?: string;
  why: string;
  caveats?: string[];
  example_cases?: string[];
}

interface DecisionBranch {
  question_zh: string;
  question_en: string;
  branches: Array<{ condition: string; leaf: DecisionLeaf }>;
}

// Decision tree data — domain knowledge encoded as concrete branches. Each
// branch ties to existing patterns (data/patterns/*.yaml) so updates to
// individual pattern docs auto-flow through.
const DECISION_TREE: DecisionBranch[] = [
  {
    question_zh: '硬件代际是什么?',
    question_en: 'What hardware generation?',
    branches: [
      {
        condition: 'Blackwell / Rubin (B100/B200/GB200/R100)',
        leaf: {
          precision: 'FP4 (W4-only) → 衰减后用 FP8',
          pattern_id: 'fp4-weight-only-quant',
          why: 'Blackwell 有 native FP4 tensor core, decode 1.8-2.5x BF16 加速; HBM 占用降 4x. 仅权重 FP4 (W4A16) 质量损失 < 0.8 pt MMLU.',
          caveats: ['<13B 模型 FP4 量化损失偏大 (1-3 pt)', 'Hopper 走 emulation, 收益跌一半'],
          example_cases: ['case-llama4mvk-gb200-nvl72-001']
        }
      },
      {
        condition: 'Hopper (H100/H200) / Ada (L40s)',
        leaf: {
          precision: 'FP8 (W8A8 E4M3)',
          why: 'Hopper Transformer Engine 原生 FP8, decode 1.5-2x BF16; quality 损失 < 0.3 pt. 现代生产部署默认.',
          caveats: ['FP8 calibration 首次启动 ~30 分钟', '部分老 kernel (xformers) 不支持'],
          example_cases: ['case-dsv4f-h100x8-vllm-fp8-001']
        }
      },
      {
        condition: 'Ampere (A100/A800) / 国产 910C/MLU590/BR104',
        leaf: {
          precision: 'INT8 (W8A8) 或 INT4 (W4A16-AWQ)',
          pattern_id: 'memory-bound-decode-prefer-int8',
          why: '没有 FP8 硬件支持时 INT8 是最佳替代; INT4-AWQ 在 70B+ 模型上质量损失 0.5-1 pt, 显存占用降 4x.',
          caveats: ['INT4 在 < 13B 模型上质量损失 1.5-3 pt', '需要 AWQ/GPTQ 校准 30 min']
        }
      },
      {
        condition: 'Edge / 端侧 (Jetson / Apple M / Phone)',
        leaf: {
          precision: 'INT4 (Q4_K_M) 或 INT8',
          why: 'llama.cpp Q4_K_M 是端侧默认 — 4-bit + per-group scale, 在 8GB+ RAM 设备上跑 7-13B 模型.',
          caveats: ['Q4_K_M 是 GGUF 格式, 不能跑在 CUDA-only 引擎', '< 7B 模型 Q4 质量明显跌'],
          example_cases: ['case-qwen25-7b-jetson-orin-001']
        }
      }
    ]
  },
  {
    question_zh: '模型大小是多少?',
    question_en: 'How large is the model?',
    branches: [
      {
        condition: '≥ 70B 大模型',
        leaf: {
          precision: 'FP8 / INT4 PTQ 即可',
          why: '70B+ 模型对量化 robust, PTQ-AWQ INT4 跌 < 1 pt. 不需要 QAT.',
          caveats: ['MoE 模型 expert 单独看, expert 量化更敏感']
        }
      },
      {
        condition: '13-70B 中等模型',
        leaf: {
          precision: 'FP8 优先, INT4 次选',
          pattern_id: 'memory-bound-decode-prefer-int8',
          why: '中等模型 FP8 几乎无损 (< 0.3 pt); INT4 跌 0.5-1.5 pt 可接受.',
        }
      },
      {
        condition: '< 13B 小模型 + 质量敏感',
        leaf: {
          precision: 'QAT (LoRA-QAT) → INT4',
          pattern_id: 'quant-aware-finetune',
          why: 'PTQ 在 7B 模型上跌 2-3 pt, QAT (LoRA, 4-12 GPU hour) 恢复到 < 0.5 pt — ROI 高.',
          caveats: ['需要任务相关训练数据 ≥ 100K token', '维护成本: 升级模型要重 QAT']
        }
      }
    ]
  },
  {
    question_zh: '工作负载是什么?',
    question_en: 'What workload?',
    branches: [
      {
        condition: '长会话 / chatbot (多轮共享前缀)',
        leaf: {
          precision: 'BF16/FP8 + KV-cache INT8',
          pattern_id: 'kv-cache-int8',
          why: '权重精度保高, KV cache 单独 INT8 — 长会话 KV 是主要 HBM 占用. 配合 prefix-radix-cache 收益叠加.',
        }
      },
      {
        condition: 'Agent / few-shot (静态 system prompt)',
        leaf: {
          precision: 'FP8 + GQA/MQA',
          pattern_id: 'gqa-mqa-shared-kv',
          why: '现代 Llama 3+/Qwen 3+ 已经 GQA, KV cache 8x 减少. FP8 权重 + GQA KV 叠加 = 长 context 友好.',
        }
      },
      {
        condition: '单轮高吞吐 (SaaS API)',
        leaf: {
          precision: 'FP8 / INT4',
          why: '单轮请求 KV cache 不是瓶颈, 权重精度直接决定吞吐. FP8 在 Hopper, INT4-AWQ 在 Ampere.',
        }
      },
      {
        condition: '低 latency (实时 voice / interactive)',
        leaf: {
          precision: 'FP8 + speculative decoding (MTP)',
          pattern_id: 'mtp-multi-token-prediction',
          why: '量化降 decode latency, MTP head 1 forward 出 2-3 token, 累积加速 3-5x. P50 latency 30-50% 降.',
        }
      }
    ]
  }
];

// Surface relevant cases per leaf
const casesById = new Map(cases.map((c) => [c.id, c]));
const patternsById = new Map(patterns.map((p) => [p.id, p]));
const quantsById = new Map(quantizations.map((q) => [q.id, q]));
---
<BaseLayout title="量化决策树 / Quantization Decision Tree">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        LEARN · QUANTIZATION DECISION TREE
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        量化决策树 · Quantization Decision Tree
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        量化是部署优化第一杠杆 — 选错精度 = 浪费一半显存 + 跌 2 pt 跑分. 这是按
        <strong>(硬件 × 模型大小 × 工作负载)</strong> 的三步决策, 每步链接到
        相关的 <a href={pathname('/patterns/')} style="color: var(--color-accent);" class="hover:underline">优化模式</a>
        和 <a href={pathname('/cases/')} style="color: var(--color-accent);" class="hover:underline">实测案例</a>.
      </p>
      <div class="mt-6 flex gap-6 text-sm flex-wrap">
        <div><span style="color: var(--color-text-muted);">支持的精度: </span><strong>{quantizations.length}</strong></div>
        <div><span style="color: var(--color-text-muted);">相关 pattern: </span><strong>{patterns.filter((p) => p.category === 'quantization' || p.category === 'kv-cache').length}</strong></div>
        <div><span style="color: var(--color-text-muted);">实测案例: </span><strong>{cases.length}</strong></div>
      </div>
    </section>

    {DECISION_TREE.map((branch, idx) => (
      <section class="py-8 border-t" style="border-color: var(--color-border);">
        <h2 class="text-2xl font-semibold mb-2 flex items-center gap-2">
          <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-surface-raised); color: var(--color-text-muted);">{idx + 1}/{DECISION_TREE.length}</span>
          {branch.question_zh} <span class="text-base font-normal" style="color: var(--color-text-muted);">/ {branch.question_en}</span>
        </h2>

        <div class="grid lg:grid-cols-2 gap-3 mt-6">
          {branch.branches.map((b) => {
            const pattern = b.leaf.pattern_id ? patternsById.get(b.leaf.pattern_id) : undefined;
            const examples = (b.leaf.example_cases ?? []).map((id) => casesById.get(id)).filter(Boolean);
            return (
              <div class="rounded-lg border p-5" style="border-color: var(--color-border); background: var(--color-surface-raised);">
                <div class="text-xs font-medium uppercase tracking-wider mb-2" style="color: var(--color-text-muted);">如果 / If</div>
                <div class="text-sm font-semibold mb-3" style="color: var(--color-text);">{b.condition}</div>

                <div class="text-xs font-medium uppercase tracking-wider mb-1" style="color: var(--color-accent);">→ 推荐</div>
                <div class="text-base font-semibold mb-2" style="color: var(--color-text);">{b.leaf.precision}</div>
                <p class="text-sm" style="color: var(--color-text-muted);">{b.leaf.why}</p>

                {b.leaf.caveats && b.leaf.caveats.length > 0 && (
                  <div class="mt-3">
                    <div class="text-xs font-medium uppercase tracking-wider mb-1" style="color: var(--color-text-muted);">⚠️ 注意</div>
                    <ul class="text-xs space-y-1" style="color: var(--color-text-muted);">
                      {b.leaf.caveats.map((c) => (<li>· {c}</li>))}
                    </ul>
                  </div>
                )}

                <div class="mt-4 flex gap-3 flex-wrap text-xs">
                  {pattern && (
                    <a href={pathname(`/patterns/${pattern.id}/`)} class="px-2 py-1 rounded hover:underline" style="background: var(--color-bg); color: var(--color-accent);">
                      🧩 {pattern.name}
                    </a>
                  )}
                  {examples.map((c) => (
                    <a href={pathname(`/cases/${c!.id}/`)} class="px-2 py-1 rounded hover:underline" style="background: var(--color-bg); color: var(--color-text);">
                      📦 {c!.title.length > 40 ? c!.title.slice(0, 38) + '…' : c!.title}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </section>
    ))}

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">还在犹豫?</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">
          打开<a href={pathname('/calculator/')} style="color: var(--color-accent);" class="hover:underline">计算器</a>对照具体 (model × hardware × precision) 组合的吞吐 / TCO 上界,
          或浏览<a href={pathname('/playbooks/')} style="color: var(--color-accent);" class="hover:underline">部署 Playbook</a> 看完整端到端配方.
        </p>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/calculator/')} class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;">打开计算器 →</a>
          <a href={pathname('/playbooks/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">浏览 Playbook →</a>
          <a href={pathname('/patterns/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">所有 19 个优化模式 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
