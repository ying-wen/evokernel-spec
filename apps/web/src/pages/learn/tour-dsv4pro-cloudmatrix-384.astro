---
/**
 * End-to-end tour: DeepSeek V4 Pro 671B-A37B MoE on Huawei CloudMatrix 384
 * with MindIE 1.0 BF16. The marquee Chinese-stack reasoning deployment —
 * shows what gap-3 looks like end-to-end on a non-NVIDIA platform.
 *
 * Walks all 7 pipeline stages — same template as the Llama 4 Scout tour,
 * but every decision differs because of (a) ascend-only hardware, (b) MoE
 * EP=6 routing, and (c) 信创 / 国央企 deployment context.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import {
  getResolvedCases, getPipelineStages, getPlaybooks,
  getOperators, getFusedKernels, getPatterns
} from '~/lib/data';

const [resolvedCases, pipelineStages, playbooks, operators, fusedKernels, patterns] = await Promise.all([
  getResolvedCases(), getPipelineStages(), getPlaybooks(), getOperators(),
  getFusedKernels(), getPatterns()
]);

const TOUR_CASE_ID = 'case-dsv4pro-cm384-mindie-001';
const tourCase = resolvedCases.find((c) => c.id === TOUR_CASE_ID) ?? resolvedCases[0];

const playbook = playbooks.find((p) => p.id === 'moe-llm-large-on-ascend-cluster');

interface StageNarrative {
  stage_id: string;
  decision: string;
  rationale: string;
  involves_operators?: string[];
  involves_kernels?: string[];
  involves_patterns?: string[];
  pitfall?: string;
}

const NARRATIVES: StageNarrative[] = [
  {
    stage_id: 'acquire',
    decision: 'deepseek-ai/DeepSeek-V4-Pro — HuggingFace safetensors',
    rationale: 'DeepSeek V4 Pro 671B-A37B MoE, BF16 weights ~1.34 TB total. CloudMatrix 384 集群拉权重走 OBS (华为云对象存储) 镜像源, 比 hf-mirror.com 快约 3x.',
    pitfall: 'License: DeepSeek 系商业 license 允许部署. CloudMatrix 384 集群部署需要先 ModelArts 注册 model card.'
  },
  {
    stage_id: 'convert',
    decision: 'safetensors → MindIE checkpoint (CANN 8.1 native format)',
    rationale: 'MindIE 不直接读 HF safetensors — 需要 mindie-convert 转成 MindIE 内部 .pt 格式 (~30 min, 单节点完成). vLLM-ascend fork 支持 safetensors 直读但 MindIE 路径吞吐高 ~25%.',
    pitfall: 'CANN 8.1 与 8.0 的 checkpoint 格式不兼容 — 升级 CANN 后必须重转, 否则 model load 报错.'
  },
  {
    stage_id: 'quantize',
    decision: 'BF16 (no quantization) — Atlas 800T A3 384 GB total HBM 装下 1.34 TB? No — but EP-shard 后单卡只装一部分',
    rationale: '671B BF16 + EP=6 让每卡只装 1/6 expert + shared backbone ≈ 102 GB / 卡 (memory_per_card_gb=102 from case). 910C 单卡 64 GB HBM, 不够 — 实际靠 EP=6 + TP=16 分布. 目前不上 INT8 因为: (1) 910D FP8 路径成熟前 INT8 calibration MindIE 1.0 仍 experimental; (2) reasoning 场景对量化敏感.',
    involves_patterns: ['memory-bound-decode-prefer-int8'],
    pitfall: 'BF16 + 384 卡导致 HBM 占用 71% 高位. INT8 在 910D / MindIE 2.0+ 上线后, 此 deployment 升级路径明确.'
  },
  {
    stage_id: 'compile',
    decision: 'CANN 8.1 graph compiler + AscendC kernels (FlashAttn-2 + fused MoE dispatch)',
    rationale: 'MindIE 1.0 走 CANN graph 离线 compile (类似 TRT-LLM trtllm-build), engine 缓存到 disk. 384 卡 cluster 用 NPU-aware schedule 让 FA2 + MoE dispatch 各自融合.',
    involves_operators: ['scaled-dot-product-attention', 'matmul', 'rmsnorm', 'silu', 'swiglu', 'moe-gate', 'all2all'],
    involves_kernels: ['flash-attention-v3', 'fused-mlp-silu', 'fused-rmsnorm-residual', 'fused-rope-qkv', 'fused-moe-dispatch-deepep'],
    involves_patterns: ['flashattention-v3', 'gqa-mqa-shared-kv', 'moe-expert-routing-on-domestic'],
    pitfall: '910C 没 TMA-equivalent, FlashAttn-3 path 走 emulation, 性能比 H100 Hopper 低 30-40% — bottleneck 在 attention 阶段.'
  },
  {
    stage_id: 'shard',
    decision: 'TP=16 (intra-cabinet) × PP=4 (cross-cabinet) × EP=6 — 16 × 4 × 6 = 384 卡',
    rationale: 'CloudMatrix 384 单 cabinet 16 卡 HCCS-v2 全互联. 跨 cabinet 走 lingqu 灵衢 optical fabric. TP=16 利用单 cabinet bandwidth; PP=4 跨 4 cabinet 容忍较低 lingqu latency; EP=6 让 16 expert MoE 沿设备分布.',
    involves_patterns: ['tp-allreduce-overlap', 'moe-expert-routing-on-domestic'],
    pitfall: 'EP=6 expert 路由首跑负载不均 (case 实测 issue) — 用 router warmup batch 在前 3000 step 内做均衡. 不 warmup 导致冷启动 P99 latency 比 P50 高 4-6x.'
  },
  {
    stage_id: 'serve',
    decision: 'MindIE 1.0 + continuous batching + paged-attention (Ascend 实现)',
    rationale: 'MindIE 是昇腾唯一 production-grade 推理栈; CANN 9.0 之前没 disagg 支持. Continuous batching 在 384 卡 + max_concurrent_requests=256 上线性扩展.',
    involves_kernels: ['paged-attention-decode'],
    involves_patterns: ['continuous-batching', 'paged-attention'],
    pitfall: '信创合规: MindIE + CANN 是已认证栈; vllm-ascend fork 在 信创 招标中 不被接受. 国央企 部署必走 MindIE.'
  },
  {
    stage_id: 'observe',
    decision: 'MindStudio metrics + npu-smi + 华为云监控',
    rationale: 'Ascend 没有 nvidia-smi 等价物 — 用 npu-smi (华为提供). MindStudio 集成 MindIE 内部 trace, 看 per-step latency / KV cache 占用率.',
    pitfall: 'Lingqu 跨柜延迟比单柜 HCCS 高约 18% (case 实测 issue) — 监控时要分柜内 / 跨柜 latency, 否则跨柜 P99 抖动会被柜内数据稀释.'
  }
];

const operatorsById = new Map(operators.map((o) => [o.id, o]));
const kernelsById = new Map(fusedKernels.map((k) => [k.id, k]));
const patternsById = new Map(patterns.map((p) => [p.id, p]));

const orderedStages = [...pipelineStages].sort((a, b) => a.order - b.order);
---
<BaseLayout title="Tour: DeepSeek V4 Pro × CloudMatrix 384 / 国央企 reasoning">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        LEARN · TOUR · 国央企 REASONING
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        Tour: DeepSeek V4 Pro × CloudMatrix 384
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        端到端部署 tour 第二例 — 国央企 reasoning 场景, 全 Ascend / MindIE / 信创认证栈.
        与 <a href={pathname('/learn/end-to-end-tour/')} style="color: var(--color-accent);" class="hover:underline">Llama 4 Scout × H200 tour</a> 是不同 deployment 的对照:
        硬件、引擎、量化、信创合规要求都不同, 但 7 阶段框架是一致的.
      </p>

      <div class="mt-6 rounded-lg border p-4" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, transparent);">
        <div class="text-xs font-medium uppercase tracking-wider mb-2" style="color: var(--color-accent);">本次 Tour 选的例子</div>
        {tourCase ? (
          <>
            <h2 class="text-lg font-semibold mb-1">
              <a href={pathname(`/cases/${tourCase.id}/`)} class="hover:underline" style="color: var(--color-text);">{tourCase.title}</a>
            </h2>
            <p class="text-sm" style="color: var(--color-text-muted);">
              Model: <strong>{tourCase.resolved.model.name}</strong> · Hardware: <strong>{tourCase.resolved.hardware.name} ×{tourCase.stack.hardware.count}</strong> ·
              Engine: <strong>{tourCase.resolved.engine.name} {tourCase.stack.engine.version}</strong> · Quant: <strong>{tourCase.stack.quantization}</strong> ·
              Parallel: TP={tourCase.stack.parallel.tp}, PP={tourCase.stack.parallel.pp}, EP={tourCase.stack.parallel.ep}
            </p>
            {playbook && (
              <p class="text-xs mt-2" style="color: var(--color-text-muted);">
                匹配 playbook: <a href={pathname(`/playbooks/${playbook.id}/`)} class="hover:underline" style="color: var(--color-accent);">→ {playbook.id}</a>
              </p>
            )}
          </>
        ) : null}
      </div>
    </section>

    <section class="py-6 border-t" style="border-color: var(--color-border);" aria-labelledby="tour-stages-heading">
      <h2 id="tour-stages-heading" class="text-2xl font-semibold mb-4">7 阶段部署链路</h2>
      <div class="space-y-4">
        {orderedStages.map((stage) => {
          const narrative = NARRATIVES.find((n) => n.stage_id === stage.id);
          if (!narrative) return null;
          return (
            <div class="rounded-lg border p-5" style="border-color: var(--color-border); background: var(--color-surface-raised);" data-testid={`tour-stage-${stage.id}`}>
              <div class="flex items-baseline gap-2 mb-3">
                <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-text-muted);">{stage.order}/7</span>
                <h3 class="text-lg font-semibold">
                  <a href={pathname(`/pipeline/${stage.id}/`)} class="hover:underline" style="color: var(--color-text);">{stage.name_zh}</a>
                  <span class="text-sm font-normal ml-2" style="color: var(--color-text-muted);">/ {stage.name_en}</span>
                </h3>
              </div>

              <div class="text-xs font-medium uppercase tracking-wider mb-1" style="color: var(--color-accent);">本次 tour 的决定</div>
              <div class="text-sm font-mono mb-2 px-3 py-1.5 rounded inline-block" style="background: var(--color-bg); color: var(--color-text);">{narrative.decision}</div>
              <p class="text-sm mb-3" style="color: var(--color-text-muted);">{narrative.rationale}</p>

              {(narrative.involves_operators || narrative.involves_kernels || narrative.involves_patterns) && (
                <div class="grid sm:grid-cols-3 gap-3 text-xs mb-3">
                  {narrative.involves_operators && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及算子 ({narrative.involves_operators.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_operators.map((id) => {
                          const op = operatorsById.get(id);
                          return op ? (
                            <li><a href={pathname(`/operators/${id}/`)} class="hover:underline" style="color: var(--color-text);">⚙ {op.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                  {narrative.involves_kernels && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及 kernel ({narrative.involves_kernels.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_kernels.map((id) => {
                          const k = kernelsById.get(id);
                          return k ? (
                            <li><a href={pathname(`/fused-kernels/${id}/`)} class="hover:underline" style="color: var(--color-accent);">🧩 {k.name.length > 28 ? k.name.slice(0, 26) + '…' : k.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                  {narrative.involves_patterns && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及 pattern ({narrative.involves_patterns.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_patterns.map((id) => {
                          const p = patternsById.get(id);
                          return p ? (
                            <li><a href={pathname(`/patterns/${id}/`)} class="hover:underline" style="color: var(--color-text);">⭐ {p.name.length > 28 ? p.name.slice(0, 26) + '…' : p.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                </div>
              )}

              {narrative.pitfall && (
                <div class="rounded p-2.5 text-xs" style="background: color-mix(in oklch, oklch(70% 0.18 50) 8%, transparent); border-left: 3px solid oklch(70% 0.18 50);">
                  <span class="font-semibold" style="color: oklch(60% 0.18 50);">⚠️ Pitfall:</span>
                  <span class="ml-1" style="color: var(--color-text-muted);">{narrative.pitfall}</span>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">看其他 Tour</h3>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/learn/tours/')} class="text-sm px-4 py-2 rounded-md font-medium" style="background: var(--color-accent); color: white;">全部 Tour 索引 →</a>
          <a href={pathname('/learn/end-to-end-tour/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">Tour: Llama 4 Scout × H200 →</a>
          <a href={pathname('/learn/tour-llama4-maverick-nvl72/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">Tour: Llama 4 Maverick × NVL72 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
