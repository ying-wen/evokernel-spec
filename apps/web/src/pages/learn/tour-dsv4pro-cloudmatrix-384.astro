---
/**
 * Legacy URL — redirects to /learn/tours/dsv4pro-cloudmatrix-384-mindie/.
 * Hand-coded in v1.23, moved to data-driven in v1.24.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';

const target = pathname('/learn/tours/dsv4pro-cloudmatrix-384-mindie/');
---
<BaseLayout title="Tour: DeepSeek V4 Pro × CloudMatrix 384 (redirecting…)" noIndex>
  <Fragment slot="head">
    <meta http-equiv="refresh" set:html={`0; url=${target}`} />
    <link rel="canonical" href={target} />
  </Fragment>
  <main class="p-12 text-center">
    <p class="text-lg" style="color: var(--color-text);">Tour 已迁移到新地址.</p>
    <p class="text-sm mt-2" style="color: var(--color-text-muted);">
      正在跳转到 <a href={target} style="color: var(--color-accent);" class="hover:underline">{target}</a>…
    </p>
  </main>
</BaseLayout>
