---
/**
 * Legacy URL — redirects to /learn/tours/llama4-scout-h200-vllm-fp8/.
 *
 * This page existed as a hand-coded tour in v1.22-v1.23 before tours moved to
 * data-driven (v1.24). Kept as a meta-refresh redirect to preserve external
 * links from blog posts, social media, and citations.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import { pathname } from '~/lib/i18n';

const target = pathname('/learn/tours/llama4-scout-h200-vllm-fp8/');
---
<BaseLayout title="Tour: Llama 4 Scout × H200 (redirecting…)" noIndex>
  <Fragment slot="head">
    <meta http-equiv="refresh" set:html={`0; url=${target}`} />
    <link rel="canonical" href={target} />
  </Fragment>
  <main class="p-12 text-center">
    <p class="text-lg" style="color: var(--color-text);">Tour 已迁移到新地址.</p>
    <p class="text-sm mt-2" style="color: var(--color-text-muted);">
      正在跳转到 <a href={target} style="color: var(--color-accent);" class="hover:underline">{target}</a>…
    </p>
  </main>
</BaseLayout>
