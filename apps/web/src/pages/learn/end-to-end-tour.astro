---
/**
 * /learn/end-to-end-tour/ — single concrete deployment walked through every
 * stage. Where the rest of /learn/* shows abstract decision matrices, this
 * page traces ONE example top-to-bottom: Llama 4 Scout 109B-A17B MoE on
 * 8× H200 with vLLM FP8.
 *
 * Each stage shows the actual decision made + which existing spec entries
 * (operators / kernels / patterns / playbook) were involved. Closes the
 * gap-3 ask: "deployment optimization chain unclear" was partly because the
 * data was correct but spread across 5 separate sections.
 */
import BaseLayout from '~/layouts/BaseLayout.astro';
import Container from '~/components/ui/Container.astro';
import { pathname } from '~/lib/i18n';
import {
  getCases, getResolvedCases, getPipelineStages, getPlaybooks,
  getOperators, getFusedKernels, getPatterns
} from '~/lib/data';

const [resolvedCases, pipelineStages, playbooks, operators, fusedKernels, patterns] = await Promise.all([
  getResolvedCases(), getPipelineStages(), getPlaybooks(), getOperators(),
  getFusedKernels(), getPatterns()
]);

// Pick the tour case — Llama 4 Scout on H200x8 with vLLM FP8.
const TOUR_CASE_ID = 'case-llama4-scout-h100x8-vllm-001';
const tourCase = resolvedCases.find((c) => c.id === TOUR_CASE_ID) ?? resolvedCases[0];

const playbookId = 'moe-llm-medium-on-hopper-single-node';
const playbook = playbooks.find((p) => p.id === playbookId);

// Resolve which patterns + kernels + ops the case touches per stage.
// (We hand-curate the per-stage mapping since cases don't tag stages directly.)
interface StageNarrative {
  stage_id: string;
  decision: string;
  rationale: string;
  involves_operators?: string[];
  involves_kernels?: string[];
  involves_patterns?: string[];
  pitfall?: string;
}

const NARRATIVES: StageNarrative[] = [
  {
    stage_id: 'acquire',
    decision: 'meta-llama/Llama-4-Scout — HuggingFace safetensors',
    rationale: 'Llama 4 Scout 109B-A17B MoE 是 Meta 官方 release. 用 HF Hub 自动 download 而非自部署 weight server (~ 220GB BF16 weights).',
    pitfall: 'License gating: 部署前确认 Llama 4 license 允许商业使用; 国内拉取走 hf-mirror.com 镜像加速.'
  },
  {
    stage_id: 'convert',
    decision: 'BF16 safetensors as-is (HF format)',
    rationale: '现代 vLLM/SGLang 直接读 safetensors, 无需手动转 GGUF/onnx/engine. Format 路径见 /learn/picking-quantization-format/.',
    pitfall: '老脚本可能需要 transformers 4.45+ 才认识 Llama 4 architecture.'
  },
  {
    stage_id: 'quantize',
    decision: 'FP8 W8A8 (E4M3) — Hopper native path',
    rationale: 'H200 有 native FP8 tensor core, decode 1.5-2x BF16. Llama 4 Scout 109B 体量适合 FP8 (跌 < 0.3 pt). FP4 收益要等 Blackwell, 这代不上.',
    involves_patterns: ['memory-bound-decode-prefer-int8'],
    pitfall: 'FP8 calibration ~30 分钟, 首次启动有冷等待. 校准 set 选 chat-style + multi-language 数据避免单领域偏置.'
  },
  {
    stage_id: 'compile',
    decision: 'CUDA Graph capture + FlashAttention-3 + GQA fast path',
    rationale: 'vLLM 0.6+ 默认 CUDA Graph 捕获多个 batch size; H200 上 FlashAttn-3 + GQA-8 是默认 attention path.',
    involves_operators: ['scaled-dot-product-attention', 'matmul', 'rmsnorm', 'rope', 'silu', 'swiglu'],
    involves_kernels: ['flash-attention-v3', 'fused-mlp-silu', 'fused-rmsnorm-residual', 'fused-rope-qkv'],
    involves_patterns: ['flashattention-v3', 'gqa-mqa-shared-kv'],
    pitfall: 'CUDA Graph capture 不喜欢 dynamic shape — 需要预 capture 几个常用 batch size 备用; 否则运行时变 shape 触发 recapture.'
  },
  {
    stage_id: 'shard',
    decision: 'TP=8 + EP=8, no PP, no Ring (single-node fits 109B BF16)',
    rationale: 'H200 8-OAM (1.13 TB total HBM) 装下 109B FP8 (~110 GB) + 16 expert MoE EP. 不需要跨节点. EP=8 让 16 experts 沿 GPU 分布.',
    involves_patterns: ['tp-allreduce-overlap', 'moe-expert-routing-on-domestic'],
    pitfall: 'EP all2all 跨 NVSwitch Gen-3, 单节点 NVLink-4 内 latency 5-10us; 跨节点跌 5x.'
  },
  {
    stage_id: 'serve',
    decision: 'vLLM 0.7 continuous batching + PagedAttention + prefix-radix cache',
    rationale: 'vLLM 是 multi-model 兼容性最好的栈; continuous batching 让 decode 吞吐随 batch 线性升; PagedAttention KV cache 降碎片化 ~15%.',
    involves_kernels: ['paged-attention-decode', 'fused-radix-attention'],
    involves_patterns: ['continuous-batching', 'paged-attention', 'prefix-radix-cache'],
    pitfall: '生产部署不要忘加 --enable-prefix-caching; 多轮 chat 场景 TTFT 直接降 5-10x.'
  },
  {
    stage_id: 'observe',
    decision: 'vLLM Prometheus metrics + nvidia-smi + Grafana dashboard',
    rationale: 'vLLM 暴露 /metrics 给 Prometheus. 监控关键指标: gpu_utilization, time_to_first_token, time_per_output_token, kv_cache_usage. P99 latency 异常优先看 KV cache 占用率.',
    pitfall: '只看平均 latency 会错过 P99 抖动 — 长 prompt + cache miss 路径会让 P99 比 P50 高 3-5x.'
  }
];

// Helper resolvers
const operatorsById = new Map(operators.map((o) => [o.id, o]));
const kernelsById = new Map(fusedKernels.map((k) => [k.id, k]));
const patternsById = new Map(patterns.map((p) => [p.id, p]));
const stagesById = new Map(pipelineStages.map((s) => [s.id, s]));

const orderedStages = [...pipelineStages].sort((a, b) => a.order - b.order);
---
<BaseLayout title="端到端部署 Tour / End-to-End Deployment Tour">
  <Container width="wide">
    <section class="pt-12 pb-8">
      <div class="text-xs uppercase tracking-widest font-medium mb-3" style="color: var(--color-accent);">
        LEARN · END-TO-END TOUR
      </div>
      <h1 style="font-size: clamp(2rem, 1.4rem + 4vw, 3.5rem); line-height: 1.05; font-weight: 600; letter-spacing: -0.02em;">
        端到端部署 Tour · E2E Walkthrough
      </h1>
      <p class="text-lg mt-6 max-w-3xl" style="color: var(--color-text-muted);">
        把整个部署链路 — 从拉权重到生产监控 — 用 <strong>1 个具体例子</strong>串起来.
        <a href={pathname('/learn/quantization-decision-tree/')} style="color: var(--color-accent);" class="hover:underline">/learn/* 决策树</a> 给的是抽象矩阵,
        本页给的是 "走过一次完整的 7 阶段是什么样" — 每个 stage 的具体决定 + 涉及的 op / kernel / pattern.
      </p>
      <div class="mt-6 rounded-lg border p-4" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, transparent);">
        <div class="text-xs font-medium uppercase tracking-wider mb-2" style="color: var(--color-accent);">本次 Tour 选的例子</div>
        {tourCase ? (
          <>
            <h2 class="text-lg font-semibold mb-1">
              <a href={pathname(`/cases/${tourCase.id}/`)} class="hover:underline" style="color: var(--color-text);">{tourCase.title}</a>
            </h2>
            <p class="text-sm" style="color: var(--color-text-muted);">
              Model: <strong>{tourCase.resolved.model.name}</strong> · Hardware: <strong>{tourCase.resolved.hardware.name} ×{tourCase.stack.hardware.count}</strong> ·
              Engine: <strong>{tourCase.resolved.engine.name} {tourCase.stack.engine.version}</strong> · Quant: <strong>{tourCase.stack.quantization}</strong> ·
              Parallel: TP={tourCase.stack.parallel.tp}, EP={tourCase.stack.parallel.ep}, PP={tourCase.stack.parallel.pp}
            </p>
            {playbook && (
              <p class="text-xs mt-2" style="color: var(--color-text-muted);">
                匹配 playbook: <a href={pathname(`/playbooks/${playbook.id}/`)} class="hover:underline" style="color: var(--color-accent);">→ {playbook.id}</a>
              </p>
            )}
          </>
        ) : (
          <p class="text-sm" style="color: var(--color-text-muted);">案例未找到, fallback 走默认例子.</p>
        )}
      </div>
    </section>

    <section class="py-6 border-t" style="border-color: var(--color-border);" aria-labelledby="tour-stages-heading">
      <h2 id="tour-stages-heading" class="text-2xl font-semibold mb-4">7 阶段部署链路</h2>
      <div class="space-y-4">
        {orderedStages.map((stage) => {
          const narrative = NARRATIVES.find((n) => n.stage_id === stage.id);
          if (!narrative) return null;
          return (
            <div class="rounded-lg border p-5" style="border-color: var(--color-border); background: var(--color-surface-raised);" data-testid={`tour-stage-${stage.id}`}>
              <div class="flex items-baseline gap-2 mb-3">
                <span class="text-sm font-mono px-2 py-0.5 rounded" style="background: var(--color-bg); color: var(--color-text-muted);">{stage.order}/7</span>
                <h3 class="text-lg font-semibold">
                  <a href={pathname(`/pipeline/${stage.id}/`)} class="hover:underline" style="color: var(--color-text);">{stage.name_zh}</a>
                  <span class="text-sm font-normal ml-2" style="color: var(--color-text-muted);">/ {stage.name_en}</span>
                </h3>
              </div>

              <div class="text-xs font-medium uppercase tracking-wider mb-1" style="color: var(--color-accent);">本次 tour 的决定</div>
              <div class="text-sm font-mono mb-2 px-3 py-1.5 rounded inline-block" style="background: var(--color-bg); color: var(--color-text);">{narrative.decision}</div>
              <p class="text-sm mb-3" style="color: var(--color-text-muted);">{narrative.rationale}</p>

              {(narrative.involves_operators || narrative.involves_kernels || narrative.involves_patterns) && (
                <div class="grid sm:grid-cols-3 gap-3 text-xs mb-3">
                  {narrative.involves_operators && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及算子 ({narrative.involves_operators.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_operators.map((id) => {
                          const op = operatorsById.get(id);
                          return op ? (
                            <li><a href={pathname(`/operators/${id}/`)} class="hover:underline" style="color: var(--color-text);">⚙ {op.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                  {narrative.involves_kernels && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及 kernel ({narrative.involves_kernels.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_kernels.map((id) => {
                          const k = kernelsById.get(id);
                          return k ? (
                            <li><a href={pathname(`/fused-kernels/${id}/`)} class="hover:underline" style="color: var(--color-accent);">🧩 {k.name.length > 28 ? k.name.slice(0, 26) + '…' : k.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                  {narrative.involves_patterns && (
                    <div>
                      <div class="font-semibold mb-1" style="color: var(--color-text-muted);">涉及 pattern ({narrative.involves_patterns.length})</div>
                      <ul class="space-y-1">
                        {narrative.involves_patterns.map((id) => {
                          const p = patternsById.get(id);
                          return p ? (
                            <li><a href={pathname(`/patterns/${id}/`)} class="hover:underline" style="color: var(--color-text);">⭐ {p.name.length > 28 ? p.name.slice(0, 26) + '…' : p.name}</a></li>
                          ) : null;
                        })}
                      </ul>
                    </div>
                  )}
                </div>
              )}

              {narrative.pitfall && (
                <div class="rounded p-2.5 text-xs" style="background: color-mix(in oklch, oklch(70% 0.18 50) 8%, transparent); border-left: 3px solid oklch(70% 0.18 50);">
                  <span class="font-semibold" style="color: oklch(60% 0.18 50);">⚠️ Pitfall:</span>
                  <span class="ml-1" style="color: var(--color-text-muted);">{narrative.pitfall}</span>
                </div>
              )}
            </div>
          );
        })}
      </div>
    </section>

    <section class="py-8 border-t" style="border-color: var(--color-border);">
      <h2 class="text-2xl font-semibold mb-4">想看其他例子的 tour?</h2>
      <p class="text-sm mb-4" style="color: var(--color-text-muted);">
        本页是单一例子的 narrative. 想看其他 (model × hardware) 组合的端到端配方, 浏览 {playbooks.length} 个
        <a href={pathname('/playbooks/')} style="color: var(--color-accent);" class="hover:underline">部署 playbook</a>
        和 {resolvedCases.length} 个 <a href={pathname('/cases/')} style="color: var(--color-accent);" class="hover:underline">实测案例</a>.
        遇到部署问题先查 <a href={pathname('/learn/deployment-failures/')} style="color: var(--color-accent);" class="hover:underline">踩坑记录</a>.
      </p>
    </section>

    <section class="py-12 border-t" style="border-color: var(--color-border);">
      <div class="rounded-lg p-6 border" style="border-color: var(--color-accent); background: color-mix(in oklch, var(--color-accent) 5%, var(--color-bg));">
        <h3 class="text-lg font-semibold mb-2">/learn/ 全部 6 个指南</h3>
        <p class="text-sm mb-4" style="color: var(--color-text-muted);">本页串起整个部署链路; 单步深入看下面专题.</p>
        <div class="flex gap-3 flex-wrap">
          <a href={pathname('/learn/attention-variants/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">Attention 变体 →</a>
          <a href={pathname('/learn/quantization-decision-tree/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">量化策略 →</a>
          <a href={pathname('/learn/picking-quantization-format/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">量化格式 →</a>
          <a href={pathname('/learn/parallelism-cheatsheet/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">并行策略 →</a>
          <a href={pathname('/learn/picking-engine/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">引擎选型 →</a>
          <a href={pathname('/learn/deployment-failures/')} class="text-sm px-4 py-2 rounded-md font-medium border" style="border-color: var(--color-border); color: var(--color-text);">踩坑记录 →</a>
        </div>
      </div>
    </section>
  </Container>
</BaseLayout>
