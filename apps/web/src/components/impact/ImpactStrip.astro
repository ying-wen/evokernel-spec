---
/**
 * Compact impact heartbeat for the homepage. Server-rendered with everything
 * known at build (case count, contributor count, last commit date) plus a
 * client island for the live GitHub star count.
 *
 * Goal: a first-time visitor sees within 1 second that this site is active,
 * has external recognition, and is being used.
 */
import GitHubStarButton from '~/components/impact/GitHubStarButton.tsx';
import '~/components/impact/GitHubStarButton.css';
import { contributorStats } from '~/lib/build-meta';
import { pathname } from '~/lib/i18n';

interface Props {
  caseCount: number;
  hardwareCount: number;
  playbookCount: number;
}

const { caseCount, hardwareCount, playbookCount } = Astro.props as Props;
const stats = contributorStats();

function daysSince(iso: string | null): string {
  if (!iso) return '?';
  const then = new Date(iso).getTime();
  const days = Math.max(0, Math.floor((Date.now() - then) / (1000 * 60 * 60 * 24)));
  if (days === 0) return '今天';
  if (days === 1) return '昨天';
  if (days < 30) return `${days} 天前`;
  if (days < 365) return `${Math.floor(days / 30)} 个月前`;
  return `${Math.floor(days / 365)} 年前`;
}

const lastCommitLabel = daysSince(stats.lastCommitDate);
---
<section
  class="impact-strip flex flex-wrap items-center gap-x-6 gap-y-2 py-3 px-4 border-y text-sm"
  style="border-color: var(--color-border); background: color-mix(in oklch, var(--color-accent) 4%, var(--color-bg));"
  aria-label="Project impact heartbeat"
>
  <a href="https://github.com/ying-wen/evokernel-spec" target="_blank" rel="noopener noreferrer" class="impact-strip-item">
    <GitHubStarButton client:only="react" />
  </a>

  <span class="impact-strip-divider hidden md:inline" style="color: var(--color-text-muted);">·</span>

  <span class="impact-strip-item" data-testid="impact-strip-contributors">
    <span class="impact-strip-icon" aria-hidden="true">👥</span>
    <strong class="tabular-nums">{stats.contributorCount}</strong>
    <span style="color: var(--color-text-muted);">contributors</span>
  </span>

  <span class="impact-strip-divider hidden md:inline" style="color: var(--color-text-muted);">·</span>

  <span class="impact-strip-item" data-testid="impact-strip-cases">
    <span class="impact-strip-icon" aria-hidden="true">📦</span>
    <strong class="tabular-nums">{caseCount}</strong>
    <span style="color: var(--color-text-muted);">cases</span>
  </span>

  <span class="impact-strip-divider hidden lg:inline" style="color: var(--color-text-muted);">·</span>

  <span class="impact-strip-item hidden lg:inline-flex">
    <span class="impact-strip-icon" aria-hidden="true">🧩</span>
    <strong class="tabular-nums">{hardwareCount}</strong>
    <span style="color: var(--color-text-muted);">cards · {playbookCount} playbooks</span>
  </span>

  <span class="impact-strip-divider hidden lg:inline" style="color: var(--color-text-muted);">·</span>

  <span class="impact-strip-item" data-testid="impact-strip-last-commit">
    <span class="impact-strip-icon" aria-hidden="true">🚀</span>
    <span style="color: var(--color-text-muted);">最近更新</span>
    <strong>{lastCommitLabel}</strong>
  </span>

  <a href={pathname('/impact/')} class="ml-auto text-xs px-3 py-1 rounded font-medium impact-strip-cta" data-testid="impact-strip-cta">
    详细影响指标 ↗
  </a>
</section>

<style>
.impact-strip-item {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  white-space: nowrap;
  text-decoration: none;
  color: var(--color-text);
}
.impact-strip-icon {
  font-size: 0.875rem;
  line-height: 1;
}
.impact-strip-cta {
  background: var(--color-accent);
  color: white !important;
  text-decoration: none;
  white-space: nowrap;
  transition: transform var(--duration-fast) var(--ease-out-expo);
}
.impact-strip-cta:hover {
  transform: translateY(-1px);
}
</style>
