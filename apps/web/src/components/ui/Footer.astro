---
import { t, localePath, type Locale } from '~/lib/i18n';
import { buildMeta } from '~/lib/build-meta';

interface Props { locale?: Locale }
const { locale = 'zh' } = Astro.props as Props;
const isEn = locale === 'en';
const meta = buildMeta();
const builtLabel = isEn ? 'Built' : '构建于';
---
<footer class="border-t mt-16" style="border-color: var(--color-border); background: var(--color-surface);">
  <div class="max-w-7xl mx-auto py-12 px-6 text-sm" style="color: var(--color-text-muted);">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="font-semibold mb-2" style="color: var(--color-text);">EvoKernel·Spec</div>
        <p class="text-xs">{t(locale, 'footer.tagline')}</p>
      </div>
      <div>
        <div class="font-semibold mb-2" style="color: var(--color-text);">{t(locale, 'footer.browse')}</div>
        <ul class="space-y-1 text-xs">
          <li><a href={localePath(locale, '/hardware')}>{t(locale, 'nav.hardware')}</a></li>
          <li><a href={localePath(locale, '/models')}>{t(locale, 'nav.models')}</a></li>
          <li><a href={localePath(locale, '/cases')}>{t(locale, 'nav.cases')}</a></li>
          <li><a href={localePath(locale, '/china')} style="color: var(--color-china);">{t(locale, 'nav.china')}</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold mb-2" style="color: var(--color-text);">{t(locale, 'footer.participate')}</div>
        <ul class="space-y-1 text-xs">
          <li><a href={localePath(locale, '/contribute')} style="color: var(--color-accent); font-weight: 600;">⚡ {t(locale, 'nav.contribute')} →</a></li>
          <li><a href={localePath(locale, '/pipeline')}>{isEn ? 'Deployment pipeline' : '部署链路'}</a></li>
          <li><a href={localePath(locale, '/patterns')}>{isEn ? 'Optimization patterns' : '优化模式'}</a></li>
          <li><a href={localePath(locale, '/about')}>{t(locale, 'footer.about')}</a></li>
          <li><a href={localePath(locale, '/learn')}>{t(locale, 'footer.learn')}</a></li>
          <li><a href={localePath(locale, '/showcase')}>{isEn ? 'Showcase' : '精选发现'}</a></li>
          <li><a href={localePath(locale, '/quality')}>{t(locale, 'footer.quality')}</a></li>
          <li><a href="https://github.com/ying-wen/evokernel-spec">GitHub</a></li>
          <li><a href={localePath(locale, '/calculator')}>{t(locale, 'footer.calculator')}</a></li>
        </ul>
      </div>
      <div>
        <div class="font-semibold mb-2" style="color: var(--color-text);">{t(locale, 'footer.license')}</div>
        <ul class="space-y-1 text-xs">
          <li>{isEn ? 'Code: Apache 2.0' : '代码 Apache 2.0'}</li>
          <li>{isEn ? 'Data: CC-BY-SA 4.0' : '数据 CC-BY-SA 4.0'}</li>
        </ul>
      </div>
    </div>
    <div class="text-xs pt-4 border-t flex flex-wrap justify-between items-center gap-3" style="border-color: var(--color-border);">
      <p class="flex-1 min-w-0">{t(locale, 'footer.disclaimer')}</p>
      <p class="font-mono text-xs whitespace-nowrap">
        {builtLabel} <time datetime={meta.builtAt}>{meta.builtAt.slice(0, 10)}</time>
        · <span data-build-sha>{meta.sha}</span>
      </p>
    </div>
  </div>
</footer>
