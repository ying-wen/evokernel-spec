---
import Search from './Search.tsx';
import ThemeToggle from './ThemeToggle.astro';
import { t, localePath, type Locale } from '~/lib/i18n';

interface Props { locale?: Locale }
const { locale = 'zh' } = Astro.props as Props;

const links = [
  { href: localePath(locale, '/hardware'), label: t(locale, 'nav.hardware') },
  { href: localePath(locale, '/compare'), label: t(locale, 'nav.compare') },
  { href: localePath(locale, '/models'), label: t(locale, 'nav.models') },
  { href: localePath(locale, '/cases'), label: t(locale, 'nav.cases') },
  { href: localePath(locale, '/calculator'), label: t(locale, 'nav.calculator') },
  { href: localePath(locale, '/pricing'), label: t(locale, 'nav.pricing') },
  { href: localePath(locale, '/china'), label: t(locale, 'nav.china'), accent: true }
];

// Build "switch locale" target: keep current path, swap locale prefix.
//
// Astro.url.pathname includes the deploy base (e.g. /evokernel-spec/hardware/),
// so we strip the base, swap the locale prefix on the bare path, then
// re-prepend the base. Otherwise zh → en on a project-page deploy produces
// "/en/evokernel-spec/..." (locale prefix landed in front of base).
const currentPath = Astro.url.pathname;
const otherLocale: Locale = locale === 'zh' ? 'en' : 'zh';
const NAV_BASE_RAW = import.meta.env.BASE_URL ?? '/';
const NAV_BASE = NAV_BASE_RAW === '/' ? '' : NAV_BASE_RAW.replace(/\/$/, '');
const stripNavBase = (p: string) => (NAV_BASE && p.startsWith(NAV_BASE) ? p.slice(NAV_BASE.length) || '/' : p);
const bare = stripNavBase(currentPath);
const localeSwitchHref = (() => {
  if (locale === 'zh') {
    // zh → en: prepend /en (then base)
    if (bare === '/') return NAV_BASE + '/en/';
    return NAV_BASE + '/en' + (bare.startsWith('/') ? bare : '/' + bare);
  }
  // en → zh: strip /en prefix (then base)
  if (bare === '/en' || bare === '/en/') return NAV_BASE + '/';
  return NAV_BASE + (bare.replace(/^\/en/, '') || '/');
})();
---
<header class="border-b sticky top-0 z-30" style="border-color: var(--color-border); background: color-mix(in oklch, var(--color-surface) 92%, transparent); backdrop-filter: blur(8px);">
  <nav class="flex items-center justify-between py-3 px-6 max-w-7xl mx-auto" aria-label="Main navigation">
    <a href={localePath(locale, '/')} class="font-semibold text-lg flex items-center gap-2" style="color: var(--color-text);">
      <span style="font-size: 1.25rem;">⚛</span>
      EvoKernel<span style="color: var(--color-accent);">·Spec</span>
    </a>

    <ul class="hidden md:flex gap-6 items-center">
      {links.map((l) => (
        <li>
          <a href={l.href} class="text-sm transition-opacity hover:opacity-80"
             style={`color: ${l.accent ? 'var(--color-china)' : 'var(--color-text-muted)'}; font-weight: ${l.accent ? '600' : '400'};`}>
            {l.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-2">
      <Search client:idle />
      <ThemeToggle />
      <a href={localeSwitchHref} class="text-xs px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);" aria-label="Switch language">
        {otherLocale === 'en' ? 'EN' : '中'}
      </a>
      <a href="https://github.com/evokernel/evokernel-spec" class="hidden sm:inline-flex text-xs px-2 py-1 rounded border" style="border-color: var(--color-border); color: var(--color-text-muted);">GitHub</a>
      <button id="menu-toggle" type="button" class="md:hidden px-2 py-1 rounded border text-sm" style="border-color: var(--color-border); color: var(--color-text);" aria-label={t(locale, 'nav.menu')} aria-expanded="false">
        ≡
      </button>
    </div>
  </nav>

  <ul id="mobile-menu" class="md:hidden hidden flex-col gap-2 px-6 pb-4 border-t" style="border-color: var(--color-border);">
    {links.map((l) => (
      <li>
        <a href={l.href} class="block py-2 text-sm"
           style={`color: ${l.accent ? 'var(--color-china)' : 'var(--color-text)'}; font-weight: ${l.accent ? '600' : '400'};`}>
          {l.label}
        </a>
      </li>
    ))}
    <li>
      <a href="https://github.com/evokernel/evokernel-spec" class="block py-2 text-sm" style="color: var(--color-text-muted);">GitHub ↗</a>
    </li>
  </ul>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', () => {
      const open = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      menu.classList.toggle('flex');
      btn.setAttribute('aria-expanded', String(!open));
    });
  });
</script>
