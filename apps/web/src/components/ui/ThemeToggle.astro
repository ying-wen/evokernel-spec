---
// Inline-rendered button — script handles toggle and persistence in localStorage.
---
<button id="theme-toggle" type="button"
        class="text-xs px-2 py-1 rounded border inline-flex items-center"
        style="border-color: var(--color-border); color: var(--color-text-muted); background: var(--color-surface);"
        aria-label="切换深色模式" title="切换深色模式 (Toggle dark mode)">
  <span data-theme-icon-light>☀️</span>
  <span data-theme-icon-dark style="display: none;">🌙</span>
</button>

<script is:inline>
  (() => {
    const KEY = 'evokernel-theme';
    function apply(theme) {
      document.documentElement.dataset.theme = theme;
      // Update color-scheme so form controls + scrollbars adapt
      document.documentElement.style.colorScheme = theme;
      const lightIcon = document.querySelector('[data-theme-icon-light]');
      const darkIcon = document.querySelector('[data-theme-icon-dark]');
      if (lightIcon && darkIcon) {
        lightIcon.style.display = theme === 'dark' ? 'none' : '';
        darkIcon.style.display = theme === 'dark' ? '' : 'none';
      }
    }
    const saved = localStorage.getItem(KEY) || 'light';
    apply(saved);
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('theme-toggle');
      if (!btn) return;
      btn.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        localStorage.setItem(KEY, next);
        apply(next);
      });
    });
  })();
</script>
