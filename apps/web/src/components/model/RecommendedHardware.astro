---
import type { Hardware, Model, Case } from '@evokernel/schemas';
import { pathname, type Locale } from '~/lib/i18n';
import {
  recommendHardwareForModel,
  topByThroughput,
  topByCost,
  verifiedByMeasuredCase,
  calculatorDeepLink,
  type RecommendationRow
} from '~/lib/recommendations';

interface Props {
  model: Model;
  hardware: Hardware[];
  cases: Case[];
  locale?: Locale;
}
const { model, hardware, cases, locale = 'zh' } = Astro.props as Props;
const en = locale === 'en';

// Compute recommendations across all hardware. Tier-1 calibrated upper bounds;
// Tier-0 measured values used for cost when available.
const rows = recommendHardwareForModel({ model, hardware, cases });
const topThroughput = topByThroughput(rows, 5);
const topCost = topByCost(rows, 5);
const verified = verifiedByMeasuredCase(rows).slice(0, 5);

const totalFeasible = rows.filter((r) => r.feasible).length;
const totalInfeasible = rows.length - totalFeasible;

function fmtNum(n: number): string {
  if (!Number.isFinite(n)) return '—';
  return Math.round(n).toLocaleString();
}
function fmtCost(n: number): string {
  if (!Number.isFinite(n)) return '—';
  return `$${n.toFixed(2)}`;
}

interface CardProps {
  title: string;
  badge: string;
  badgeColor: string;
  emptyMsg: string;
  rows: RecommendationRow[];
  primaryMetric: 'throughput' | 'cost' | 'measured';
}

const cards: CardProps[] = [
  {
    title: en ? 'Highest decode throughput' : '最高 decode 吞吐',
    badge: '🚀',
    badgeColor: 'var(--color-accent)',
    emptyMsg: en ? 'No card fits this model in 8-card scale-up.' : '8 卡 scale-up 域内无可容纳的硬件',
    rows: topThroughput,
    primaryMetric: 'throughput'
  },
  {
    title: en ? 'Lowest $/M tokens' : '最低 $/M tokens',
    badge: '💰',
    badgeColor: 'var(--color-tier-measured)',
    emptyMsg: en ? 'Need at least one feasible config to estimate cost.' : '至少需要一个可行配置才能估成本',
    rows: topCost,
    primaryMetric: 'cost'
  },
  {
    title: en ? 'Verified by measured cases' : '✅ 实测案例验证',
    badge: '✅',
    badgeColor: 'var(--color-tier-measured)',
    emptyMsg: en ? 'No measured deployment case for this model yet — be the first to contribute.' : '暂无该模型的实测案例 — 欢迎首位贡献者',
    rows: verified,
    primaryMetric: 'measured'
  }
];
---
<section class="pb-12" id="recommendations">
  <div class="mb-4">
    <h3 class="text-lg font-semibold mb-1">
      {en ? '推荐硬件 / Recommended hardware' : '推荐硬件 / Recommended hardware'}
    </h3>
    <p class="text-xs" style="color: var(--color-text-muted);">
      {en
        ? `Default scenario: 8 cards, TP=8, prefill=1024 / decode=256, batch=16. Each row links to /calculator with these knobs preset for further tuning. ${totalFeasible} of ${rows.length} hardware can fit this model; ${totalInfeasible} ruled out by memory.`
        : `默认场景: 8 卡, TP=8, prefill=1024 / decode=256, batch=16. 每行链接到 /calculator 携带配置, 可继续调参. ${rows.length} 张硬件中 ${totalFeasible} 张可容纳本模型, ${totalInfeasible} 张因显存不足排除.`}
    </p>
  </div>

  <div class="grid lg:grid-cols-3 gap-4">
    {cards.map((card) => (
      <article class="rounded-lg border" style={`border-color: color-mix(in oklch, ${card.badgeColor} 30%, var(--color-border)); background: var(--color-surface-raised);`}>
        <header class="px-4 py-3 border-b flex items-center justify-between gap-2" style={`border-color: var(--color-border); background: color-mix(in oklch, ${card.badgeColor} 6%, var(--color-bg));`}>
          <h4 class="text-sm font-semibold flex items-center gap-2" style={`color: ${card.badgeColor};`}>
            <span style="font-size: 1.1rem;">{card.badge}</span>
            {card.title}
          </h4>
          <span class="text-xs px-2 py-0.5 rounded font-mono" style={`background: var(--color-surface); color: ${card.badgeColor};`}>
            {card.rows.length}/{card.primaryMetric === 'measured' ? rows.length : 5}
          </span>
        </header>
        {card.rows.length === 0 ? (
          <div class="p-4 text-xs" style="color: var(--color-text-muted);">
            {card.emptyMsg}
          </div>
        ) : (
          <ol class="divide-y" style="border-color: var(--color-border);">
            {card.rows.map((row, i) => {
              const isCN = (row.hw.vendor as unknown as string).includes('huawei')
                || (row.hw.vendor as unknown as string).includes('cambricon')
                || (row.hw.vendor as unknown as string).includes('hygon')
                || (row.hw.vendor as unknown as string).includes('moore-threads')
                || (row.hw.vendor as unknown as string).includes('biren')
                || (row.hw.vendor as unknown as string).includes('metax')
                || (row.hw.vendor as unknown as string).includes('iluvatar')
                || (row.hw.vendor as unknown as string).includes('enflame')
                || (row.hw.vendor as unknown as string).includes('pingtouge');
              return (
                <li class="px-4 py-3 flex items-start justify-between gap-3" style="border-color: var(--color-border);">
                  <div class="min-w-0 flex-1">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-xs font-mono font-semibold" style="color: var(--color-text-muted);">#{i + 1}</span>
                      <a href={pathname(`/hardware/${row.hw.id}/`)} class="text-sm font-medium hover:underline" style="color: var(--color-text);">
                        {row.hw.name}
                      </a>
                      {isCN && <span class="text-xs" style="color: var(--color-china);" title="China-origin silicon">🇨🇳</span>}
                      {row.hasMeasuredCase && card.primaryMetric !== 'measured' && (
                        <span title={en ? 'Has at least one measured case' : '有实测 case'} style="color: var(--color-tier-measured);">✅</span>
                      )}
                    </div>
                    <div class="text-xs mt-1 flex items-center gap-2 flex-wrap" style="color: var(--color-text-muted);">
                      <span class="font-mono">{row.scenario.tp}× cards · {row.precision.toUpperCase()}</span>
                      {row.bottleneck === 'memory' && <span style="color: var(--color-china);">mem-bw bound</span>}
                      {row.bottleneck === 'compute' && <span style="color: var(--color-accent);">compute bound</span>}
                      {row.isCalibrated && <span title={en ? 'Calibrated against measured cases' : '已用实测案例校准'}>📐 calibrated</span>}
                    </div>
                  </div>
                  <div class="text-right">
                    {card.primaryMetric === 'throughput' && (
                      <>
                        <div class="font-mono text-base font-semibold" style="color: var(--color-text);">{fmtNum(row.decodeTokPerSecPerCard)}</div>
                        <div class="text-xs" style="color: var(--color-text-muted);">tok/s/card</div>
                      </>
                    )}
                    {card.primaryMetric === 'cost' && (
                      <>
                        <div class="font-mono text-base font-semibold" style="color: var(--color-tier-measured);">{fmtCost(row.costPerMTokens)}</div>
                        <div class="text-xs" style="color: var(--color-text-muted);">/M tokens</div>
                      </>
                    )}
                    {card.primaryMetric === 'measured' && (
                      <>
                        <div class="font-mono text-base font-semibold" style="color: var(--color-tier-measured);">
                          {fmtNum(row.measuredDecodeTokPerSecPerCard ?? 0)}
                        </div>
                        <div class="text-xs" style="color: var(--color-text-muted);">measured tok/s/card</div>
                      </>
                    )}
                    <a href={pathname(calculatorDeepLink(model.id, row))} class="text-xs underline mt-1 inline-block" style="color: var(--color-accent);">
                      {en ? 'tune →' : '调参 →'}
                    </a>
                  </div>
                </li>
              );
            })}
          </ol>
        )}
      </article>
    ))}
  </div>

  <p class="text-xs mt-3" style="color: var(--color-text-muted);">
    {en
      ? 'Methodology: same Roofline math as /calculator with calibrated efficiency from /cases corpus when available; cost formula matches /pricing (assumes $2.5/h/card, $0.10/kWh, PUE 1.3 — compute-only BoM lower bound).'
      : '方法论: 与 /calculator 同 Roofline 公式, 有 /cases 时启用 calibrated efficiency; 成本公式与 /pricing 一致 (假设 $2.5/卡/小时, $0.10/kWh, PUE 1.3 — 纯推理 BoM 下界).'}
  </p>
</section>
